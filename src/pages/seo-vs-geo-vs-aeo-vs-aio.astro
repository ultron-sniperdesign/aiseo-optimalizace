---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("pillar", "seo-vs-geo-vs-aeo-vs-aio");
if (!entry) {
  throw new Error("Pillar entry 'seo-vs-geo-vs-aeo-vs-aio' nenalezena v src/content/pillar/");
}
const { Content, headings } = await render(entry);

/**
 * Auto-generovaný Table of Contents — pouze H2 nadpisy z markdownu.
 * Každý heading má slug (auto-generated od Astro content), který je href anchor.
 */
const tocItems = headings.filter((h) => h.depth === 2);

/**
 * JSON-LD — Article + FAQPage (preserve schema).
 */
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.description,
  dateModified: entry.data.updated,
  datePublished: entry.data.updated,
  inLanguage: "cs-CZ",
  keywords: entry.data.keywords.join(", "),
};

const faqJsonLd =
  entry.data.faq && entry.data.faq.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: entry.data.faq.map((item) => ({
          "@type": "Question",
          name: item.q,
          acceptedAnswer: {
            "@type": "Answer",
            text: item.a,
          },
        })),
      }
    : undefined;

const allLd = faqJsonLd ? [articleJsonLd, faqJsonLd] : [articleJsonLd];

const faqCount = entry.data.faq?.length ?? 0;
---

<BaseLayout title={entry.data.title} description={entry.data.description} jsonLd={allLd}>
  <!-- READING PROGRESS BAR -->
  <div class="progress" id="reading-progress" aria-hidden="true"></div>

  <div class="page">
    <!-- HERO -->
    <section class="hero">
      <span class="eyebrow"><span class="eyebrow__num">★</span> Hlavní průvodce</span>

      <h1 class="display hero__title">{entry.data.title}</h1>

      <p class="hero__lead">{entry.data.description}</p>

      <div class="hero__meta">
        <span>~3 000 slov</span>
        <span>{faqCount} častých otázek</span>
        <span>Srovnávací tabulka</span>
        <span>~12 minut čtení</span>
        <span>Aktualizováno: {entry.data.updated}</span>
      </div>
    </section>

    <!-- TL;DR -->
    <section class="tldr-wrap">
      <aside class="tldr">
        <span class="tldr__mark">TL;DR</span>
        <p class="tldr__text">{entry.data.tldr}</p>
      </aside>
    </section>

    <!-- TOC + ARTICLE LAYOUT -->
    <div class="layout">
      <!-- ToC sidebar (sticky desktop, accordion mobile) -->
      <aside class="toc" aria-label="Obsah článku">
        <details class="toc__details" open>
          <summary class="toc__summary">
            <span class="toc__summary-label">Obsah</span>
            <span class="toc__summary-count">{tocItems.length} kapitol</span>
          </summary>
          <ol class="toc__list">
            {
              tocItems.map((h, i) => (
                <li class="toc__item">
                  <a href={`#${h.slug}`} class="toc__link" data-toc-target={h.slug}>
                    <span class="toc__link-num">{String(i + 1).padStart(2, "0")}</span>
                    <span class="toc__link-text">{h.text}</span>
                  </a>
                </li>
              ))
            }
          </ol>
        </details>
      </aside>

      <!-- ARTICLE BODY -->
      <article class="article">
        <div class="article__prose">
          <Content />
        </div>
      </article>
    </div>

    <!-- FAQ -->
    {
      entry.data.faq && entry.data.faq.length > 0 && (
        <section class="faq" aria-labelledby="faq-title">
          <header class="faq__head">
            <span class="eyebrow"><span class="eyebrow__num">FAQ</span> Časté otázky</span>
            <h2 id="faq-title" class="faq__title">
              Sedm otázek ke <strong>4 zkratkám</strong>
            </h2>
          </header>

          <dl class="faq__list">
            {entry.data.faq.map((item, i) => (
              <div class="faq__item">
                <dt class="faq__q">
                  <span class="faq__q-num">{i + 1}</span>
                  <span>{item.q}</span>
                </dt>
                <dd class="faq__a">{item.a}</dd>
              </div>
            ))}
          </dl>
        </section>
      )
    }

    <!-- BACK TO HOME CTA -->
    <section class="back-cta">
      <a href="/" class="back-cta__link">
        <span aria-hidden="true">←</span>
        Zpět na úvod
      </a>
    </section>
  </div>
</BaseLayout>

<script is:inline>
  // Reading progress bar — top hairline, fills as user scrolls
  (function () {
    const bar = document.getElementById("reading-progress");
    if (!bar) return;
    function update() {
      const max = document.body.scrollHeight - window.innerHeight;
      const pct = max > 0 ? (window.scrollY / max) * 100 : 0;
      bar.style.width = pct + "%";
    }
    window.addEventListener("scroll", update, { passive: true });
    update();
  })();

  // Scroll-spy — highlight current ToC item based on which H2 is in viewport
  (function () {
    const tocLinks = document.querySelectorAll("[data-toc-target]");
    if (!tocLinks.length) return;
    const headings = Array.from(tocLinks)
      .map((link) => {
        const id = link.getAttribute("data-toc-target");
        return id ? document.getElementById(id) : null;
      })
      .filter(Boolean);
    if (!headings.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            tocLinks.forEach((link) => {
              const isActive = link.getAttribute("data-toc-target") === id;
              link.classList.toggle("toc__link--active", isActive);
            });
          }
        });
      },
      { rootMargin: "-20% 0px -70% 0px" }
    );
    headings.forEach((h) => observer.observe(h));
  })();
</script>

<style>
  /* ===== READING PROGRESS BAR ===== */
  .progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    background: var(--color-accent);
    width: 0;
    z-index: 100;
    transition: width 0.1s linear;
  }

  /* ===== PAGE ROOT ===== */
  .page {
    --d: var(--color-accent);
    --d-tint: oklch(0.96 0.022 250);
    --d-soft: oklch(0.86 0.06 250);
  }

  /* ===== TYPOGRAPHY ===== */
  .display {
    font-family: var(--font-sans);
    font-weight: 250;
    letter-spacing: -0.045em;
    line-height: 0.95;
  }

  /* ===== HERO ===== */
  .hero {
    max-width: 80rem;
    margin: 0 auto;
    padding: clamp(3rem, 9vh, 6rem) clamp(1.25rem, 4vw, 4rem) clamp(2rem, 4vw, 3rem);
  }
  .hero__title {
    font-size: clamp(2.25rem, 5.5vw, 4.5rem);
    margin: 1.25rem 0 1.5rem;
    max-width: 22ch;
    color: var(--color-ink);
    line-height: 1;
  }
  .hero__lead {
    font-family: var(--font-sans);
    font-weight: 350;
    font-size: clamp(1.0625rem, 1.5vw, 1.25rem);
    line-height: 1.55;
    color: var(--color-ink-muted);
    max-width: 50rem;
    margin: 0 0 1.75rem;
  }
  .hero__meta {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem 1.5rem;
  }
  .hero__meta span {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .hero__meta span::before {
    content: "";
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    border-radius: 50%;
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: none; }
  }
  .hero > * { animation: rise 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) backwards; }
  .hero > *:nth-child(1) { animation-delay: 0.04s; }
  .hero > *:nth-child(2) { animation-delay: 0.16s; }
  .hero > *:nth-child(3) { animation-delay: 0.28s; }
  .hero > *:nth-child(4) { animation-delay: 0.40s; }

  /* ===== TL;DR ===== */
  .tldr-wrap {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 4rem);
  }
  .tldr {
    background: var(--color-paper-deep);
    border: 1px solid var(--color-rule);
    border-left: 4px solid var(--color-accent);
    border-radius: 8px;
    padding: clamp(1.5rem, 2.5vw, 2.25rem);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 60rem;
  }
  .tldr__mark {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .tldr__mark::before {
    content: "";
    width: 7px;
    height: 7px;
    background: var(--color-accent);
    border-radius: 50%;
  }
  .tldr__text {
    font-family: var(--font-sans);
    font-weight: 380;
    font-size: clamp(1.0625rem, 1.4vw, 1.1875rem);
    line-height: 1.6;
    color: var(--color-ink);
    margin: 0;
  }

  /* ===== LAYOUT (ToC + Article) ===== */
  .layout {
    max-width: 80rem;
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 4rem) clamp(1.25rem, 4vw, 4rem) clamp(3rem, 5vw, 5rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 1024px) {
    .layout {
      grid-template-columns: 18rem 1fr;
      gap: 4rem;
    }
  }

  /* ===== TOC SIDEBAR ===== */
  .toc {
    font-family: var(--font-sans);
  }
  @media (min-width: 1024px) {
    .toc {
      position: sticky;
      top: 5rem;
      align-self: start;
      max-height: calc(100vh - 6rem);
      overflow-y: auto;
    }
  }
  .toc__details {
    border: 1px solid var(--color-rule);
    border-radius: 8px;
    background: var(--color-paper-deep);
  }
  .toc__summary {
    cursor: pointer;
    padding: 1rem 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    list-style: none;
    border-radius: 8px;
    transition: background 0.15s ease;
  }
  .toc__summary::-webkit-details-marker { display: none; }
  .toc__summary:hover { background: var(--color-paper-hover); }
  .toc__summary-label {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.005em;
  }
  .toc__summary-count {
    font-size: 0.8rem;
    color: var(--color-ink-faint);
  }
  .toc__details[open] .toc__summary {
    border-bottom: 1px solid var(--color-rule);
    border-radius: 8px 8px 0 0;
  }

  .toc__list {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
  }
  .toc__item { margin: 0; }
  .toc__link {
    display: flex;
    gap: 0.875rem;
    padding: 0.5rem 1.25rem;
    text-decoration: none;
    color: var(--color-ink-muted);
    font-size: 0.875rem;
    line-height: 1.4;
    transition: all 0.15s ease;
    border-left: 2px solid transparent;
  }
  .toc__link:hover {
    color: var(--color-ink);
    background: var(--color-paper-hover);
  }
  .toc__link--active {
    color: var(--color-accent);
    font-weight: 500;
    border-left-color: var(--color-accent);
    background: var(--d-tint);
  }
  .toc__link-num {
    flex: none;
    font-variant-numeric: tabular-nums;
    color: var(--color-ink-faint);
    font-weight: 500;
    font-size: 0.78rem;
    min-width: 1.25rem;
  }
  .toc__link--active .toc__link-num { color: var(--color-accent); }
  .toc__link-text {
    flex: 1;
  }

  /* ===== ARTICLE BODY ===== */
  .article {
    min-width: 0;
  }
  .article__prose {
    max-width: 42rem;
    font-family: var(--font-sans);
  }

  /* Markdown rendered body — sans typography matching sections */
  .article__prose :global(h2) {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin: 3rem 0 1.5rem;
    color: var(--color-ink);
    scroll-margin-top: 5rem;
  }
  .article__prose :global(h2:first-child) { margin-top: 0; }
  .article__prose :global(h3) {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 1.25rem;
    line-height: 1.3;
    letter-spacing: -0.018em;
    margin: 2.25rem 0 0.875rem;
    color: var(--color-ink);
    scroll-margin-top: 5rem;
  }
  .article__prose :global(p) {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-ink);
    margin: 0 0 1.125rem;
  }
  .article__prose :global(p strong) { font-weight: 600; }
  .article__prose :global(p em) { font-style: italic; }
  .article__prose :global(a) {
    color: var(--color-accent);
    border-bottom: 1px solid var(--d-soft);
    text-decoration: none;
    transition: border-color 0.15s ease;
  }
  .article__prose :global(a:hover) { border-bottom-color: var(--color-accent); }

  /* První paragraf po H2 dostává lead treatment */
  .article__prose :global(h2 + p) {
    font-size: 1.1875rem;
    line-height: 1.55;
    font-weight: 400;
    color: var(--color-ink);
    padding-left: 1rem;
    border-left: 2px solid var(--color-accent);
    margin-bottom: 1.5rem;
  }

  /* Lists */
  .article__prose :global(ul),
  .article__prose :global(ol) {
    margin: 1.25rem 0;
    padding-left: 0;
    list-style: none;
  }
  .article__prose :global(ul li) {
    position: relative;
    padding-left: 1.625rem;
    margin-bottom: 0.625rem;
    line-height: 1.65;
    font-size: 1.0625rem;
  }
  .article__prose :global(ul li::before) {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7rem;
    width: 0.75rem;
    height: 1px;
    background: var(--color-accent);
  }
  .article__prose :global(ol) {
    counter-reset: ord;
  }
  .article__prose :global(ol li) {
    position: relative;
    padding-left: 2.25rem;
    margin-bottom: 0.75rem;
    line-height: 1.65;
    font-size: 1.0625rem;
    counter-increment: ord;
  }
  .article__prose :global(ol li::before) {
    content: counter(ord);
    position: absolute;
    left: 0;
    top: 0.15em;
    width: 1.625rem;
    height: 1.625rem;
    border-radius: 50%;
    background: var(--d-tint);
    border: 1px solid var(--d-soft);
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  /* Tabulky */
  .article__prose :global(table) {
    width: 100%;
    margin: 1.5rem 0;
    border-collapse: collapse;
    font-size: 0.95rem;
    border: 1px solid var(--color-rule);
    border-radius: 8px;
    overflow: hidden;
  }
  .article__prose :global(thead) { background: var(--d-tint); }
  .article__prose :global(th) {
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    color: var(--color-accent);
    border-bottom: 1px solid var(--d-soft);
    font-size: 0.875rem;
  }
  .article__prose :global(td) {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-rule);
    color: var(--color-ink);
    vertical-align: top;
  }
  .article__prose :global(tr:last-child td) { border-bottom: none; }

  /* Code */
  .article__prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-paper-deep);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--color-ink);
  }
  .article__prose :global(pre) {
    background: oklch(0.18 0.012 260);
    color: oklch(0.92 0.012 80);
    padding: 1.25rem 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
    border-left: 3px solid var(--color-accent);
  }
  .article__prose :global(pre code) {
    background: transparent;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.65;
    color: inherit;
  }

  /* Blockquotes */
  .article__prose :global(blockquote) {
    margin: 2rem 0;
    padding: 0.5rem 0 0.5rem 1.5rem;
    border-left: 3px solid var(--color-accent);
    font-style: normal;
    color: var(--color-ink-muted);
    font-size: 1.0625rem;
    line-height: 1.6;
  }
  .article__prose :global(blockquote p) { margin: 0 0 0.5rem; color: inherit; }
  .article__prose :global(blockquote p:last-child) { margin-bottom: 0; }

  /* HR */
  .article__prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-rule);
    margin: 2.5rem 0;
  }

  /* ===== FAQ ===== */
  .faq {
    max-width: 80rem;
    margin: 0 auto;
    padding: clamp(3rem, 5vw, 5rem) clamp(1.25rem, 4vw, 4rem);
    border-top: 1px solid var(--color-rule);
    background: var(--color-paper-deep);
  }
  .faq__head {
    margin-bottom: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .faq__title {
    font-family: var(--font-sans);
    font-weight: 280;
    font-size: clamp(1.625rem, 3vw, 2.5rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--color-ink);
    margin: 0;
  }
  .faq__title strong { font-weight: 600; }

  .faq__list {
    max-width: 60rem;
    margin: 0;
  }
  .faq__item {
    border-top: 1px solid var(--color-rule);
    padding: 1.75rem 0;
  }
  .faq__item:last-child { border-bottom: 1px solid var(--color-rule); }
  .faq__q {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(1.0625rem, 1.5vw, 1.25rem);
    line-height: 1.35;
    letter-spacing: -0.018em;
    color: var(--color-ink);
    margin-bottom: 0.875rem;
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }
  .faq__q-num {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--d-tint);
    border: 1px solid var(--d-soft);
    color: var(--color-accent);
    font-size: 0.85rem;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: center;
  }
  .faq__a {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-ink-muted);
    max-width: 50rem;
    margin: 0 0 0 3rem;
  }

  /* ===== BACK CTA ===== */
  .back-cta {
    max-width: 80rem;
    margin: 0 auto;
    padding: clamp(3rem, 5vw, 4rem) clamp(1.25rem, 4vw, 4rem) clamp(3rem, 5vw, 5rem);
    text-align: center;
  }
  .back-cta__link {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-ink-muted);
    text-decoration: none;
    padding: 0.625rem 1.25rem;
    border: 1px solid var(--color-rule-strong);
    border-radius: 999px;
    transition: all 0.2s ease;
  }
  .back-cta__link:hover {
    color: var(--color-ink);
    border-color: var(--color-ink);
    transform: translateX(-2px);
  }
</style>
