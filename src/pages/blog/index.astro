---
import BaseLayout from "~/layouts/BaseLayout.astro";
import SniperDesignSmallContact from "~/components/sniperdesign/SmallContact.astro";
import { getCollection } from "astro:content";

/**
 * Blog list page — všechny články z articles collection, sort by `updated` DESC.
 * Filter podle category je implementován client-side přes data-category atribut na cards.
 */
const articles = (await getCollection("articles")).sort((a, b) =>
  b.data.updated.localeCompare(a.data.updated),
);

/** Category labels pro filter chips + per-card tag. */
const categoryLabel: Record<string, string> = {
  tutorial: "Tutorial",
  analysis: "Analýza",
  defensive: "Defenzivní",
  "case-study": "Case study",
};

/** Reading time per článek — dynamicky z body. */
function calcReading(body: string): { wordCount: number; minutes: number } {
  const wc = body
    .replace(/<[^>]+>/g, " ")
    .replace(/[#*_`>~]/g, " ")
    .split(/\s+/)
    .filter(Boolean).length;
  return { wordCount: Math.round(wc / 100) * 100, minutes: Math.max(1, Math.round(wc / 200)) };
}

/** Distinct categories ze článků pro filter chips. */
const usedCategories = Array.from(new Set(articles.map((a) => a.data.category)));

/** Dynamic stats pro fact-density v leadu. */
const totalWords = articles.reduce((sum, a) => {
  const wc = (a.body ?? "").replace(/<[^>]+>/g, " ").replace(/[#*_`>~]/g, " ").split(/\s+/).filter(Boolean).length;
  return sum + wc;
}, 0);
const avgWords = Math.round(totalWords / articles.length / 100) * 100;
const newestDate = articles[0]?.data.updated;

const pageTitle = "Blog: aktuální obsah o AI SEO";
const pageDescription =
  "Tutoriály, analýzy a defenzivní průvodce AI vyhledáváním pro český trh. SEO, GEO, AEO i AIO — nový článek pravidelně.";

/** FAQ — 6 reálných otázek o blogu (zdroje pro AI scrapery + lidské čtenáře). */
const faq = [
  {
    q: "Co na blogu najdu?",
    a: "Praktické tutoriály (postupy krok za krokem), analýzy (rozbor trendů a změn) a defenzivní průvodce (jak se vypořádat s problémy typu zero-click éra Google AI Overviews). Každý článek má 1 700–3 000 slov, schema markup (Article + FAQPage + případně HowTo) a fact-density 3+ konkrétní fakta na 100 slov. Cíleno na provozovatele webů, e-shopů a marketéry.",
  },
  {
    q: "Jak často vychází nový článek?",
    a: "Aktuálně přibývá průměrně 1 článek týdně. Plánujeme přejít na automatizovanou denní kadenci přes AI skill. Datum poslední aktualizace každého článku je viditelně zobrazené v hlavičce; všechny články se 1× ročně přepisují, aby data zůstávala aktuální (datový refresh, fix broken linků, screenshot updaty).",
  },
  {
    q: "Pro koho je obsah určený?",
    a: "Pro tři typy čtenářů: (1) provozovatelé webů a e-shopů, kteří chtějí, aby je AI engine citoval místo přeskočil; (2) marketéři a SEO specialisté hledající aktuální postupy pro AI éru; (3) developery a content stratégy, kteří implementují schema markup, FAQPage a HowTo strukturu. Texty jsou v češtině, s důrazem na CZ trh (Seznam, GBP, ceny v Kč).",
  },
  {
    q: "Jaký je rozdíl mezi blogem a hlavním průvodcem na webu?",
    a: "Hlavní průvodce (/seo-vs-geo-vs-aeo-vs-aio/) je pillar content ~3 000 slov, který drží přehled napříč 4 disciplínami SEO/GEO/AEO/AIO. Sekce /seo/, /geo/, /aeo/ a /aio/ jsou hub-and-spoke clusters s konceptuálním rozborem každé disciplíny. Blog je sbírka samostatných tutoriálů a analýz, které jdou do hloubky konkrétních problémů (audit, nástroje, local SEO, měření, strukturování pillar contentu).",
  },
  {
    q: "Mohu se přihlásit k odběru nových článků?",
    a: "Aktuálně nemá web RSS feed ani newsletter — pracujeme na tom. Nejsnadnější způsob sledovat nové články: bookmark této stránky (/blog/) nebo follow GitHub repository. RSS feed přidáme současně se spuštěním automatizované denní publikace.",
  },
  {
    q: "Můžu některý článek použít ve své práci, citovat nebo přeložit?",
    a: "Ano, s atribucí. Citace v rámci 'fair use' (krátké citace s odkazem na zdroj) je vítaná a podpoří GEO/AEO scénáře, na které sami v článcích cílíme. Pro celkové překlady, embedování v komerčních produktech nebo PDF distribuci napište na kontakt přes Sniperdesign — jsme open to spolupráci.",
  },
];

/** JSON-LD: Blog + ItemList (8× BlogPosting) + BreadcrumbList + FAQPage */
const blogJsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: pageTitle,
  description: pageDescription,
  url: "https://aiseo-optimalizace.cz/blog/",
  inLanguage: "cs-CZ",
  publisher: {
    "@type": "Organization",
    name: "aiseo-optimalizace.cz",
    url: "https://aiseo-optimalizace.cz/",
  },
};

const itemListJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListOrder: "https://schema.org/ItemListOrderDescending",
  numberOfItems: articles.length,
  itemListElement: articles.map((entry, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: `https://aiseo-optimalizace.cz/blog/${entry.data.slug}/`,
    item: {
      "@type": "BlogPosting",
      headline: entry.data.title,
      description: entry.data.description,
      datePublished: entry.data.updated,
      dateModified: entry.data.updated,
      url: `https://aiseo-optimalizace.cz/blog/${entry.data.slug}/`,
      inLanguage: "cs-CZ",
      keywords: entry.data.keywords?.join(", "),
    },
  })),
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Úvod", item: "https://aiseo-optimalizace.cz/" },
    { "@type": "ListItem", position: 2, name: "Blog", item: "https://aiseo-optimalizace.cz/blog/" },
  ],
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};

const allLd = [blogJsonLd, itemListJsonLd, breadcrumbJsonLd, faqJsonLd];

/** Answer block — 40–60 slov, definice 'Blog je…' pro AI scrapery + lidské. */
const answerText =
  "Blog aiseo-optimalizace.cz je sbírka praktických tutoriálů, analýz a defenzivních průvodců pro AI éru vyhledávání. Každý článek je strukturovaný pro citovatelnost v ChatGPT, Perplexity i Google AI Overviews — answer block, FAQPage schema, 3+ konkrétní fakta na 100 slov. Pro provozovatele webů, e-shopů a marketéry, kteří chtějí, aby AI engine jejich obsah citoval, ne přeskočil.";
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={allLd} image="/og/default.png">
  <div class="page">
    <!-- HERO -->
    <section class="hero">
      <nav class="hero__crumbs" aria-label="Drobečková navigace">
        <a href="/">Úvod</a>
        <span class="crumb-sep">›</span>
        <span class="hero__crumb-pill">Blog</span>
      </nav>

      <h1 class="display hero__title">
        <span class="hl">Aktuální obsah</span> o AI&nbsp;vyhledávání
      </h1>

      <p class="hero__lead">
        Tutoriály, analýzy a defenzivní průvodce pro provozovatele webů a e&#8209;shopů, kteří chtějí být <strong>citováni v ChatGPT, Perplexity i v Google AI Overviews</strong>. Nový článek pravidelně, bez vaty.
      </p>

      <div class="hero__meta">
        <span>{articles.length} článků</span>
        <span>{usedCategories.length} kategorií</span>
        <span>průměrně ~{avgWords.toLocaleString("cs-CZ")} slov / článek</span>
        <span>nejnovější: {newestDate}</span>
      </div>
    </section>

    <!-- ANSWER BLOCK -->
    <section class="answer">
      <div class="answer__inner">
        <span class="answer__mark">Stručná definice</span>
        <p class="answer__text">{answerText}</p>
      </div>
    </section>

    <!-- FILTER CHIPS -->
    <section class="filter-bar" aria-label="Filtr článků podle kategorie">
      <button class="chip chip--active" data-filter="all" type="button">
        Všechny <span class="chip__count">({articles.length})</span>
      </button>
      {
        usedCategories.map((cat) => {
          const count = articles.filter((a) => a.data.category === cat).length;
          return (
            <button class="chip" data-filter={cat} type="button">
              {categoryLabel[cat] ?? cat}
              <span class="chip__count">({count})</span>
            </button>
          );
        })
      }
    </section>

    <!-- ARTICLES GRID -->
    <section class="articles" aria-label="Seznam článků">
      <div class="articles__grid">
        {
          articles.map((entry) => {
            const reading = calcReading(entry.body ?? "");
            return (
              <a
                href={`/blog/${entry.data.slug}/`}
                class="acard"
                data-category={entry.data.category}
              >
                <div class="acard__header">
                  <span class="acard__tag">{categoryLabel[entry.data.category] ?? entry.data.category}</span>
                  <span class="acard__time">{reading.minutes} min</span>
                </div>
                <h2 class="acard__title">{entry.data.title}</h2>
                <p class="acard__desc">{entry.data.description}</p>
                <div class="acard__meta">
                  <span>{entry.data.updated}</span>
                  <span>~{reading.wordCount.toLocaleString("cs-CZ")} slov</span>
                  <span class="acard__cta">
                    Číst <span aria-hidden="true">→</span>
                  </span>
                </div>
              </a>
            );
          })
        }
      </div>
    </section>

    <!-- SNIPERDESIGN SMALL CONTACT — nad FAQ -->
    <SniperDesignSmallContact />

    <!-- FAQ -->
    <section class="faq" aria-labelledby="faq-title">
      <header class="faq__head">
        <span class="eyebrow"><span class="eyebrow__num">FAQ</span> Časté otázky</span>
        <h2 id="faq-title" class="faq__title">
          Šest otázek, které k <span class="hl">blogu</span> <strong>nejčastěji padají</strong>
        </h2>
      </header>

      <dl class="faq__list">
        {faq.map((item, i) => (
          <div class="faq__item">
            <dt class="faq__q">
              <span class="faq__q-num">{i + 1}</span>
              <span>{item.q}</span>
            </dt>
            <dd class="faq__a">{item.a}</dd>
          </div>
        ))}
      </dl>
    </section>
  </div>
</BaseLayout>

<script is:inline>
  // Filter chips — client-side toggle pro show/hide cards podle data-category
  (function () {
    const chips = document.querySelectorAll(".chip");
    const cards = document.querySelectorAll(".acard");
    chips.forEach((chip) => {
      chip.addEventListener("click", function () {
        const filter = this.getAttribute("data-filter");
        chips.forEach((c) => c.classList.remove("chip--active"));
        this.classList.add("chip--active");
        cards.forEach((card) => {
          const cat = card.getAttribute("data-category");
          card.style.display = filter === "all" || cat === filter ? "" : "none";
        });
      });
    });
  })();
</script>

<style>
  /* ===== PAGE ROOT ===== */
  .page {
    --d: var(--color-accent);
    --d-tint: oklch(0.96 0.022 250);
    --d-soft: oklch(0.86 0.06 250);
  }

  /* ===== TYPOGRAPHY ===== */
  .display {
    font-family: var(--font-sans);
    font-weight: 250;
    letter-spacing: -0.045em;
    line-height: 0.95;
  }

  /* ===== HERO ===== */
  .hero {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(3rem, 9vh, 6rem) var(--space-section-x) clamp(2rem, 4vw, 3rem);
  }
  .hero__crumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    flex-wrap: wrap;
  }
  .hero__crumbs a {
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .hero__crumbs a:hover { color: var(--color-ink); }
  .hero__crumb-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    background: var(--d-tint);
    color: var(--d);
    border: 1px solid var(--d-soft);
    border-radius: 999px;
    font-weight: 500;
  }
  .hero__crumb-pill::before {
    content: "";
    width: 7px;
    height: 7px;
    background: var(--d);
    border-radius: 50%;
  }
  .crumb-sep { opacity: 0.4; }

  .hero__title {
    font-size: clamp(1.875rem, 4.5vw, 3.75rem);
    margin: 0 0 1.5rem;
    max-width: 24ch;
    color: var(--color-ink);
    line-height: 1.05;
  }
  .hero__lead {
    font-family: var(--font-sans);
    font-weight: 350;
    font-size: clamp(1.0625rem, 1.5vw, 1.25rem);
    line-height: 1.55;
    color: var(--color-ink-muted);
    max-width: 50rem;
    margin: 0 0 1.75rem;
  }
  .hero__lead strong { font-weight: 600; color: var(--color-ink); }
  .hero__meta {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem 1.5rem;
  }
  .hero__meta span {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .hero__meta span::before {
    content: "";
    width: 6px;
    height: 6px;
    background: var(--d);
    border-radius: 50%;
  }

  /* ===== FILTER CHIPS ===== */
  .filter-bar {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: 0 var(--space-section-x) clamp(2rem, 3vw, 2.5rem);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .chip {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.5rem 1rem;
    background: var(--color-paper);
    border: 1px solid var(--color-rule-strong);
    border-radius: 999px;
    color: var(--color-ink);
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .chip:hover {
    border-color: var(--d);
    color: var(--d);
  }
  .chip__count {
    font-size: 0.78rem;
    color: var(--color-ink-faint);
  }
  .chip--active {
    background: var(--d);
    border-color: var(--d);
    color: var(--color-paper);
  }
  .chip--active .chip__count { color: color-mix(in oklch, var(--color-paper) 75%, transparent); }

  /* ===== ARTICLES GRID ===== */
  .articles {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: 0 var(--space-section-x) clamp(4rem, 8vw, 6rem);
  }
  .articles__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1rem;
  }
  .acard {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding: 1.75rem;
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }
  .acard::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--d);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.2s ease;
  }
  .acard:hover {
    transform: translateY(-2px);
    border-color: var(--d-soft);
    box-shadow: 0 6px 18px -8px color-mix(in oklch, var(--d) 30%, transparent);
  }
  .acard:hover::before { transform: scaleY(1); }
  .acard__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 0.78rem;
  }
  .acard__tag {
    background: var(--d-tint);
    color: var(--d);
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .acard__time {
    color: var(--color-ink-faint);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }
  .acard__title {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.018em;
    line-height: 1.3;
    color: var(--color-ink);
    margin: 0;
  }
  .acard__desc {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
    margin: 0;
    flex: 1;
  }
  .acard__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--color-ink-faint);
    border-top: 1px solid var(--color-rule);
    padding-top: 0.75rem;
    margin-top: auto;
  }
  .acard__cta {
    margin-left: auto;
    color: var(--d);
    font-weight: 600;
  }

  /* ===== ANSWER BLOCK (sjednocený s article pages) ===== */
  .answer {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: 0 var(--space-section-x) clamp(2.5rem, 5vw, 4rem);
  }
  .answer__inner {
    background: var(--color-paper-deep);
    border: 1px solid var(--color-rule);
    border-left: 3px solid var(--d);
    border-radius: 8px;
    padding: clamp(1.75rem, 2.5vw, 2.25rem);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 60rem;
  }
  .answer__mark {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--d);
  }
  .answer__text {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.55;
    color: var(--color-ink);
    margin: 0;
  }

  /* ===== FAQ (sjednocený s article pages) ===== */
  .faq {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(2rem, 4vw, 3rem) var(--space-section-x) clamp(4rem, 8vw, 6rem);
  }
  .faq__head {
    max-width: 50rem;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--color-ink-muted);
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .eyebrow__num {
    color: var(--d);
    font-weight: 600;
  }
  .faq__title {
    font-family: var(--font-sans);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 250;
    letter-spacing: -0.025em;
    margin: 0.75rem 0 0;
    color: var(--color-ink);
    line-height: 1.1;
  }
  .faq__list {
    max-width: 60rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .faq__item {
    border-top: 1px solid var(--color-rule);
    padding-top: 1.5rem;
  }
  .faq__q {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-bottom: 0.625rem;
    display: flex;
    gap: 0.875rem;
    align-items: baseline;
    line-height: 1.35;
  }
  .faq__q-num {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--d);
    flex-shrink: 0;
  }
  .faq__a {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0 0 0 1.875rem;
  }
</style>
