---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

/**
 * Blog list page — všechny články z articles collection, sort by `updated` DESC.
 * Filter podle category je implementován client-side přes data-category atribut na cards.
 */
const articles = (await getCollection("articles")).sort((a, b) =>
  b.data.updated.localeCompare(a.data.updated),
);

/** Category labels pro filter chips + per-card tag. */
const categoryLabel: Record<string, string> = {
  tutorial: "Tutorial",
  analysis: "Analýza",
  defensive: "Defenzivní",
  "case-study": "Case study",
};

/** Reading time per článek — dynamicky z body. */
function calcReading(body: string): { wordCount: number; minutes: number } {
  const wc = body
    .replace(/<[^>]+>/g, " ")
    .replace(/[#*_`>~]/g, " ")
    .split(/\s+/)
    .filter(Boolean).length;
  return { wordCount: Math.round(wc / 100) * 100, minutes: Math.max(1, Math.round(wc / 200)) };
}

/** Distinct categories ze článků pro filter chips. */
const usedCategories = Array.from(new Set(articles.map((a) => a.data.category)));

const pageTitle = "Blog: aktuální obsah o AI SEO";
const pageDescription =
  "Tutoriály, analýzy a defenzivní průvodce AI vyhledáváním pro český trh. SEO, GEO, AEO i AIO — nový článek pravidelně.";
---

<BaseLayout title={pageTitle} description={pageDescription} image="/og/default.png">
  <div class="page">
    <!-- HERO -->
    <section class="hero">
      <nav class="hero__crumbs" aria-label="Drobečková navigace">
        <a href="/">Úvod</a>
        <span class="crumb-sep">›</span>
        <span class="hero__crumb-pill">Blog</span>
      </nav>

      <h1 class="display hero__title">
        <span class="hl">Aktuální obsah</span> o AI&nbsp;vyhledávání
      </h1>

      <p class="hero__lead">
        Tutoriály, analýzy a defenzivní průvodce pro provozovatele webů a e&#8209;shopů, kteří chtějí být citováni v ChatGPT, Perplexity i v Google AI Overviews. <strong>Nový článek pravidelně</strong>, bez vaty.
      </p>

      <div class="hero__meta">
        <span>{articles.length} článků</span>
        <span>{usedCategories.length} kategorií</span>
        <span>SEO + GEO + AEO + AIO</span>
      </div>
    </section>

    <!-- FILTER CHIPS -->
    <section class="filter-bar" aria-label="Filtr článků podle kategorie">
      <button class="chip chip--active" data-filter="all" type="button">
        Všechny <span class="chip__count">({articles.length})</span>
      </button>
      {
        usedCategories.map((cat) => {
          const count = articles.filter((a) => a.data.category === cat).length;
          return (
            <button class="chip" data-filter={cat} type="button">
              {categoryLabel[cat] ?? cat}
              <span class="chip__count">({count})</span>
            </button>
          );
        })
      }
    </section>

    <!-- ARTICLES GRID -->
    <section class="articles" aria-label="Seznam článků">
      <div class="articles__grid">
        {
          articles.map((entry) => {
            const reading = calcReading(entry.body ?? "");
            return (
              <a
                href={`/blog/${entry.data.slug}/`}
                class="acard"
                data-category={entry.data.category}
              >
                <div class="acard__header">
                  <span class="acard__tag">{categoryLabel[entry.data.category] ?? entry.data.category}</span>
                  <span class="acard__time">{reading.minutes} min</span>
                </div>
                <h2 class="acard__title">{entry.data.title}</h2>
                <p class="acard__desc">{entry.data.description}</p>
                <div class="acard__meta">
                  <span>{entry.data.updated}</span>
                  <span>~{reading.wordCount.toLocaleString("cs-CZ")} slov</span>
                  <span class="acard__cta">
                    Číst <span aria-hidden="true">→</span>
                  </span>
                </div>
              </a>
            );
          })
        }
      </div>
    </section>
  </div>
</BaseLayout>

<script is:inline>
  // Filter chips — client-side toggle pro show/hide cards podle data-category
  (function () {
    const chips = document.querySelectorAll(".chip");
    const cards = document.querySelectorAll(".acard");
    chips.forEach((chip) => {
      chip.addEventListener("click", function () {
        const filter = this.getAttribute("data-filter");
        chips.forEach((c) => c.classList.remove("chip--active"));
        this.classList.add("chip--active");
        cards.forEach((card) => {
          const cat = card.getAttribute("data-category");
          card.style.display = filter === "all" || cat === filter ? "" : "none";
        });
      });
    });
  })();
</script>

<style>
  /* ===== PAGE ROOT ===== */
  .page {
    --d: var(--color-accent);
    --d-tint: oklch(0.96 0.022 250);
    --d-soft: oklch(0.86 0.06 250);
  }

  /* ===== TYPOGRAPHY ===== */
  .display {
    font-family: var(--font-sans);
    font-weight: 250;
    letter-spacing: -0.045em;
    line-height: 0.95;
  }

  /* ===== HERO ===== */
  .hero {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(3rem, 9vh, 6rem) var(--space-section-x) clamp(2rem, 4vw, 3rem);
  }
  .hero__crumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    flex-wrap: wrap;
  }
  .hero__crumbs a {
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .hero__crumbs a:hover { color: var(--color-ink); }
  .hero__crumb-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    background: var(--d-tint);
    color: var(--d);
    border: 1px solid var(--d-soft);
    border-radius: 999px;
    font-weight: 500;
  }
  .hero__crumb-pill::before {
    content: "";
    width: 7px;
    height: 7px;
    background: var(--d);
    border-radius: 50%;
  }
  .crumb-sep { opacity: 0.4; }

  .hero__title {
    font-size: clamp(1.875rem, 4.5vw, 3.75rem);
    margin: 0 0 1.5rem;
    max-width: 24ch;
    color: var(--color-ink);
    line-height: 1.05;
  }
  .hero__lead {
    font-family: var(--font-sans);
    font-weight: 350;
    font-size: clamp(1.0625rem, 1.5vw, 1.25rem);
    line-height: 1.55;
    color: var(--color-ink-muted);
    max-width: 50rem;
    margin: 0 0 1.75rem;
  }
  .hero__lead strong { font-weight: 600; color: var(--color-ink); }
  .hero__meta {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem 1.5rem;
  }
  .hero__meta span {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .hero__meta span::before {
    content: "";
    width: 6px;
    height: 6px;
    background: var(--d);
    border-radius: 50%;
  }

  /* ===== FILTER CHIPS ===== */
  .filter-bar {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: 0 var(--space-section-x) clamp(2rem, 3vw, 2.5rem);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .chip {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.5rem 1rem;
    background: var(--color-paper);
    border: 1px solid var(--color-rule-strong);
    border-radius: 999px;
    color: var(--color-ink);
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .chip:hover {
    border-color: var(--d);
    color: var(--d);
  }
  .chip__count {
    font-size: 0.78rem;
    color: var(--color-ink-faint);
  }
  .chip--active {
    background: var(--d);
    border-color: var(--d);
    color: var(--color-paper);
  }
  .chip--active .chip__count { color: color-mix(in oklch, var(--color-paper) 75%, transparent); }

  /* ===== ARTICLES GRID ===== */
  .articles {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: 0 var(--space-section-x) clamp(4rem, 8vw, 6rem);
  }
  .articles__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1rem;
  }
  .acard {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding: 1.75rem;
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }
  .acard::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--d);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.2s ease;
  }
  .acard:hover {
    transform: translateY(-2px);
    border-color: var(--d-soft);
    box-shadow: 0 6px 18px -8px color-mix(in oklch, var(--d) 30%, transparent);
  }
  .acard:hover::before { transform: scaleY(1); }
  .acard__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 0.78rem;
  }
  .acard__tag {
    background: var(--d-tint);
    color: var(--d);
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .acard__time {
    color: var(--color-ink-faint);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }
  .acard__title {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.018em;
    line-height: 1.3;
    color: var(--color-ink);
    margin: 0;
  }
  .acard__desc {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
    margin: 0;
    flex: 1;
  }
  .acard__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--color-ink-faint);
    border-top: 1px solid var(--color-rule);
    padding-top: 0.75rem;
    margin-top: auto;
  }
  .acard__cta {
    margin-left: auto;
    color: var(--d);
    font-weight: 600;
  }
</style>
