---
import BaseLayout from "~/layouts/BaseLayout.astro";
import MockupPage from "~/components/MockupPage.astro";
import SniperDesignSmallContact from "~/components/sniperdesign/SmallContact.astro";

const pageTitle = "AI SEO Wireframe Pack — sedm typů stránek pro AI vyhledávání";
const pageDescription =
  "Pack obsahuje sedm typů stránek s hotovými texty: homepage, produkt, kategorie, blog (článek + výpis), prodejní landing a kontakt. Aplikujete na svůj web během odpoledne. 1 490 Kč jednorázově.";

/**
 * STRIPE CHECKOUT URL — placeholder dokud nedorazí reálná URL.
 * Update jen na jednom místě, propíše se do všech CTA tlačítek.
 * Reálná URL po vyřešení Stripe komplikace.
 */
const STRIPE_CHECKOUT_URL = "#TODO-stripe-checkout";

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Co konkrétně Pack obsahuje?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sedm typů stránek (homepage, produkt, kategorie, blog článek, blog výpis, prodejní landing, kontakt) — pro každou anotovaný wireframe, šablony textů a schema markup příklady (Product, FAQPage, Article, LocalBusiness). Plus krok-za-krokem návod, jak to aplikovat na váš web. Vše v jednom master PDF (~50 stran).",
      },
    },
    {
      "@type": "Question",
      name: "Mohu Pack použít na jakémkoli CMS?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ano. Pack je framework, ne plugin. Wireframy, šablony textů a schema markup příklady aplikujete na libovolný systém — Upgates, Shoptet, WordPress, Webflow, custom Astro, Next.js i statické HTML. Specifické instrukce pro Upgates a Shoptet jsou navíc.",
      },
    },
    {
      "@type": "Question",
      name: "Co když si nejsem jistý, jestli to zvládnu?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Pack obsahuje krok-za-krokem návod psaný pro provozovatele webů, ne pro vývojáře. Většinu úprav (text, schema markup, struktura) zvládnete sami za odpoledne. Pokud preferujete, abychom to udělali za vás, podívejte se na AI SEO audit od Sniperdesign za 9 990 Kč — projdeme váš web a předáme prioritní seznam úprav.",
      },
    },
    {
      "@type": "Question",
      name: "Dostanu aktualizace Packu, pokud se AI SEO změní?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ano. AI vyhledávání se vyvíjí, Pack udržujeme aktuální. Drobné aktualizace (nová schema markup pravidla, změny v ChatGPT/Perplexity citation systémech) dostanete zdarma e-mailem. Pokud bude potřeba zásadní revize struktury (např. nový typ AI engine), oznámíme to dopředu — typicky 1× ročně.",
      },
    },
    {
      "@type": "Question",
      name: "Je Pack vhodný i pro web bez blogu nebo bez e-shopu?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ano. Pack obsahuje sedm typů stránek, ale nemusíte aplikovat všechny. Pokud máte jen služby (žádný e-shop), využijete homepage, prodejní landing, kontakt — případně blog článek. Pokud máte e-shop bez blogu, naopak produkt, kategorii a kontakt. Pack je modulární, vezmete si jen typy, které váš web obsahuje.",
      },
    },
  ],
};

const pageTypes = [
  {
    num: 1,
    title: "Homepage",
    desc: "Wireframe + anotace + šablony textů. Stejný framework jako v free PDF — rozšířený o varianty pro různé typy byznysu (e-shop, služby, agentura, freelance).",
    pageTitle: "Homepage",
    tone: "primary" as const,
  },
  {
    num: 2,
    title: "Produktová stránka",
    desc: "Detail produktu — title pattern, Product schema, FAQ se strukturovanými daty, related products. AI ji rozpozná jako shopable.",
    pageTitle: "Produkt",
    tone: "primary" as const,
  },
  {
    num: 3,
    title: "Kategoriální stránka",
    desc: "Listing s filtry, kategoriální popis pro AI, schema markup CollectionPage, AI-friendly hierarchie značek a podtřídění.",
    pageTitle: "Kategorie",
    tone: "primary" as const,
  },
  {
    num: 4,
    title: "Blog článek",
    desc: "Detail článku s answer block 40–60 slov, FAQPage schema, strukturovaná data autora. Citovatelný v ChatGPT i Google AI Overviews.",
    pageTitle: "Blog článek",
    tone: "accent" as const,
  },
  {
    num: 5,
    title: "Blog výpis článků",
    desc: "Listing článků s filtry, paginace, autoreferenční schema, hub-and-spoke prolinkování pro AI rozpoznání tématu.",
    pageTitle: "Blog výpis",
    tone: "accent" as const,
  },
  {
    num: 6,
    title: "Prodejní landing",
    desc: "Pro službu nebo produkt. Varianta pro lead generation (form pro sběr e-mailů) i pro direct-purchase (CTA s odkazem na checkout). Social proof, FAQ, risk reduction — vše ready.",
    pageTitle: "Prodejní landing",
    tone: "accent" as const,
  },
  {
    num: 7,
    title: "Kontaktní stránka",
    desc: "Kontaktní formulář, mapa, NAP data (Name, Address, Phone), LocalBusiness schema. AI ji rozpozná jako oficiální entity contact.",
    pageTitle: "Kontakt",
    tone: "neutral" as const,
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={faqJsonLd}>
  <main class="pack">
    <!-- ===== HERO ===== -->
    <section class="pack-hero">
      <div class="pack-hero__inner">
        <div class="pack-hero__copy">
          <span class="pack-hero__eyebrow">Pack · pro celý web</span>
          <h1 class="pack-hero__title">
            Postavte web, kterému AI rozumí —<br />
            <strong>celý, ne jen homepage</strong>
          </h1>
          <p class="pack-hero__urgency">
            Bez struktury mimo homepage budete v AI odpovědích snadno přehlédnutí.
            <strong>Čím déle čekáte, tím víc obsahu pak budete předělávat.</strong>
          </p>
          <p class="pack-hero__lead">
            Wireframe Pack obsahuje sedm typů stránek se šablonami textů, schema markupem
            a krok-za-krokem návodem aplikace. Vše v jednom master PDF (~50 stran).
            Aplikujete na svůj web během odpoledne — bez konzultantů, bez měsíců práce.
          </p>

          <div class="pack-hero__pricing">
            <span class="pack-price">1&nbsp;490&nbsp;Kč</span>
            <span class="pack-price__detail">jednorázově, bez DPH</span>
          </div>

          <!-- PRIMARY CTA — Stripe checkout -->
          <div class="pack-hero__buy" id="koupit-pack">
            <a
              href={STRIPE_CHECKOUT_URL}
              class="pack-buy-btn"
              aria-label="Koupit AI SEO Wireframe Pack za 1 490 Kč"
            >
              Koupit Pack za 1&nbsp;490&nbsp;Kč
              <svg width="16" height="16" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path
                  d="M1 7H13M13 7L7 1M13 7L7 13"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
            </a>
            <p class="pack-hero__trust-line">
              Platba kartou (Stripe) · faktura na firmu · bez předplatného
            </p>
          </div>

          <!-- "Po zaplacení dostanete" mini box — snižuje nejistotu před klikem -->
          <aside class="pack-delivery" aria-label="Co dostanete po zaplacení">
            <p class="pack-delivery__label">Po zaplacení dostanete</p>
            <ul class="pack-delivery__list">
              <li>Master PDF (~50 stran)</li>
              <li>7 anotovaných wireframů</li>
              <li>Textové šablony a schema příklady</li>
              <li>Fakturu na firmu</li>
            </ul>
            <p class="pack-delivery__note">Vše okamžitě na e-mail po platbě.</p>
          </aside>
        </div>

        <!-- 7-page mockup focus -->
        <div class="pack-hero__mockup" aria-hidden="true">
          <div class="hero-focus">
            <div class="hero-focus__back hero-focus__back--1">
              <MockupPage pageNumber={2} pageTitle="Produkt" tone="primary" totalPages={7} />
            </div>
            <div class="hero-focus__back hero-focus__back--2">
              <MockupPage pageNumber={5} pageTitle="Blog výpis" tone="accent" totalPages={7} />
            </div>
            <div class="hero-focus__back hero-focus__back--3">
              <MockupPage pageNumber={6} pageTitle="Prodejní landing" tone="accent" totalPages={7} />
            </div>
            <div class="hero-focus__hero">
              <MockupPage pageNumber={1} pageTitle="Homepage" tone="primary" totalPages={7} />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 01 CO PACK OBSAHUJE ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">01</span> Co Pack obsahuje</span>
        <h2 class="lp-section__title">
          Sedm typů stránek, které <strong>tvoří kostru jakéhokoli webu</strong>
        </h2>
        <p class="lp-section__lead">
          Každá stránka má vlastní wireframe s anotacemi, šablonu textů,
          schema markup příklad a vysvětlení, jak signalizuje AI nástrojům
          obsah a kontext.
        </p>
      </header>

      <div class="page-types">
        {pageTypes.map((pt) => (
          <article class="page-type">
            <span class="page-type__num">{pt.num}</span>
            <h3 class="page-type__title">{pt.title}</h3>
            <p class="page-type__desc">{pt.desc}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ===== 02 UKÁZKA STRUKTURY — drill-down jednoho typu stránky ===== -->
    <section class="lp-section lp-section--alt">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">02</span> Co je uvnitř jedné stránky</span>
        <h2 class="lp-section__title">
          Ukázka struktury — <strong>produktová stránka v Packu</strong>
        </h2>
        <p class="lp-section__lead">
          Každý ze 7 typů stránek obsahuje wireframe, anotace, šablonu
          textů a schema markup. Tady je, jak se to skládá u produktové
          stránky:
        </p>
      </header>

      <article class="pack-sample">
        <ol class="pack-sample__list">
          <li>
            <span class="pack-sample__num">01</span>
            <div class="pack-sample__body">
              <strong>Hero s názvem produktu a hlavním benefitem</strong>
              <p>Title pattern pro AI citaci. Krátká anotace (40–60 slov) hned pod titulem — AI nástroje ji vytahují jako přímou odpověď.</p>
            </div>
          </li>
          <li>
            <span class="pack-sample__num">02</span>
            <div class="pack-sample__body">
              <strong>Blok dostupnosti a parametrů</strong>
              <p>Strukturovaná specifikace, kterou AI rozpozná jako produktová data (cena, stav skladu, varianty).</p>
            </div>
          </li>
          <li>
            <span class="pack-sample__num">03</span>
            <div class="pack-sample__body">
              <strong>FAQ pro nákupní námitky</strong>
              <p>Otázky a odpovědi s FAQPage schema — ChatGPT a Perplexity vytahují přímé citace, Google AI Overviews je zobrazuje.</p>
            </div>
          </li>
          <li>
            <span class="pack-sample__num">04</span>
            <div class="pack-sample__body">
              <strong>Product schema JSON-LD</strong>
              <p>Strukturovaná data o produktu, ceně, dostupnosti — připravené pro Google Rich Results i AI nástroje.</p>
            </div>
          </li>
          <li>
            <span class="pack-sample__num">05</span>
            <div class="pack-sample__body">
              <strong>Related products + interní prolinkování</strong>
              <p>Hub-and-spoke pattern, aby AI rozpoznala kategorii a propojila váš sortiment do tematických clusterů.</p>
            </div>
          </li>
        </ol>
        <p class="pack-sample__note">
          Stejný princip drží pro všech 7 typů stránek — homepage, produkt, kategorii,
          blog článek, blog výpis, prodejní landing i kontakt.
        </p>
      </article>
    </section>

    <!-- ===== 03 CO DOSTANETE ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">03</span> Co dostanete po koupi</span>
        <h2 class="lp-section__title">
          Sedm stránek, šablony, schema a návod <strong>jako jeden balík</strong>
        </h2>
      </header>

      <ul class="pack-deliverables">
        <li>
          <strong>7 wireframů s anotacemi</strong> — každý prvek vysvětlený, proč tam je
          a jaký signál pro AI generuje
        </li>
        <li>
          <strong>Šablony textů pro každý typ stránky</strong> — title pattern, meta
          description, headings, body copy, FAQ — vše ready ke kopírování
        </li>
        <li>
          <strong>Schema markup příklady</strong> — Product, FAQPage, Article,
          BreadcrumbList, LocalBusiness, Organization — JSON-LD copy-paste
        </li>
        <li>
          <strong>Krok-za-krokem návod aplikace</strong> — checklist, jak Pack aplikovat
          na váš stávající web, podle CMS (Upgates, Shoptet, WordPress, custom)
        </li>
        <li>
          <strong>Anti-pattern checklist</strong> — čemu se vyhnout u každého
          typu stránky. Z analýzy stovek e-shopů, kde stejné chyby brzdí AI viditelnost.
        </li>
      </ul>
    </section>

    <!-- ===== 03 KOMU SE PACK HODÍ ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">04</span> Komu se Pack hodí</span>
        <h2 class="lp-section__title">
          Pack <strong>nejvíc využijí ti, kdo mají co prodávat</strong>
        </h2>
        <p class="lp-section__lead">
          Pack je framework — stránka po stránce. Hodí se webům, které
          chtějí být vidět v AI odpovědích a získat z nich konkrétní
          akce: nákupy, leady, kontakty.
        </p>
      </header>

      <ul class="pack-audience">
        <li>
          <strong>Provozovatelé e-shopů</strong> — Upgates, Shoptet, WooCommerce, Shopify
          a další. AI musí rozpoznat produkty, kategorie a recenze.
        </li>
        <li>
          <strong>Firemní weby s katalogem služeb</strong> — služby, produkty, kontakt.
          AI musí pochopit, co děláte a jak vás kontaktovat.
        </li>
        <li>
          <strong>Marketing agentury</strong> — chcete framework, který nabídnete klientům
          jako součást vašich služeb. White-label rozšíření je možné domluvit.
        </li>
        <li>
          <strong>Copywriteři, designéři, vývojáři</strong> — chcete šablonu, podle které
          pracovat na klientských webech bez vymýšlení od nuly.
        </li>
        <li>
          <strong>Osobní weby, portfolia, blogy</strong> — i osobní brand těží z toho,
          když ho AI cituje a doporučuje.
        </li>
      </ul>
    </section>

    <!-- ===== 04 SNIPERDESIGN MEDAILONEK ===== -->
    <SniperDesignSmallContact />

    <!-- ===== FAQ ===== -->
    <section class="lp-section lp-section--alt">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">FAQ</span> Časté otázky</span>
        <h2 class="lp-section__title">Než přistoupíte k nákupu, <strong>tady jsou odpovědi</strong></h2>
      </header>

      <dl class="lp-faq">
        {faqJsonLd.mainEntity.map((q, i) => (
          <div class="lp-faq__item">
            <dt class="lp-faq__q">
              <span class="lp-faq__q-num">{String(i + 1).padStart(2, "0")}</span>
              <span>{q.name}</span>
            </dt>
            <dd class="lp-faq__a">{q.acceptedAnswer.text}</dd>
          </div>
        ))}
      </dl>

      <!-- Mikrotransparentnost k digitálnímu produktu — místo refundu -->
      <p class="pack-transparency">
        Jde o digitální produkt s okamžitým přístupem po platbě.
        Před nákupem proto na stránce uvádíme přesný obsah Packu —
        sedm typů stránek, ukázku struktury, deliverables i FAQ.
      </p>
    </section>

    <!-- ===== Mobile sticky CTA bar — viditelný po opuštění hero =====
         Snižuje friction na dlouhých scrollech, drží Buy akci na dosah palce. -->
    <aside class="pack-sticky-cta" id="pack-sticky-cta" aria-hidden="true">
      <div class="pack-sticky-cta__inner">
        <div class="pack-sticky-cta__price">
          <strong>1&nbsp;490&nbsp;Kč</strong>
          <span>jednorázově</span>
        </div>
        <a
          href={STRIPE_CHECKOUT_URL}
          class="pack-sticky-cta__btn"
          aria-label="Koupit Pack za 1 490 Kč"
        >
          Koupit Pack
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path
              d="M1 7H13M13 7L7 1M13 7L7 13"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
          </svg>
        </a>
      </div>
    </aside>

    <!-- ===== FINAL CTA ===== -->
    <section class="pack-final">
      <div class="pack-final__inner">
        <h2 class="pack-final__title">
          Postavte web, kterému AI rozumí —<br />
          <strong>celý, ne jen homepage</strong>
        </h2>
        <p class="pack-final__lead">
          Sedm typů stránek, šablony textů, schema markup a krok-za-krokem návod.
          <strong>1&nbsp;490&nbsp;Kč jednorázově.</strong> Žádné předplatné,
          žádné skryté poplatky.
        </p>
        <a
          href={STRIPE_CHECKOUT_URL}
          class="pack-buy-btn pack-buy-btn--large"
          aria-label="Koupit AI SEO Wireframe Pack za 1 490 Kč"
        >
          Koupit Pack za 1&nbsp;490&nbsp;Kč
          <svg width="18" height="18" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path
              d="M1 7H13M13 7L7 1M13 7L7 13"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
          </svg>
        </a>
        <p class="pack-final__trust">
          Platba kartou (Stripe) · faktura na firmu · okamžitý přístup po platbě
        </p>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ===== Page root ===== */
  .pack {
    --lp-violet: oklch(0.55 0.25 305);
    --lp-magenta: oklch(0.62 0.27 335);
    --lp-gold: oklch(0.82 0.16 80);
  }

  /* ===== Section primitives (reused style scheme z /navod-zdarma/) ===== */
  .lp-section {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(3.5rem, 7vw, 6rem) var(--space-section-x);
  }
  .lp-section--alt {
    background: var(--color-paper-deep);
    max-width: none;
    padding-left: 0;
    padding-right: 0;
  }
  .lp-section--alt > * {
    max-width: var(--max-section);
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--space-section-x);
    padding-right: var(--space-section-x);
  }
  .lp-section__head {
    max-width: 50rem;
    margin-bottom: clamp(2.5rem, 4vw, 3.5rem);
  }
  .lp-section__title {
    font-family: var(--font-sans);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }
  .lp-section__title strong {
    font-weight: 700;
    color: var(--lp-violet);
  }
  .lp-section__lead {
    font-family: var(--font-sans);
    font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0;
    max-width: 42rem;
  }

  .eyebrow {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: 1rem;
  }
  .eyebrow__num {
    color: var(--lp-violet);
    font-weight: 700;
  }

  /* ===== HERO ===== */
  .pack-hero {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 4rem) var(--space-section-x) clamp(3rem, 6vw, 5rem);
  }
  .pack-hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: start;
  }
  @media (min-width: 960px) {
    .pack-hero__inner { grid-template-columns: 1.1fr 1fr; gap: 4rem; }
  }
  .pack-hero__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--lp-violet);
    background: oklch(0.95 0.04 305);
    padding: 0.4rem 0.875rem;
    border-radius: 999px;
    margin-bottom: 1.25rem;
  }
  .pack-hero__title {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin: 0 0 1.25rem;
  }
  .pack-hero__title strong {
    font-weight: 700;
    color: var(--lp-violet);
  }
  .pack-hero__urgency {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.5;
    color: var(--color-ink-muted);
    margin: 1.25rem 0 1.5rem;
