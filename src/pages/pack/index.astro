---
import BaseLayout from "~/layouts/BaseLayout.astro";
import SniperDesignSmallContact from "~/components/sniperdesign/SmallContact.astro";

const pageTitle = "AI SEO Wireframe Pack — sedm typů stránek pro AI vyhledávání";
const pageDescription =
  "Pack obsahuje sedm typů stránek s hotovými texty: homepage, produkt, kategorie, blog (článek + výpis), prodejní landing a kontakt. Master PDF má 85 stran. Aplikujete na svůj web během odpoledne. 1 490 Kč jednorázově.";

/**
 * STRIPE CHECKOUT URL — placeholder dokud nedorazí reálná URL.
 * Update jen na jednom místě, propíše se do všech CTA tlačítek.
 * Reálná URL po vyřešení Stripe komplikace.
 */
const STRIPE_CHECKOUT_URL = "https://buy.stripe.com/4gM9AU8Km1wm6vY4Hw0VO00";

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Co konkrétně Pack obsahuje?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sedm typů stránek (homepage, produkt, kategorie, blog článek, blog výpis, prodejní landing, kontakt) — pro každou anotovaný wireframe, šablony textů a ukázky strukturovaných dat (pro produkt, časté dotazy, článek, místní firmu). Plus krok-za-krokem návod, jak to aplikovat na váš web. Vše v jednom master PDF (85 stran).",
      },
    },
    {
      "@type": "Question",
      name: "Mohu Pack použít na jakémkoli CMS?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ano. Pack je praktický pracovní rámec, ne plugin. Wireframy, šablony textů a ukázky strukturovaných dat aplikujete na libovolný systém — Upgates, Shoptet, WordPress, Webflow, custom Astro, Next.js i statické HTML. Specifické instrukce pro Upgates a Shoptet jsou navíc.",
      },
    },
    {
      "@type": "Question",
      name: "Co když si nejsem jistý, jestli to zvládnu?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Pack obsahuje krok-za-krokem návod psaný pro provozovatele webů, ne pro vývojáře. Většinu úprav (text, struktura) zvládnete sami za odpoledne. Strukturovaná data připravíte jako podklad a předáte vývojáři nebo správci webu. Pokud preferujete, abychom to udělali za vás, podívejte se na AI SEO audit od Sniperdesign za 9 990 Kč — projdeme váš web a předáme prioritní seznam úprav.",
      },
    },
    {
      "@type": "Question",
      name: "Dostanu aktualizace Packu, pokud se AI SEO změní?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ano. AI vyhledávání se vyvíjí, Pack udržujeme aktuální. Pokud vydáme drobnou aktualizaci této edice (nová pravidla pro strukturovaná data, změny v tom, jak ChatGPT a Perplexity uvádějí zdroje), pošleme ji držitelům licence zdarma e-mailem. Pokud bude potřeba zásadní revize struktury, oznámíme to dopředu.",
      },
    },
    {
      "@type": "Question",
      name: "Je Pack vhodný i pro web bez blogu nebo bez e-shopu?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ano. Pack obsahuje sedm typů stránek, ale nemusíte aplikovat všechny. Pokud máte jen služby (žádný e-shop), využijete homepage, prodejní landing, kontakt — případně blog článek. Pokud máte e-shop bez blogu, naopak produkt, kategorii a kontakt. Pack je modulární, vezmete si jen typy, které váš web obsahuje.",
      },
    },
  ],
};

const pageTypes = [
  {
    num: 1,
    title: "Homepage",
    desc: "Wireframe + anotace + šablony textů. Stejný framework jako v free PDF — rozšířený o varianty pro různé typy byznysu (e-shop, služby, agentura, freelance).",
    pageTitle: "Homepage",
    tone: "primary" as const,
  },
  {
    num: 2,
    title: "Produktová stránka",
    desc: "Detail produktu — vzor titulku, strukturovaná data pro produkt (Product), časté dotazy se strukturovanými daty, související produkty. AI ji rozpozná jako nakupovatelnou stránku.",
    pageTitle: "Produkt",
    tone: "primary" as const,
  },
  {
    num: 3,
    title: "Kategoriální stránka",
    desc: "Výpis s filtry, kategoriální popis pro AI, strukturovaná data pro kategorii (CollectionPage, ItemList), přehledná hierarchie značek a podtřídění.",
    pageTitle: "Kategorie",
    tone: "primary" as const,
  },
  {
    num: 4,
    title: "Blog článek",
    desc: "Detail článku s krátkou odpovědí 40–60 slov, strukturovanými daty pro časté dotazy (FAQPage) a informacemi o autorovi. Citovatelný v ChatGPT i Google AI Overviews.",
    pageTitle: "Blog článek",
    tone: "accent" as const,
  },
  {
    num: 5,
    title: "Blog výpis článků",
    desc: "Výpis článků s filtry, stránkování, prolinkování mezi hlavními a podpůrnými články (hub-and-spoke) pro AI rozpoznání tématu.",
    pageTitle: "Blog výpis",
    tone: "accent" as const,
  },
  {
    num: 6,
    title: "Prodejní landing",
    desc: "Pro službu nebo produkt. Varianta pro získávání kontaktů (formulář pro sběr e-mailů) i pro přímý prodej (tlačítko s odkazem na pokladnu). Reference, časté dotazy, snížení obav — vše připravené.",
    pageTitle: "Prodejní landing",
    tone: "accent" as const,
  },
  {
    num: 7,
    title: "Kontaktní stránka",
    desc: "Kontaktní formulář, mapa, kontaktní údaje — název, adresa, telefon (NAP), strukturovaná data pro místní firmu (LocalBusiness). AI ji rozpozná jako oficiální kontakt firmy.",
    pageTitle: "Kontakt",
    tone: "neutral" as const,
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={faqJsonLd}>
  <main class="pack">
    <!-- ===== HERO ===== -->
    <section class="pack-hero">
      <div class="pack-hero__inner">
        <div class="pack-hero__copy">
          <span class="pack-hero__eyebrow">Pack · pro celý web</span>
          <h1 class="pack-hero__title">
            Postavte web, kterému AI rozumí —<br />
            <strong>celý, ne jen homepage</strong>
          </h1>
          <p class="pack-hero__urgency">
            Bez struktury mimo homepage budete v AI odpovědích snadno přehlédnutí.
            <strong>Čím déle čekáte, tím víc obsahu pak budete předělávat.</strong>
          </p>
          <p class="pack-hero__lead">
            Wireframe Pack obsahuje sedm typů stránek se šablonami textů, ukázkami
            strukturovaných dat pro vývojáře a krok-za-krokem návodem aplikace. Vše
            v jednom master PDF (85 stran). Aplikujete na svůj web během odpoledne —
            bez konzultantů, bez měsíců práce.
          </p>

          <!-- ===== PRIMARY CTA card — cena + delivery + buy button ===== -->
          <!-- Vizuálně oddělené z hero copy, aby uživatel nepřehlédl, že tohle
               je TO, co se má stát (koupit Pack za 1 490 Kč). Green-tinted card
               sjednocený s color tématem buy button gradientu. -->
          <div class="pack-hero__cta-card" id="koupit-pack" role="region" aria-labelledby="cta-card-eyebrow">
            <span id="cta-card-eyebrow" class="pack-hero__cta-eyebrow">
              <span class="pack-hero__cta-eyebrow-pill">Po zaplacení</span>
              <span>vše okamžitě na e-mail</span>
            </span>

            <div class="pack-hero__pricing">
              <span class="pack-price">1&nbsp;490&nbsp;Kč</span>
              <span class="pack-price__detail">jednorázově, bez DPH</span>
            </div>

            <ul class="pack-delivery__list" aria-label="Co Pack přinese vašemu webu">
              <li>Vidíte se v ChatGPT, Perplexity i AI Overviews</li>
              <li>Předběhnete konkurenci, která o AI SEO zatím neví</li>
              <li>Aplikujete za odpoledne, ne za týdny zkoumání</li>
              <li>Vlastní framework — bez konzultantů, bez měsíců</li>
            </ul>

            <a
              href={STRIPE_CHECKOUT_URL}
              class="pack-buy-btn pack-buy-btn--large"
              aria-label="Koupit AI SEO Wireframe Pack za 1 490 Kč"
            >
              Koupit Pack za 1&nbsp;490&nbsp;Kč
              <svg width="16" height="16" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path
                  d="M1 7H13M13 7L7 1M13 7L7 13"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
            </a>

            <p class="pack-hero__trust-line">
              Platba kartou (Stripe) · faktura na firmu · bez předplatného
            </p>
          </div>
        </div>

        <!-- Hero mockup — 4 stránky z FREE PDF (cover, wireframe, principy,
             před/po). Rendrované na 414×585 px JPEG (50 DPI z A4) — display-size
             only, standalone obrázek nečitelný (anti-leak placeného Packu). -->
        <div class="pack-hero__mockup" aria-hidden="true">
          <div class="hero-focus">
            <div class="hero-focus__back hero-focus__back--1">
              <img src="/pack/preview/free-p4-pred-po.jpg"
                   alt="" loading="eager" width="414" height="585"
                   class="hero-focus__img" />
            </div>
            <div class="hero-focus__back hero-focus__back--2">
              <img src="/pack/preview/free-p3-principy.jpg"
                   alt="" loading="eager" width="414" height="585"
                   class="hero-focus__img" />
            </div>
            <div class="hero-focus__back hero-focus__back--3">
              <img src="/pack/preview/free-p2-wireframe.jpg"
                   alt="" loading="eager" width="414" height="585"
                   class="hero-focus__img" />
            </div>
            <div class="hero-focus__hero">
              <img src="/pack/preview/free-p1-cover.jpg"
                   alt="" loading="eager" width="414" height="585"
                   class="hero-focus__img" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 01 CO PACK OBSAHUJE ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">01</span> Co Pack obsahuje</span>
        <h2 class="lp-section__title">
          Sedm typů stránek, které <strong>tvoří kostru většiny firemních webů a e-shopů</strong>
        </h2>
        <p class="lp-section__lead">
          Každá stránka má vlastní wireframe s anotacemi, šablonu textů,
          ukázku strukturovaných dat a vysvětlení, jak pomáhá vyhledávačům
          a AI lépe pochopit obsah stránky.
        </p>
      </header>

      <div class="page-types">
        {pageTypes.map((pt) => (
          <article class="page-type">
            <span class="page-type__num">{pt.num}</span>
            <h3 class="page-type__title">{pt.title}</h3>
            <p class="page-type__desc">{pt.desc}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ===== 02 PODÍVEJTE SE DOVNITŘ — vizuální look-inside ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">02</span> Podívejte se dovnitř</span>
        <h2 class="lp-section__title">
          Takhle vypadají <strong>stránky uvnitř Packu</strong>
        </h2>
        <p class="lp-section__lead">
          Tři ukázkové stránky z první kapitoly — wireframe s anotacemi,
          tři principy SEO/GEO/AEO color-coded a šablony textů ke kopírování.
          Master PDF má 85 stran ve stejné kvalitě.
        </p>
      </header>

      <div class="pack-preview-grid">
        <figure class="pack-preview">
          <img src="/pack/preview/hero-wireframe-homepage.png"
               alt="Ukázka strany 7 master PDF — wireframe homepage s 10 anotacemi"
               loading="lazy" width="1240" height="1754" />
          <figcaption>
            <span class="pack-preview__chapter">Kap. 01 · str. 7</span>
            <span class="pack-preview__title">Wireframe homepage s 10 anotacemi</span>
          </figcaption>
        </figure>
        <figure class="pack-preview">
          <img src="/pack/preview/hero-tri-principy.png"
               alt="Ukázka strany 8 master PDF — tři principy SEO/GEO/AEO color-coded"
               loading="lazy" width="1240" height="1754" />
          <figcaption>
            <span class="pack-preview__chapter">Kap. 01 · str. 8</span>
            <span class="pack-preview__title">Tři principy SEO / GEO / AEO</span>
          </figcaption>
        </figure>
        <figure class="pack-preview">
          <img src="/pack/preview/hero-sablony-textu.png"
               alt="Ukázka strany 11 master PDF — šablony textů ke kopírování"
               loading="lazy" width="1240" height="1754" />
          <figcaption>
            <span class="pack-preview__chapter">Kap. 01 · str. 11</span>
            <span class="pack-preview__title">Šablony textů ke kopírování</span>
          </figcaption>
        </figure>
      </div>
    </section>

    <!-- ===== 03 UKÁZKA STRUKTURY — drill-down jednoho typu stránky ===== -->
    <section class="lp-section lp-section--alt">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">02</span> Co je uvnitř jedné stránky</span>
        <h2 class="lp-section__title">
          Ukázka struktury — <strong>produktová stránka v Packu</strong>
        </h2>
        <p class="lp-section__lead">
          Každý ze 7 typů stránek obsahuje wireframe, anotace, šablonu
          textů a ukázku strukturovaných dat. Tady je, jak se to skládá
          u produktové stránky:
        </p>
      </header>

      <article class="pack-sample">
        <ol class="pack-sample__list">
          <li>
            <span class="pack-sample__num">01</span>
            <div class="pack-sample__body">
              <strong>Hero s názvem produktu a hlavním benefitem</strong>
              <p>Vzor titulku pro AI citaci. Krátká odpověď (40–60 slov) hned pod titulkem — AI nástroje ji vytahují jako přímou odpověď.</p>
            </div>
          </li>
          <li>
            <span class="pack-sample__num">02</span>
            <div class="pack-sample__body">
              <strong>Blok dostupnosti a parametrů</strong>
              <p>Strukturovaná specifikace, kterou AI rozpozná jako produktová data (cena, stav skladu, varianty).</p>
            </div>
          </li>
          <li>
            <span class="pack-sample__num">03</span>
            <div class="pack-sample__body">
              <strong>Časté dotazy pro nákupní námitky</strong>
              <p>Otázky a odpovědi se strukturovanými daty (FAQPage) — ChatGPT a Perplexity vytahují přímé citace, Google AI Overviews je zobrazuje.</p>
            </div>
          </li>
          <li>
            <span class="pack-sample__num">04</span>
            <div class="pack-sample__body">
              <strong>Strukturovaná data pro produkt (Product, JSON-LD)</strong>
              <p>Údaje o produktu, ceně a dostupnosti ve strojově čitelném formátu — připravené pro Google Rich Results Test i AI nástroje. Podklad k předání vývojáři.</p>
            </div>
          </li>
          <li>
            <span class="pack-sample__num">05</span>
            <div class="pack-sample__body">
              <strong>Související produkty + interní prolinkování</strong>
              <p>Prolinkování mezi stránkami (hub-and-spoke), aby AI rozpoznala kategorii a propojila váš sortiment do tematických celků.</p>
            </div>
          </li>
        </ol>
        <p class="pack-sample__note">
          Stejný princip drží pro všech 7 typů stránek — homepage, produkt, kategorii,
          blog článek, blog výpis, prodejní landing i kontakt.
        </p>
      </article>
    </section>

    <!-- ===== 03 CO DOSTANETE ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">03</span> Co dostanete po koupi</span>
        <h2 class="lp-section__title">
          Sedm stránek, šablony, strukturovaná data a návod <strong>jako jeden balík</strong>
        </h2>
      </header>

      <ul class="pack-deliverables">
        <li>
          <strong>7 wireframů s anotacemi</strong> — každý prvek vysvětlený, proč tam je
          a jak pomáhá vyhledávačům a AI lépe pochopit obsah stránky
        </li>
        <li>
          <strong>Šablony textů pro každý typ stránky</strong> — vzor titulku, meta
          popisek, nadpisy, hlavní text, časté dotazy — vše ready ke kopírování
        </li>
        <li>
          <strong>Ukázky strukturovaných dat</strong> — Product, FAQPage, Article,
          BreadcrumbList, LocalBusiness, Organization v JSON-LD — podklad k předání
          vývojáři
        </li>
        <li>
          <strong>Krok-za-krokem návod aplikace</strong> — checklist, jak Pack aplikovat
          na váš stávající web, podle CMS (Upgates, Shoptet, WordPress, custom)
        </li>
        <li>
          <strong>Anti-pattern checklist</strong> — čemu se vyhnout u každého
          typu stránky. Z analýzy stovek e-shopů, kde stejné chyby brzdí AI viditelnost.
        </li>
      </ul>
    </section>

    <!-- ===== 03 KOMU SE PACK HODÍ ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">04</span> Komu se Pack hodí</span>
        <h2 class="lp-section__title">
          Pack <strong>nejvíc využijí ti, kdo mají co prodávat</strong>
        </h2>
        <p class="lp-section__lead">
          Pack je praktický pracovní rámec — stránka po stránce. Hodí se webům, které
          chtějí být vidět v AI odpovědích a získat z nich konkrétní
          akce: nákupy, leady, kontakty.
        </p>
      </header>

      <ul class="pack-audience">
        <li>
          <strong>Provozovatelé e-shopů</strong> — Upgates, Shoptet, WooCommerce, Shopify
          a další. AI musí rozpoznat produkty, kategorie a recenze.
        </li>
        <li>
          <strong>Firemní weby s katalogem služeb</strong> — služby, produkty, kontakt.
          AI musí pochopit, co děláte a jak vás kontaktovat.
        </li>
        <li>
          <strong>Marketing agentury</strong> — chcete framework, který nabídnete klientům
          jako součást vašich služeb. White-label rozšíření je možné domluvit.
        </li>
        <li>
          <strong>Copywriteři, designéři, vývojáři</strong> — chcete šablonu, podle které
          pracovat na klientských webech bez vymýšlení od nuly.
        </li>
        <li>
          <strong>Osobní weby, portfolia, blogy</strong> — i osobní brand těží z toho,
          když ho AI cituje a doporučuje.
        </li>
      </ul>
    </section>

    <!-- ===== 04 SNIPERDESIGN MEDAILONEK ===== -->
    <SniperDesignSmallContact />

    <!-- ===== FAQ ===== -->
    <section class="lp-section lp-section--alt">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">FAQ</span> Časté otázky</span>
        <h2 class="lp-section__title">Než přistoupíte k nákupu, <strong>tady jsou odpovědi</strong></h2>
      </header>

      <dl class="lp-faq">
        {faqJsonLd.mainEntity.map((q, i) => (
          <div class="lp-faq__item">
            <dt class="lp-faq__q">
              <span class="lp-faq__q-num">{String(i + 1).padStart(2, "0")}</span>
              <span>{q.name}</span>
            </dt>
            <dd class="lp-faq__a">{q.acceptedAnswer.text}</dd>
          </div>
        ))}
      </dl>
    </section>

    <!-- ===== Mobile sticky CTA bar — viditelný po opuštění hero =====
         Snižuje friction na dlouhých scrollech, drží Buy akci na dosah palce. -->
    <aside class="pack-sticky-cta" id="pack-sticky-cta" aria-hidden="true">
      <div class="pack-sticky-cta__inner">
        <div class="pack-sticky-cta__price">
          <strong>1&nbsp;490&nbsp;Kč</strong>
          <span>jednorázově</span>
        </div>
        <a
          href={STRIPE_CHECKOUT_URL}
          class="pack-sticky-cta__btn"
          aria-label="Koupit Pack za 1 490 Kč"
        >
          Koupit Pack
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path
              d="M1 7H13M13 7L7 1M13 7L7 13"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
          </svg>
        </a>
      </div>
    </aside>

    <!-- ===== FINAL CTA ===== -->
    <section class="pack-final">
      <div class="pack-final__inner">
        <h2 class="pack-final__title">
          Postavte web, kterému AI rozumí —<br />
          <strong>celý, ne jen homepage</strong>
        </h2>
        <p class="pack-final__lead">
          Sedm typů stránek, šablony textů, strukturovaná data a krok-za-krokem návod.
          <strong>1&nbsp;490&nbsp;Kč jednorázově.</strong> Žádné předplatné,
          žádné skryté poplatky.
        </p>
        <a
          href={STRIPE_CHECKOUT_URL}
          class="pack-buy-btn pack-buy-btn--large"
          aria-label="Koupit AI SEO Wireframe Pack za 1 490 Kč"
        >
          Koupit Pack za 1&nbsp;490&nbsp;Kč
          <svg width="18" height="18" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path
              d="M1 7H13M13 7L7 1M13 7L7 13"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
          </svg>
        </a>
        <p class="pack-final__trust">
          Platba kartou (Stripe) · faktura na firmu · okamžitý přístup po platbě
        </p>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ===== Page root ===== */
  .pack {
    --lp-violet: oklch(0.55 0.25 305);
    --lp-magenta: oklch(0.62 0.27 335);
    --lp-gold: oklch(0.82 0.16 80);
  }

  /* ===== Section primitives (reused style scheme z /navod-zdarma/) ===== */
  .lp-section {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(3.5rem, 7vw, 6rem) var(--space-section-x);
  }
  .lp-section--alt {
    background: var(--color-paper-deep);
    max-width: none;
    padding-left: 0;
    padding-right: 0;
  }
  .lp-section--alt > * {
    max-width: var(--max-section);
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--space-section-x);
    padding-right: var(--space-section-x);
  }
  .lp-section__head {
    max-width: 50rem;
    margin-bottom: clamp(2.5rem, 4vw, 3.5rem);
  }
  .lp-section__title {
    font-family: var(--font-sans);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }
  .lp-section__title strong {
    font-weight: 700;
    color: var(--lp-violet);
  }
  .lp-section__lead {
    font-family: var(--font-sans);
    font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0;
    max-width: 42rem;
  }

  .eyebrow {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: 1rem;
  }
  .eyebrow__num {
    color: var(--lp-violet);
    font-weight: 700;
  }

  /* ===== HERO ===== */
  .pack-hero {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 4rem) var(--space-section-x) clamp(3rem, 6vw, 5rem);
  }
  .pack-hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: start;
  }
  @media (min-width: 960px) {
    .pack-hero__inner { grid-template-columns: 1.1fr 1fr; gap: 4rem; }
  }
  .pack-hero__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--lp-violet);
    background: oklch(0.95 0.04 305);
    padding: 0.4rem 0.875rem;
    border-radius: 999px;
    margin-bottom: 1.25rem;
  }
  .pack-hero__title {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin: 0 0 1.25rem;
  }
  .pack-hero__title strong {
    font-weight: 700;
    color: var(--lp-violet);
  }
  .pack-hero__urgency {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.5;
    color: var(--color-ink-muted);
    margin: 1.25rem 0 1.5rem;
    padding-left: 0.875rem;
    border-left: 3px solid var(--lp-magenta);
    max-width: 36rem;
  }
  .pack-hero__urgency strong {
    color: var(--lp-magenta);
    font-weight: 600;
  }
  .pack-hero__lead {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.5vw, 1.1875rem);
    font-weight: 350;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0 0 1.75rem;
    max-width: 36rem;
  }
  /* ===== Hero CTA card — cena + delivery + Stripe buy button =====
     Green-tinted card sjednocený s color tématem buy button gradientu.
     Vizuálně se odpíchne od bílého hero kontextu — uživatel ho nepřehlédne. */
  .pack-hero__cta-card {
    margin: 1.75rem 0 0;
    padding: clamp(1.5rem, 2.5vw, 2rem) clamp(1.25rem, 2.5vw, 1.875rem);
    background:
      linear-gradient(180deg,
        color-mix(in oklch, oklch(0.72 0.2 145) 7%, var(--color-paper)) 0%,
        var(--color-paper) 65%);
    border: 1px solid color-mix(in oklch, oklch(0.6 0.18 145) 25%, var(--color-rule));
    border-radius: 18px;
    box-shadow:
      0 14px 40px -16px color-mix(in oklch, oklch(0.6 0.18 145) 38%, transparent),
      0 2px 6px -2px color-mix(in oklch, oklch(0.6 0.18 145) 15%, transparent),
      inset 0 1px 0 color-mix(in oklch, white 60%, transparent);
    max-width: 38rem;
  }
  .pack-hero__cta-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin: 0 0 1rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink-muted);
  }
  .pack-hero__cta-eyebrow-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.625rem;
    background: oklch(0.6 0.18 145);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 999px;
  }
  .pack-hero__pricing {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin: 0 0 1.25rem;
  }
  .pack-price {
    font-family: var(--font-sans);
    font-size: clamp(2.25rem, 3.5vw, 2.875rem);
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .pack-price__detail {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-ink-muted);
  }
  .pack-hero__trust-line {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--color-ink-faint);
    margin: 0.875rem 0 0;
  }
  /* Buy button uvnitř CTA card — full-width na všech viewportech (víc presence) */
  .pack-hero__cta-card .pack-buy-btn {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  /* ===== Primary Buy Button — Stripe checkout CTA =====
     Green gradient (sjednoceno s welcome e-mail + /navod-zdarma/ form).
     Větší než form CTA, je to MAIN akce celé stránky. */
  .pack-buy-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    color: #ffffff !important;
    text-decoration: none;
    background: linear-gradient(135deg, oklch(0.72 0.2 145) 0%, oklch(0.6 0.18 145) 100%);
    padding: 1rem 2rem;
    border-radius: 999px;
    letter-spacing: -0.005em;
    box-shadow: 0 4px 16px -4px oklch(0.72 0.2 145 / 0.55);
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.2s ease;
  }
  .pack-buy-btn:hover {
    background: linear-gradient(135deg, oklch(0.6 0.18 145) 0%, oklch(0.72 0.2 145) 100%);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -4px oklch(0.72 0.2 145 / 0.7);
  }
  .pack-buy-btn:active { transform: translateY(0); }
  .pack-buy-btn--large {
    font-size: 1.125rem;
    padding: 1.125rem 2.25rem;
  }
  /* Delivery list — uvnitř CTA card (bullets above button). Bez vlastního bg. */
  .pack-delivery__list {
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-ink);
  }
  @media (min-width: 540px) {
    .pack-delivery__list { grid-template-columns: 1fr 1fr; }
  }
  .pack-delivery__list li {
    position: relative;
    padding-left: 1.5rem;
    line-height: 1.4;
  }
  .pack-delivery__list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.45em;
    width: 14px;
    height: 14px;
    background: no-repeat center / contain;
    /* checkmark v green (matchuje buy button) */
    background-image: url("data:image/svg+xml,%3Csvg width='14' height='14' viewBox='0 0 14 14' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M2 7L6 11L12 3' stroke='%2316a34a' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  }

  /* ===== Hero focus mockup (sdílený s /navod-zdarma/) ===== */
  .pack-hero__mockup {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 420px;
  }
  .hero-focus {
    position: relative;
    width: 380px;
    height: 420px;
    --scroll-p: 0;
  }
  .hero-focus__hero {
    position: absolute;
    z-index: 10;
    width: 280px;
    left: 50px;
    top: 0;
    opacity: 0;
    transform: scale(0.92) translateY(20px);
    transition:
      transform 0.7s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.5s ease;
    box-shadow:
      0 30px 60px -20px oklch(0 0 0 / 0.2),
      0 12px 24px -8px oklch(0 0 0 / 0.1);
  }
  .hero-focus__back {
    position: absolute;
    width: 200px;
    opacity: 0;
    filter: blur(0.5px);
    transition:
      transform 0.7s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.5s ease;
  }
  .hero-focus__img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 4px;
    background: #fafbfc;
  }
  .hero-focus__hero .hero-focus__img {
    box-shadow:
      0 1px 2px oklch(0 0 0 / 0.05),
      inset 0 0 0 1px oklch(0 0 0 / 0.04);
  }
  .hero-focus__back .hero-focus__img {
    box-shadow:
      0 1px 3px oklch(0 0 0 / 0.08),
      inset 0 0 0 1px oklch(0 0 0 / 0.05);
  }
  .hero-focus.is-visible .hero-focus__hero {
    opacity: 1;
    transform: scale(1) translateY(calc(var(--scroll-p) * -8px));
    transition-delay: 0ms;
  }
  .hero-focus.is-visible .hero-focus__back { opacity: 0.55; }
  .hero-focus.is-visible .hero-focus__back--1 {
    top: 10px; left: -10px; z-index: 3; transition-delay: 180ms;
    transform: translate(0, calc(var(--scroll-p) * 12px)) rotate(-7deg);
  }
  .hero-focus.is-visible .hero-focus__back--2 {
    top: 30px; right: -20px; z-index: 4; transition-delay: 240ms;
    transform: translate(0, calc(var(--scroll-p) * 16px)) rotate(8deg);
  }
  .hero-focus.is-visible .hero-focus__back--3 {
    top: 200px; right: 30px; z-index: 2; transition-delay: 300ms;
    transform: translate(0, calc(var(--scroll-p) * 20px)) rotate(4deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-focus__hero,
    .hero-focus__back {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .hero-focus__back { opacity: 0.55 !important; }
  }

  /* ===== 7 page types grid ===== */
  .page-types {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 2vw, 1.5rem);
  }
  @media (min-width: 640px) {
    .page-types { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1080px) {
    .page-types { grid-template-columns: repeat(3, 1fr); }
  }

  /* ===== Pack preview grid ("look inside") ===== */
  .pack-preview-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.25rem, 2.5vw, 2rem);
  }
  @media (min-width: 640px) {
    .pack-preview-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1080px) {
    .pack-preview-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .pack-preview {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .pack-preview img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 6px;
    border: 1px solid var(--color-rule);
    background: #fafbfc;
    box-shadow:
      0 4px 14px -8px oklch(0 0 0 / 0.18),
      0 1px 3px -1px oklch(0 0 0 / 0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .pack-preview:hover img {
    transform: translateY(-2px);
    box-shadow:
      0 8px 22px -8px oklch(0 0 0 / 0.22),
      0 2px 5px -1px oklch(0 0 0 / 0.1);
  }
  .pack-preview figcaption {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0 0.125rem;
  }
  .pack-preview__chapter {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--lp-violet);
  }
  .pack-preview__title {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.4;
    color: var(--color-ink);
    font-weight: 500;
  }
  .page-type {
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 12px;
    padding: 1.5rem 1.375rem;
    position: relative;
    transition: border-color 0.18s ease, transform 0.18s ease;
  }
  .page-type:hover {
    border-color: var(--lp-violet);
    transform: translateY(-2px);
  }
  .page-type__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 999px;
    background: var(--lp-violet);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    margin-bottom: 0.875rem;
  }
  .page-type__title {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 0.5rem;
    letter-spacing: -0.015em;
  }
  .page-type__desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0;
  }

  /* ===== Ukázka struktury — produktová stránka drill-down ===== */
  /* Parent selector pro specificity boost: .lp-section--alt > * (Astro scope
     (0,3,0)) jinak přebíjí .pack-sample ((0,2,0)) a karta spadne na celou
     --max-section místo content-width. */
  .lp-section--alt .pack-sample {
    max-width: calc(var(--max-section) - 2 * var(--space-section-x));
    /* width 100%-minus-padding na mobile drží card od edges viewportu */
    width: calc(100% - 2 * var(--space-section-x));
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 14px;
    padding: clamp(1.5rem, 3vw, 2rem);
    border-left: 4px solid var(--lp-violet);
  }
  .pack-sample__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }
  .pack-sample__list li {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }
  .pack-sample__num {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.875rem;
    height: 1.875rem;
    border-radius: 999px;
    background: oklch(0.95 0.04 305);
    color: var(--lp-violet);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 700;
    margin-top: 2px;
  }
  .pack-sample__body {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
  }
  .pack-sample__body strong {
    display: block;
    color: var(--color-ink);
    font-weight: 600;
    margin-bottom: 0.25rem;
    letter-spacing: -0.01em;
  }
  .pack-sample__body p {
    margin: 0;
  }
  .pack-sample__note {
    margin: 1.5rem 0 0;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-rule);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--color-ink-faint);
    font-style: italic;
  }

  /* ===== Deliverables / Audience lists ===== */
  .pack-deliverables,
  .pack-audience {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    max-width: 50rem;
  }
  @media (min-width: 760px) {
    .pack-deliverables,
    .pack-audience { grid-template-columns: 1fr 1fr; }
  }
  .pack-deliverables li,
  .pack-audience li {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    padding: 1rem 1.125rem;
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 10px;
    border-left: 3px solid var(--lp-violet);
  }
  .pack-deliverables li strong,
  .pack-audience li strong {
    color: var(--color-ink);
    font-weight: 600;
  }

  /* ===== FAQ (sdílený s /navod-zdarma/) ===== */
  .lp-faq {
    max-width: 60rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .lp-faq__item {
    border-top: 1px solid var(--color-rule);
    padding-top: 1.5rem;
  }
  .lp-faq__q {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.5vw, 1.1875rem);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    margin: 0 0 0.625rem;
    display: flex;
    gap: 0.75rem;
  }
  .lp-faq__q-num {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--lp-violet);
    flex: none;
    padding-top: 0.125rem;
  }
  .lp-faq__a {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0;
    padding-left: 2.25rem;
  }

  /* ===== Final CTA ===== */
  .pack-final {
    background:
      radial-gradient(ellipse 60% 50% at 100% 0%, color-mix(in oklch, var(--lp-magenta) 24%, transparent), transparent 60%),
      radial-gradient(ellipse 70% 60% at 0% 100%, color-mix(in oklch, var(--lp-violet) 24%, transparent), transparent 60%),
      linear-gradient(180deg, var(--color-paper) 0%, var(--color-paper-deep) 100%);
    padding: clamp(3rem, 6vw, 5rem) var(--space-section-x);
  }
  .pack-final__inner {
    max-width: 46rem;
    margin: 0 auto;
    text-align: center;
  }
  .pack-final__title {
    font-family: var(--font-sans);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }
  .pack-final__title strong {
    color: var(--lp-violet);
    font-weight: 700;
  }
  .pack-final__lead {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0 0 1.75rem;
  }
  .pack-final__lead strong {
    color: var(--color-ink);
    font-weight: 600;
  }
  .pack-final__trust {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--color-ink-faint);
    margin: 1rem 0 0;
  }

  /* ===== Mobile sticky CTA bar =====
     Visible on mobile only, fixed bottom. Hidden by default; .is-active když
     hero opustí viewport (controlled via IntersectionObserver). */
  .pack-sticky-cta {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 40;
    background: oklch(0.99 0.005 270);
    border-top: 1px solid var(--color-rule);
    box-shadow: 0 -4px 16px -4px oklch(0 0 0 / 0.08);
    padding: 0.625rem 1rem;
    transform: translateY(110%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .pack-sticky-cta.is-active {
    transform: translateY(0);
  }
  @media (max-width: 720px) {
    .pack-sticky-cta { display: block; }
  }
  .pack-sticky-cta__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    max-width: 30rem;
    margin: 0 auto;
  }
  .pack-sticky-cta__price {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    font-family: var(--font-sans);
    line-height: 1;
  }
  .pack-sticky-cta__price strong {
    font-size: 1.125rem;
