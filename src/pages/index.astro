---
import BaseLayout from "~/layouts/BaseLayout.astro";

const pageTitle = "AI éra vyhledávání: SEO vs. GEO vs. AEO vs. AIO — průvodce 4 zkratkami";
const pageDescription =
  "Praktický průvodce čtyřmi disciplínami AI éry vyhledávání pro český trh. SEO pro pozice v Googlu, GEO pro citace v ChatGPT, AEO pro AI Overviews, AIO jako zastřešující rámec.";

/**
 * Quartet — 4 disciplíny pro homepage hero karty.
 * Každá disciplína má vlastní barvu (--color-{d}) a vlastní /<d>/ slug.
 */
type Discipline = "seo" | "geo" | "aeo" | "aio";
interface Quartet {
  d: Discipline;
  abbr: string;
  name: string;
  desc: string;
  features: string[];
  href: string;
}

/**
 * Pill definitions — rychlé seznámení s každou disciplínou pro hero pills.
 * Klik na pill rozbalí kartu s definicí a linkem na plnou sekci.
 */
interface PillDef {
  d: Discipline;
  label: string;
  fullName: string;
  oneLine: string;
  quick: string;
  href: string;
}

const pillDefs: PillDef[] = [
  {
    d: "seo",
    label: "SEO — Search",
    fullName: "Search Engine Optimization",
    oneLine: "Pozice v Googlu a Seznamu.",
    quick: "Klasická optimalizace pro umístění v top 10 organických výsledků. Předpoklad pro vše ostatní — bez SEO základu vás AI nástroje ani neindexují.",
    href: "/seo/",
  },
  {
    d: "geo",
    label: "GEO — Generative",
    fullName: "Generative Engine Optimization",
    oneLine: "Citace v ChatGPT, Perplexity, Claude a Gemini.",
    quick: "Cílíte na to být zdrojem, který AI nástroj cituje při generování odpovědi. Místo modrého odkazu se hraje o zmínku ve výstupu.",
    href: "/geo/",
  },
  {
    d: "aeo",
    label: "AEO — Answer",
    fullName: "Answer Engine Optimization",
    oneLine: "Odpovědi v Google AI Overviews a Bing Chatu.",
    quick: "Užší disciplína cílená na panel s krátkou odpovědí nahoře nad výsledky. Klíč je FAQ schema, krátké odpovědi po nadpisu, strukturovaný návod.",
    href: "/aeo/",
  },
  {
    d: "aio",
    label: "AIO — Umbrella",
    fullName: "AI Optimization (zastřešující)",
    oneLine: "Strategický rámec nad SEO + GEO + AEO. Také funkce Google AI Overviews.",
    quick: "Dvojí význam, který se v praxi často plete. Jako strategie zastřešuje všechny tři disciplíny. Jako funkce odkazuje na konkrétní AI Overviews panel od Googlu.",
    href: "/aio/",
  },
];

const quartet: Quartet[] = [
  {
    d: "seo",
    abbr: "SEO",
    name: "Search Engine Optimization",
    desc: "Klasická optimalizace pro pozice v Googlu a Seznamu. Zůstává základem všeho ostatního — bez indexace nezafunguje GEO ani AEO.",
    features: [
      "Cílí na top 10 v Googlu",
      "První výsledky za 3 až 6 měsíců",
      "Měří se přes Google Search Console",
      "Funguje pro Google a Seznam",
    ],
    href: "/seo/",
  },
  {
    d: "geo",
    abbr: "GEO",
    name: "Generative Engine Optimization",
    desc: "Optimalizace pro citace v ChatGPT, Perplexity, Claude a Gemini. Místo modrého odkazu cílíte na to, abyste byli zdrojem, ze kterého AI čerpá fakta.",
    features: [
      "Cílí na zmínky v AI odpovědích",
      "První výsledky za 1 až 3 měsíce",
      "Měří se počet citací napříč nástroji",
      "Funguje pro ChatGPT a Perplexity",
    ],
    href: "/geo/",
  },
  {
    d: "aeo",
    abbr: "AEO",
    name: "Answer Engine Optimization",
    desc: "Užší disciplína cílená na Google AI Overviews a Bing Chat. FAQ sekce, návody a krátké odpovědi hned po nadpisu — to je její řemeslo.",
    features: [
      "Cílí na panel AI Overviews v Googlu",
      "První výsledky za 2 až 4 měsíce",
      "Měří se přes Google Search Console",
      "Funguje pro Google a Bing",
    ],
    href: "/aeo/",
  },
  {
    d: "aio",
    abbr: "AIO",
    name: "AI Optimization (zastřešující)",
    desc: "Strategický deštník nad SEO, GEO a AEO. Také konkrétní funkce Google AI Overviews. Dvojí význam, který se v praxi často plete.",
    features: [
      "Cílí na koherentní strategii",
      "Iteruje se po kvartálech",
      "Měří se hybridně přes všechny kanály",
      "Pokrývá vše dohromady",
    ],
    href: "/aio/",
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- HERO -->
  <section class="hero">
    <span class="hero__intro">Průvodce AI érou vyhledávání pro český trh</span>

    <h1 class="display hero__title">
      <strong>AI éra vyhledávání</strong> se neptá <span class="hl">na pozice</span>. Ptá se <span class="hl">na citace</span>.
    </h1>

    <p class="lead hero__lead">
      Praktický průvodce čtyřmi disciplínami, které rozhodují o tom, jestli vás Google ukáže, jestli vás zacitují ChatGPT, Perplexity nebo Claude, jestli vás Gemini zařadí do AI přehledu, a jestli vás v roce 2026 najde někdo jiný než vy sami.
    </p>

    <div class="hero__pills" role="tablist" aria-label="Rychlé seznámení s disciplínami">
      {pillDefs.map((p) => (
        <button
          type="button"
          class="pill pill--btn"
          data-d={p.d}
          data-pill-trigger={p.d}
          aria-controls={`pill-panel-${p.d}`}
          aria-expanded="false"
          role="tab"
        >
          <span>{p.label}</span>
          <svg class="pill__icon" width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
            <path d="M5.5 1V10M1 5.5H10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
        </button>
      ))}
    </div>

    <!-- Pill detail panel — shared, swaps content based on active pill -->
    <div class="pill-panels" data-pill-panels>
      {pillDefs.map((p) => (
        <article
          class="pill-panel"
          id={`pill-panel-${p.d}`}
          data-d={p.d}
          data-pill-panel={p.d}
          role="tabpanel"
          hidden
        >
          <header class="pill-panel__head">
            <span class="pill-panel__abbr">{p.d.toUpperCase()}</span>
            <h3 class="pill-panel__title">{p.fullName}</h3>
            <button type="button" class="pill-panel__close" data-pill-close aria-label="Zavřít detail">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
              </svg>
            </button>
          </header>
          <p class="pill-panel__one">{p.oneLine}</p>
          <p class="pill-panel__quick">{p.quick}</p>
          <a href={p.href} class="pill-panel__link">
            Otevřít detail disciplíny
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 7H13M13 7L7 1M13 7L7 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </article>
      ))}
    </div>
  </section>

  <!-- HERO MEDIA SLOT (placeholder pro budoucí ilustraci/video) -->
  <section class="hero-media" aria-label="Místo pro hlavní ilustraci">
    <figure class="hero-media__frame">
      <span class="hero-media__label">Hlavní ilustrace nebo úvodní video</span>
      <span class="hero-media__sub">Sem přijde úvodní obrázek, abstraktní vizualizace, nebo krátké video — formát 16:9. Doplníme po schválení designu.</span>
    </figure>
  </section>

  <!-- STAT BAR — proč to musíte řešit (e-shop / web owner pain points) -->
  <section class="stat-bar" aria-label="Proč začít s AI SEO">
    <div class="stat-bar__inner">
      <div class="stat">
        <div class="stat__num"><strong>~30&nbsp;%</strong></div>
        <p class="stat__label">Informačních dotazů v Googlu už dnes spouští AI Overview panel</p>
        <p class="stat__src">Zero-click hrozba pro váš organic traffic</p>
      </div>
      <div class="stat">
        <div class="stat__num"><strong>~65&nbsp;%</strong></div>
        <p class="stat__label">Mladších uživatelů začíná research v AI nástroji, ne v Googlu</p>
        <p class="stat__src">ChatGPT, Perplexity, Claude, Gemini</p>
      </div>
      <div class="stat">
        <div class="stat__num"><strong>~65&nbsp;%</strong></div>
        <p class="stat__label">Vyhledávání končí bez kliknutí na zdroj (zero-click search)</p>
        <p class="stat__src">Search ≠ traffic — pravidla se mění</p>
      </div>
      <div class="stat">
        <div class="stat__num"><strong>1–3&nbsp;měs.</strong></div>
        <p class="stat__label">Typický horizont prvních citací po implementaci playbooku</p>
        <p class="stat__src">Rychleji než klasické SEO</p>
      </div>
    </div>
  </section>

  <!-- QUARTET — 4 disciplíny -->
  <section class="section">
    <header class="section__head">
      <span class="eyebrow"><span class="eyebrow__num">02</span> Čtyři disciplíny</span>
      <h2 class="section__title">
        Každá řeší <span class="hl">jiný kanál</span>. Společně tvoří <strong>kvartet</strong>.
      </h2>
      <p class="section__intro">
        Nejde o synonyma ani o trendové štítky. Každá disciplína má vlastní platformy, vlastní signály a vlastní časový horizont. Chyba je dělat všechny najednou, bez pořadí.
      </p>
    </header>

    <div class="quartet">
      {
        quartet.map((q) => (
          <a href={q.href} class="qcard" data-d={q.d}>
            <h3 class="qcard__abbr">{q.abbr}</h3>
            <p class="qcard__name">{q.name}</p>
            <p class="qcard__desc">{q.desc}</p>
            <ul class="qcard__features">
              {q.features.map((f) => (
                <li>{f}</li>
              ))}
            </ul>
            <span class="qcard__cta">
              Číst sekci <span aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ANATOMY (Phase 7 content tweak — místo hub-spoke ukazujeme ideální AI-friendly stránku) -->
  <section class="anatomy-section">
    <div class="anatomy-section__inner">
      <header class="anatomy-section__head">
        <span class="eyebrow"><span class="eyebrow__num">03</span> Anatomie AI-friendly stránky</span>
        <h2 class="section__title anatomy-section__title">
          Stránka, kterou si AI <span class="hl">snadno přečte</span> a zacituje, vypadá takto.
        </h2>
        <p class="section__intro anatomy-section__intro">
          Šest prvků, které z běžné stránky udělají zdroj pro Google AI Overviews, ChatGPT i Perplexity. Žádný z nich nestojí extra peníze — jen je potřeba je tam vědomě dostat.
        </p>
      </header>

      <div class="anatomy-section__layout">
        <svg
          class="anatomy-svg"
          viewBox="0 0 480 600"
          xmlns="http://www.w3.org/2000/svg"
          role="img"
          aria-label="Wireframe ideální AI-friendly stránky se šesti očíslovanými prvky: H1 jako otázka, krátká odpověď, hutný text, podnadpisy, FAQ a schema markup."
        >
          <!-- Page outline -->
          <rect x="20" y="20" width="440" height="560" rx="14" fill="var(--color-paper)" stroke="var(--color-rule-strong)" stroke-width="1.2"></rect>

          <!-- Browser bar (decorative) -->
          <line x1="20" y1="60" x2="460" y2="60" stroke="var(--color-rule)" stroke-width="1"></line>
          <circle cx="38" cy="40" r="3.5" fill="var(--color-rule-strong)"></circle>
          <circle cx="50" cy="40" r="3.5" fill="var(--color-rule-strong)"></circle>
          <circle cx="62" cy="40" r="3.5" fill="var(--color-rule-strong)"></circle>
          <rect x="80" y="32" width="360" height="16" rx="8" fill="var(--color-paper-deep)"></rect>

          <!-- ❶ H1 jako otázka -->
          <rect x="40" y="86" width="380" height="30" rx="4" fill="var(--color-paper-deep)"></rect>
          <text x="48" y="106" font-family="Geist, sans-serif" font-size="14" font-weight="600" fill="var(--color-ink)">H1: Co je AI SEO?</text>
          <g class="anatomy-mark">
            <circle cx="446" cy="101" r="14" fill="var(--color-accent)"></circle>
            <text x="446" y="106" font-family="Geist, sans-serif" font-size="13" font-weight="600" fill="var(--color-paper)" text-anchor="middle">1</text>
          </g>

          <!-- ❷ Answer block -->
          <rect x="40" y="132" width="380" height="80" rx="6" fill="oklch(0.96 0.022 250)" stroke="oklch(0.86 0.06 250)" stroke-width="1"></rect>
          <rect x="40" y="132" width="3" height="80" fill="var(--color-accent)"></rect>
          <text x="56" y="153" font-family="JetBrains Mono, monospace" font-size="9" font-weight="600" fill="var(--color-accent)" letter-spacing="1">STRUČNÁ ODPOVĚĎ</text>
          <rect x="56" y="162" width="340" height="8" rx="2" fill="var(--color-rule-strong)" opacity="0.55"></rect>
          <rect x="56" y="176" width="320" height="8" rx="2" fill="var(--color-rule-strong)" opacity="0.55"></rect>
          <rect x="56" y="190" width="280" height="8" rx="2" fill="var(--color-rule-strong)" opacity="0.55"></rect>
          <g class="anatomy-mark">
            <circle cx="446" cy="172" r="14" fill="var(--color-accent)"></circle>
            <text x="446" y="177" font-family="Geist, sans-serif" font-size="13" font-weight="600" fill="var(--color-paper)" text-anchor="middle">2</text>
          </g>

          <!-- ❸ Body text s fakty -->
          <rect x="40" y="232" width="380" height="6" rx="2" fill="var(--color-rule)"></rect>
          <rect x="40" y="244" width="360" height="6" rx="2" fill="var(--color-rule)"></rect>
          <rect x="40" y="256" width="380" height="6" rx="2" fill="var(--color-rule)"></rect>
          <rect x="40" y="268" width="200" height="6" rx="2" fill="var(--color-rule)"></rect>
          <!-- inline highlighted "fact" -->
          <rect x="246" y="266" width="60" height="10" rx="2" fill="var(--color-accent)" opacity="0.18"></rect>
          <g class="anatomy-mark">
            <circle cx="446" cy="253" r="14" fill="var(--color-accent)"></circle>
            <text x="446" y="258" font-family="Geist, sans-serif" font-size="13" font-weight="600" fill="var(--color-paper)" text-anchor="middle">3</text>
          </g>

          <!-- ❹ H2 sub-otázka -->
          <text x="40" y="316" font-family="Geist, sans-serif" font-size="13" font-weight="600" fill="var(--color-ink)">H2: Jak začít s GEO?</text>
          <rect x="40" y="328" width="380" height="6" rx="2" fill="var(--color-rule)"></rect>
          <rect x="40" y="340" width="340" height="6" rx="2" fill="var(--color-rule)"></rect>
          <g class="anatomy-mark">
            <circle cx="446" cy="316" r="14" fill="var(--color-accent)"></circle>
            <text x="446" y="321" font-family="Geist, sans-serif" font-size="13" font-weight="600" fill="var(--color-paper)" text-anchor="middle">4</text>
          </g>

          <!-- ❺ FAQ -->
          <rect x="40" y="370" width="380" height="120" rx="6" fill="var(--color-paper-deep)" stroke="var(--color-rule)" stroke-width="1"></rect>
          <text x="56" y="392" font-family="JetBrains Mono, monospace" font-size="9" font-weight="600" fill="var(--color-accent)" letter-spacing="1">FAQ</text>
          <text x="56" y="412" font-family="Geist, sans-serif" font-size="11" font-weight="600" fill="var(--color-ink)">Q: Jak optimalizovat pro ChatGPT?</text>
          <rect x="56" y="420" width="340" height="5" rx="2" fill="var(--color-rule)"></rect>
          <rect x="56" y="430" width="320" height="5" rx="2" fill="var(--color-rule)"></rect>
          <text x="56" y="456" font-family="Geist, sans-serif" font-size="11" font-weight="600" fill="var(--color-ink)">Q: Co je rozdíl SEO a GEO?</text>
          <rect x="56" y="464" width="340" height="5" rx="2" fill="var(--color-rule)"></rect>
          <rect x="56" y="474" width="280" height="5" rx="2" fill="var(--color-rule)"></rect>
          <g class="anatomy-mark">
            <circle cx="446" cy="430" r="14" fill="var(--color-accent)"></circle>
            <text x="446" y="435" font-family="Geist, sans-serif" font-size="13" font-weight="600" fill="var(--color-paper)" text-anchor="middle">5</text>
          </g>

          <!-- ❻ Schema markup (footer area) -->
          <rect x="40" y="510" width="380" height="48" rx="6" fill="var(--color-ink)"></rect>
          <text x="56" y="532" font-family="JetBrains Mono, monospace" font-size="10" fill="oklch(0.78 0.13 145)">&lt;script type="application/ld+json"&gt;</text>
          <text x="56" y="548" font-family="JetBrains Mono, monospace" font-size="10" fill="oklch(0.85 0.06 220)">"@type": "FAQPage", "mainEntity": [...]</text>
          <g class="anatomy-mark">
            <circle cx="446" cy="534" r="14" fill="var(--color-accent)"></circle>
            <text x="446" y="539" font-family="Geist, sans-serif" font-size="13" font-weight="600" fill="var(--color-paper)" text-anchor="middle">6</text>
          </g>
        </svg>

        <ol class="anatomy-list">
          <li class="anatomy-item">
            <span class="anatomy-item__num" aria-hidden="true">1</span>
            <div class="anatomy-item__body">
              <h3 class="anatomy-item__title">H1 jako otázka nebo jasná definice</h3>
              <p class="anatomy-item__desc">
                Hlavní nadpis jednou větou říká, na jaký dotaz stránka odpovídá. AI engine to čte jako kontext celé stránky.
              </p>
            </div>
          </li>
          <li class="anatomy-item">
            <span class="anatomy-item__num" aria-hidden="true">2</span>
            <div class="anatomy-item__body">
              <h3 class="anatomy-item__title">Krátká odpověď v prvních 40–60 slovech</h3>
              <p class="anatomy-item__desc">
                Hned pod H1 stojí stručná definice. ChatGPT, Perplexity a Gemini si z ní vezmou citaci do své odpovědi.
              </p>
            </div>
          </li>
          <li class="anatomy-item">
            <span class="anatomy-item__num" aria-hidden="true">3</span>
            <div class="anatomy-item__body">
              <h3 class="anatomy-item__title">Hutný text s konkrétními fakty</h3>
              <p class="anatomy-item__desc">
                Jeden nápad na odstavec. Čísla, procenta, jména zdrojů. AI miluje doložená tvrzení, ignoruje obecné „omáčky".
              </p>
            </div>
          </li>
          <li class="anatomy-item">
            <span class="anatomy-item__num" aria-hidden="true">4</span>
            <div class="anatomy-item__body">
              <h3 class="anatomy-item__title">Podnadpisy H2/H3 jako sub-otázky</h3>
              <p class="anatomy-item__desc">
                Každý podnadpis odpovídá na konkrétní pod-dotaz. Pomáhá AI mapovat strukturu stránky a ukotvit ji k tématu.
              </p>
            </div>
          </li>
          <li class="anatomy-item">
            <span class="anatomy-item__num" aria-hidden="true">5</span>
            <div class="anatomy-item__body">
              <h3 class="anatomy-item__title">FAQ sekce s reálnými dotazy uživatelů</h3>
              <p class="anatomy-item__desc">
                Otázky berte z Google Search Console nebo z „People Also Ask" boxů. FAQ je primární zdroj pro AI Overviews.
              </p>
            </div>
          </li>
          <li class="anatomy-item">
            <span class="anatomy-item__num" aria-hidden="true">6</span>
            <div class="anatomy-item__body">
              <h3 class="anatomy-item__title">Schema.org markup v hlavičce stránky</h3>
              <p class="anatomy-item__desc">
                Strojově čitelný JSON-LD: <code>Article</code>, <code>FAQPage</code>, <code>HowTo</code>. Bez něj AI nepozná, co je co.
              </p>
            </div>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <!-- PILLAR PROMO -->
  <section class="pillar-promo">
    <div class="pillar-promo__main">
      <span class="eyebrow"><span class="eyebrow__num">04</span> Hlavní průvodce</span>
      <h2 class="pillar-promo__title">
        SEO vs. GEO vs. AEO vs. AIO: <strong>kompletní průvodce</strong> <span class="hl">4 zkratkami</span> pro AI éru
      </h2>
      <p class="pillar-promo__lead">
        Hlavní článek, který každou disciplínu rozebírá od definice přes srovnání až po rozhodovací matici. Doporučené čtení v jedné dávce.
      </p>
      <div class="pillar-promo__meta">
        <span>Asi 3 000 slov</span>
        <span>Sedm častých otázek</span>
        <span>Srovnávací tabulka</span>
        <span>12 minut čtení</span>
      </div>
      <a href="/seo-vs-geo-vs-aeo-vs-aio/" class="btn">
        Otevřít hlavní průvodce
        <svg class="btn__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M1 7H13M13 7L7 1M13 7L7 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>

    <aside class="pillar-promo__excerpt">
      <span class="pillar-promo__excerpt-mark">Z hlavního průvodce</span>
      <p class="pillar-promo__excerpt-text">
