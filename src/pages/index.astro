<script>
  // Pill popover toggle — click to open, click again or X to close, Esc to close,
  // click outside to close. Only one panel visible at a time.
  (() => {
    const triggers = document.querySelectorAll<HTMLButtonElement>("[data-pill-trigger]");
    const panels = document.querySelectorAll<HTMLElement>("[data-pill-panel]");
    const container = document.querySelector<HTMLElement>("[data-pill-panels]");

    if (!triggers.length || !panels.length || !container) return;

    const closeAll = () => {
      triggers.forEach((t) => t.setAttribute("aria-expanded", "false"));
      panels.forEach((p) => p.setAttribute("hidden", ""));
    };

    const open = (key: string) => {
      panels.forEach((p) => {
        if (p.dataset.pillPanel === key) p.removeAttribute("hidden");
        else p.setAttribute("hidden", "");
      });
      triggers.forEach((t) => {
        t.setAttribute(
          "aria-expanded",
          t.dataset.pillTrigger === key ? "true" : "false",
        );
      });
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", (e) => {
        e.stopPropagation();
        const key = trigger.dataset.pillTrigger;
        if (!key) return;
        const isOpen = trigger.getAttribute("aria-expanded") === "true";
        if (isOpen) closeAll();
        else open(key);
      });
    });

    // Close button inside panels
    document.querySelectorAll<HTMLButtonElement>("[data-pill-close]").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        closeAll();
      });
    });

    // Click outside both pills and panels closes
    document.addEventListener("click", (e) => {
      const target = e.target as Node;
      const insidePanels = container.contains(target);
      const insideTrigger = Array.from(triggers).some((t) => t.contains(target));
      if (!insidePanels && !insideTrigger) closeAll();
    });

    // Escape closes
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeAll();
    });
  })();
</script>
