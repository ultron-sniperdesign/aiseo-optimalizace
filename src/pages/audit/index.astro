<script is:inline>
  /**
   * Audit form — sloučí URL + cíl + platformu do name fieldu, aby
   * to Sniperdesign viděl v Ecomail dashboardu vedle e-mailu.
   * Ecomail subscribe endpoint nepodporuje custom fields, takže
   * data sbalíme do "name".
   */
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.querySelector(".audit-form");
    if (!form) return;
    form.addEventListener("submit", (e) => {
      const jmeno = (document.getElementById("audit-jmeno"))?.value?.trim() || "";
      const url = (document.getElementById("audit-url"))?.value?.trim() || "";
      const platforma = (document.getElementById("audit-platforma"))?.value?.trim() || "";
      const cil = (document.getElementById("audit-cil"))?.value?.trim() || "";
      const nameInput = document.getElementById("audit-form-name");
      if (!nameInput) return;
      // Sloučený "name" — Sniperdesign uvidí v Ecomail dashboardu
      const parts = ["Audit poptávka", jmeno, url, platforma, cil ? cil.slice(0, 200) : ""].filter(Boolean);
      nameInput.value = parts.join(" · ");
    });
  });
</script>

