  /* ===== „Co konkrétně dostanete" — sample output struktura (audit #5) ===== */
  .audit-deliverable {
    max-width: 56rem;
    margin: clamp(2rem, 3vw, 2.5rem) 0 0;
    padding: clamp(1.5rem, 2.5vw, 2rem);
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-left: 4px solid var(--sd-gold);
    border-radius: 14px;
  }
  .audit-deliverable__head {
    margin: 0 0 1.5rem;
  }
  .audit-deliverable__pill {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    background: var(--sd-gold);
    color: var(--sd-deep);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 999px;
    margin-bottom: 0.875rem;
  }
  .audit-deliverable__title {
    font-family: var(--font-agency, var(--font-sans));
    font-weight: 300;
    font-size: clamp(1.25rem, 2.5vw, 1.625rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0 0 0.625rem;
  }
  .audit-deliverable__title strong {
    font-weight: 700;
    color: var(--sd-deep);
  }
  .audit-deliverable__lead {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0;
  }
  .audit-deliverable__list {
    counter-reset: deliverable;
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .audit-deliverable__list li {
    counter-increment: deliverable;
    position: relative;
    padding: 0.875rem 1rem 0.875rem 3rem;
    background: var(--color-paper-deep);
    border: 1px solid var(--color-rule);
    border-radius: 8px;
  }
  .audit-deliverable__list li::before {
    content: counter(deliverable, decimal-leading-zero);
    position: absolute;
    left: 0.875rem;
    top: 0.875rem;
    width: 1.5rem;
    height: 1.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--sd-gold);
    color: var(--sd-deep);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    border-radius: 999px;
  }
  .audit-deliverable__list strong {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 0.25rem;
    letter-spacing: -0.01em;
  }
  .audit-deliverable__list span {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
  }

  /* ===== Urgency / FOMO sekce „proč to řešit teď" =====
     Hned za hero. Subtle magenta tint bg, 3-card grid s urgency framing. */
  .audit-urgency {
    background:
      radial-gradient(ellipse 50% 60% at 100% 0%, color-mix(in oklch, var(--sd-magenta) 8%, transparent), transparent 60%),
      var(--color-paper);
    border-top: 1px solid color-mix(in oklch, var(--sd-magenta) 18%, var(--color-rule));
    border-bottom: 1px solid var(--color-rule);
  }
  .audit-urgency__inner {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 4rem) var(--space-section-x);
  }
  .audit-urgency__head {
    max-width: 56rem;
    margin: 0 0 clamp(2rem, 3.5vw, 2.75rem);
  }
  .audit-urgency__pill {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    background: var(--sd-magenta);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 999px;
    margin-bottom: 1rem;
  }
  .audit-urgency__title {
    font-family: var(--font-agency, var(--font-sans));
    font-weight: 300;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin: 0;
  }
  .audit-urgency__title strong {
    font-weight: 700;
    color: var(--sd-magenta);
  }
  .audit-urgency__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 2vw, 1.5rem);
  }
  @media (min-width: 760px) {
    .audit-urgency__grid { grid-template-columns: repeat(3, 1fr); }
  }
  .audit-urgency-card {
    background: var(--color-paper-deep);
    border: 1px solid var(--color-rule);
    border-left: 3px solid var(--sd-magenta);
    border-radius: 12px;
    padding: clamp(1.25rem, 2vw, 1.625rem);
  }
  .audit-urgency-card__num {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--sd-magenta);
    margin: 0 0 0.5rem;
    letter-spacing: 0.04em;
  }
  .audit-urgency-card__title {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.015em;
    line-height: 1.3;
    margin: 0 0 0.625rem;
  }
  .audit-urgency-card__desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0;
  }

  /* ===== Final CTA banner — opakování CTA pod stránkou ===== */
  .audit-cta-final {
    background:
      radial-gradient(ellipse 60% 50% at 100% 0%, color-mix(in oklch, var(--sd-magenta) 28%, transparent), transparent 60%),
      radial-gradient(ellipse 70% 60% at 0% 100%, color-mix(in oklch, var(--sd-violet) 28%, transparent), transparent 60%),
      linear-gradient(135deg, var(--sd-deep) 0%, var(--sd-deeper) 100%);
    color: var(--sd-paper);
    padding: clamp(3rem, 6vw, 5rem) var(--space-section-x);
    text-align: center;
    /* Bottom flush k footeru (footer má margin-top 3rem) */
    margin-bottom: -3rem;
  }
  .audit-cta-final__inner {
    max-width: 46rem;
    margin: 0 auto;
  }
  .audit-cta-final__title {
    font-family: var(--font-agency);
    font-weight: 300;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: var(--sd-paper);
    margin: 0 0 1rem;
  }
  .audit-cta-final__title strong {
    font-weight: 700;
    color: color-mix(in oklch, var(--sd-magenta) 60%, white);
  }
  .audit-cta-final__lead {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.55;
    color: oklch(from var(--sd-paper) l c h / 0.85);
    margin: 0 0 1.75rem;
  }
  .audit-cta-final__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 700;
    padding: 1rem 1.875rem;
    background: var(--sd-gold);
    color: var(--sd-deep);
    border-radius: 999px;
    text-decoration: none;
    transition: transform 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
    box-shadow: 0 8px 24px -8px oklch(from var(--sd-gold) l c h / 0.55);
  }
  .audit-cta-final__btn:hover {
    background: color-mix(in oklch, var(--sd-gold) 85%, white);
    transform: translateY(-2px);
    box-shadow: 0 12px 32px -8px oklch(from var(--sd-gold) l c h / 0.7);
  }
  .audit-cta-final__trust {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: oklch(from var(--sd-paper) l c h / 0.7);
    margin: 1.25rem 0 0;
  }
  .audit-cta-final__trust a {
    color: oklch(from var(--sd-paper) l c h / 0.9);
    text-decoration: underline;
    text-decoration-color: oklch(from var(--sd-paper) l c h / 0.3);
    text-underline-offset: 2px;
  }

  /* ===== Sdílené primitivy z /pack/ ===== */
  .lp-section {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) var(--space-section-x);
  }
  .lp-section--alt {
    background: var(--color-paper-deep);
    max-width: none;
    padding-left: 0;
    padding-right: 0;
  }
  .lp-section--alt > * {
    max-width: var(--max-section);
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--space-section-x);
    padding-right: var(--space-section-x);
  }
  .lp-section__head {
    max-width: 50rem;
    margin-bottom: clamp(2rem, 3.5vw, 3rem);
  }
  .lp-section__title {
    font-family: var(--font-sans);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }
  .lp-section__title strong {
    color: var(--lp-violet);
    font-weight: 700;
  }
  .lp-section__lead {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0;
    max-width: 40rem;
  }
  .lp-section__lead a { color: var(--lp-violet); text-decoration: underline; text-underline-offset: 2px; }
  .lp-section__lead strong { color: var(--color-ink); font-weight: 600; }

  .eyebrow {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: 1rem;
  }
  .eyebrow__num {
    color: var(--lp-violet);
    font-weight: 700;
  }

  /* ===== Audit layers (3 + bonus card) ===== */
  .audit-layers {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 2vw, 1.5rem);
  }
  @media (min-width: 768px) {
    .audit-layers { grid-template-columns: repeat(2, 1fr); }
  }
  .audit-layer {
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 12px;
    padding: 1.5rem 1.5rem 1.375rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .audit-layer--bonus {
    background: oklch(0.97 0.04 305 / 0.4);
    border-color: var(--lp-violet);
  }
  .audit-layer__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: var(--color-paper-deep);
    color: var(--color-ink-muted);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
  }
  .audit-layer__num[data-tone="seo"] { background: oklch(from var(--tone-seo) l c h / 0.15); color: var(--tone-seo); }
  .audit-layer__num[data-tone="geo"] { background: oklch(from var(--tone-geo) l c h / 0.15); color: var(--tone-geo); }
  .audit-layer__num[data-tone="aeo"] { background: oklch(from var(--tone-aeo) l c h / 0.18); color: oklch(from var(--tone-aeo) calc(l - 0.15) c h); }
  .audit-layer__num--bonus {
    background: var(--lp-violet);
    color: #fff;
    font-size: 1rem;
  }
  .audit-layer h3 {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    margin: 0.25rem 0 0.5rem;
  }
  .audit-layer ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .audit-layer li {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    padding-left: 1.125rem;
    position: relative;
  }
  .audit-layer li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--lp-violet);
    font-weight: 700;
    font-size: 0.85rem;
  }
  .audit-layer li strong { color: var(--color-ink); font-weight: 600; }

  /* ===== Trust block (reused from /kontakt/ style) ===== */
  .audit-trust {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.25rem, 2.5vw, 1.75rem);
  }
  @media (min-width: 768px) {
    .audit-trust { grid-template-columns: repeat(2, 1fr); }
  }
  .audit-trust__item {
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-left: 3px solid var(--lp-violet);
    border-radius: 10px;
    padding: 1.5rem 1.5rem 1.375rem;
  }
  .audit-trust__item h3 {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-ink);
    margin: 0 0 0.625rem;
  }
  .audit-trust__item p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0;
  }
  .audit-trust__item p a {
    color: var(--lp-violet);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .audit-trust__item p strong { color: var(--color-ink); }

  /* Bridge text mezi lead a comparison (Pack vs Audit) */
  .audit-bridge {
    max-width: 44rem;
    margin: 1.25rem 0 0;
    padding: 1rem 1.25rem;
    background: oklch(from var(--lp-magenta) l c h / 0.06);
    border-left: 3px solid var(--lp-magenta);
    border-radius: 0 8px 8px 0;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink);
  }
  .audit-bridge strong { font-weight: 600; }

  /* ===== Pack vs Audit comparison ===== */
  .audit-compare {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.25rem, 2.5vw, 2rem);
  }
  @media (min-width: 768px) {
    .audit-compare { grid-template-columns: repeat(2, 1fr); }
  }
  .audit-compare__col {
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 12px;
    padding: 1.75rem 1.625rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .audit-compare__col--featured {
    border-color: var(--lp-magenta);
    border-width: 2px;
    background: oklch(0.97 0.04 335 / 0.4);
    box-shadow: 0 8px 22px -10px oklch(from var(--lp-magenta) l c h / 0.3);
  }
  .audit-compare__col header {
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: 1rem;
  }
  .audit-compare__pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 0.75rem;
  }
  .audit-compare__pill--pack {
    color: var(--lp-violet);
    background: oklch(0.96 0.05 305 / 0.6);
  }
  .audit-compare__pill--audit {
    color: #fff;
    background: var(--lp-magenta);
  }
  .audit-compare__col h3 {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-ink);
    margin: 0 0 0.5rem;
  }
  .audit-compare__col h3 strong { color: var(--lp-violet); font-weight: 700; }
  .audit-compare__col--featured h3 strong { color: var(--lp-magenta); }
  .audit-compare__price {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0;
  }
  .audit-compare__col ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }
  .audit-compare__col li {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
    padding-left: 1.25rem;
    position: relative;
  }
  .audit-compare__col li::before {
    content: "→";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--lp-violet);
    font-weight: 700;
  }
  .audit-compare__col--featured li::before { color: var(--lp-magenta); }
  .audit-compare__col li strong { color: var(--color-ink); font-weight: 600; }
  .audit-compare__cta {
    align-self: flex-start;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.625rem 1.125rem;
    border-radius: 999px;
    text-decoration: none;
    color: #fff;
    background: var(--lp-violet);
    transition: background 0.15s ease, transform 0.15s ease;
    margin-top: 0.5rem;
  }
  .audit-compare__cta:hover {
    background: color-mix(in oklch, var(--lp-violet) 85%, black);
    transform: translateY(-1px);
  }
  .audit-compare__cta--accent { background: var(--lp-magenta); }
  .audit-compare__cta--accent:hover { background: color-mix(in oklch, var(--lp-magenta) 85%, black); }

  /* ===== FAQ ===== */
  .audit-faq {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    max-width: 48rem;
    margin: 0;
  }
  @media (min-width: 768px) {
    .audit-faq { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
  }
  .audit-faq > div {
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 10px;
    padding: 1.25rem 1.375rem 1.125rem;
  }
  .audit-faq dt {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 0.5rem;
    line-height: 1.35;
  }
  .audit-faq dd {
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0;
  }
  .audit-faq dd a {
    color: var(--lp-violet);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .audit-faq dd strong { color: var(--color-ink); font-weight: 600; }

  /* ===== ORDER FORM ===== */
  .audit-form {
    max-width: 42rem;
    margin: 0 auto;
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 12px;
    padding: clamp(1.75rem, 3vw, 2.5rem);
  }
  /* Inline varianta — form je uvnitř audit-hero__form-card, který má vlastní
     bg/border/padding. Odstraň duplikované card styling. */
  .audit-form--inline {
    max-width: none;
    margin: 0;
    background: none;
    border: none;
    border-radius: 0;
    padding: 0;
  }
  /* V úzké form-card (~480 px) je 2-col grid pro jméno/email moc tísnivý
     (216 px na pole). Force všechna pole na 1-col. */
  .audit-form--inline .audit-form__grid {
    grid-template-columns: 1fr;
    gap: 0.875rem;
  }
  /* Inputs viditelnější border na světlém form-card bg */
  .audit-form--inline .audit-form__field input[type="text"],
  .audit-form--inline .audit-form__field input[type="email"],
  .audit-form--inline .audit-form__field input[type="url"],
  .audit-form--inline .audit-form__field select,
  .audit-form--inline .audit-form__field textarea {
    border-color: var(--color-rule-strong);
  }
  /* Submit: full-width, gold (matchuje hero CTA), prominent — primární akce */
  .audit-form--inline .audit-form__submit {
    display: flex;
    justify-content: center;
    width: 100%;
    background: var(--sd-gold);
    color: var(--sd-deep);
    font-weight: 700;
    font-size: 1.0625rem;
    padding: 1.125rem 1.5rem;
    margin-top: 1.25rem;
    box-shadow: 0 8px 24px -8px oklch(from var(--sd-gold) l c h / 0.55);
  }
  .audit-form--inline .audit-form__submit:hover {
    background: color-mix(in oklch, var(--sd-gold) 85%, white);
    color: var(--sd-deep);
    transform: translateY(-2px);
    box-shadow: 0 12px 32px -8px oklch(from var(--sd-gold) l c h / 0.7);
  }
  .audit-form__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.125rem;
  }
  @media (min-width: 640px) {
    .audit-form__grid { grid-template-columns: repeat(2, 1fr); }
    .audit-form__field--full { grid-column: 1 / -1; }
  }
  .audit-form__field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .audit-form__field label {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-ink);
