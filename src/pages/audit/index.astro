---
import BaseLayout from "~/layouts/BaseLayout.astro";

const pageTitle = "AI SEO audit od Sniperdesign — přesný plán pro váš web, 9 990 Kč";
const pageDescription =
  "AI SEO audit od Sniperdesign za 9 990 Kč bez DPH. Projdeme váš konkrétní web v technice, obsahu a důvěryhodnosti. Prioritní seznam úprav s odhadem dopadu + 60min konzultace. Výstup do 5 pracovních dní. Zlatý Upgates partner od 2016, 600+ e-shopů.";

const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "AI SEO audit",
  provider: {
    "@type": "Organization",
    name: "CPU s.r.o.",
    alternateName: "Sniperdesign",
    url: "https://www.sniperdesign.cz/",
    email: "aiseo-optimalizace@sniperdesign.cz",
    telephone: "+420 775 181 634",
    address: {
      "@type": "PostalAddress",
      streetAddress: "Akademická 663/5",
      addressLocality: "Praha 10 — Malešice",
      postalCode: "10800",
      addressCountry: "CZ",
    },
  },
  areaServed: { "@type": "Country", name: "Czech Republic" },
  description:
    "Komplexní audit webu pro AI éru vyhledávání. Technický audit (Core Web Vitals, schema markup), obsahový audit (pillar coverage, on-page) a důvěryhodnost (E-E-A-T, NAP). Prioritní seznam úprav s odhadem dopadu + 60min konzultace s týmem. Výstup do 5 pracovních dní.",
  offers: {
    "@type": "Offer",
    price: "9990",
    priceCurrency: "CZK",
    priceSpecification: {
      "@type": "PriceSpecification",
      price: "9990",
      priceCurrency: "CZK",
      valueAddedTaxIncluded: false,
    },
    availability: "https://schema.org/InStock",
    url: "https://aiseo-optimalizace.cz/audit/",
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Pro koho je audit určený?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Audit je pro provozovatele e-shopů (Upgates, Shoptet, WooCommerce) a firemních webů, kteří chtějí konkrétní plán, co změnit pro AI éru vyhledávání. Hodí se pro weby s ročním obratem 1+ mil. Kč a s ambicí být citovaný v ChatGPT, Perplexity a Google AI Overviews.",
      },
    },
    {
      "@type": "Question",
      name: "Co když nemám AI SEO Wireframe Pack?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Pack i audit jsou samostatné produkty. Pack je framework pro DIY úpravy (1 490 Kč), audit je hands-on analýza vašeho webu se 60min konzultací (9 990 Kč). Audit můžete objednat samostatně — nepotřebujete předem Pack. Pokud máte Pack, audit se vám hodí jako navazující krok pro implementaci na váš konkrétní sortiment.",
      },
    },
    {
      "@type": "Question",
      name: "Jak dlouho audit trvá?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Výstup audit dokumentu do 5 pracovních dní od potvrzení objednávky. Po vyplnění formuláře vás kontaktujeme do 24 hodin (v pracovní dny) s upřesněním a fakturou. Po platbě začneme auditovat. 60min online konzultaci si domluvíme po dodání auditu.",
      },
    },
    {
      "@type": "Question",
      name: "Co konkrétně dostanu jako výstup?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Audit dokument (PDF nebo Notion / Google Doc, dle preference) obsahující: 1) technický audit (Core Web Vitals, schema markup, indexace, mobile UX), 2) obsahový audit (pillar coverage, on-page optimalizace, content gaps proti konkurenci), 3) E-E-A-T a důvěryhodnost (NAP konzistence, brand mentions, backlink profil). Plus prioritní seznam úprav s odhadem dopadu a effortu, a 60min online konzultaci s naším týmem.",
      },
    },
    {
      "@type": "Question",
      name: "Komu platím a dostanu fakturu?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Platíte CPU s.r.o. (IČO 08125163, plátce DPH). Faktura je vystavena samostatně po potvrzení objednávky. Cena 9 990 Kč je bez DPH (s DPH = 12 088 Kč).",
      },
    },
    {
      "@type": "Question",
      name: "Můžu se na něco zeptat předem?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Samozřejmě. Napište nám na aiseo-optimalizace@sniperdesign.cz nebo zavolejte +420 775 181 634 (Po-Pá 9-17). Pokud chcete spíš nezávaznou konzultaci než audit, máme i tuto možnost na sniperdesign.cz/konzultace.",
      },
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={[serviceJsonLd, faqJsonLd]}>
  <main class="audit">
    <!-- ===== HERO — Sniperdesign brand box ===== -->
    <section class="audit-hero" aria-labelledby="audit-hero-title">
      <div class="audit-hero__inner">
        <a
          href="https://www.sniperdesign.cz/"
          target="_blank"
          rel="noopener"
          class="audit-hero__brand"
          aria-label="Sniperdesign — domovská stránka agentury"
        >
          <img
            src="/sniperdesign/logo-wh.svg"
            alt="Sniperdesign"
            width="200"
            height="40"
            loading="eager"
          />
        </a>

        <span class="audit-hero__eyebrow">AI SEO audit od Sniperdesign</span>

        <h1 id="audit-hero-title" class="audit-hero__title">
          Přesný plán pro váš web &mdash; <strong>co změnit, proč a&nbsp;jaký to bude mít dopad</strong>
        </h1>

        <p class="audit-hero__lead">
          Projdeme váš konkrétní web v <strong>technice, obsahu a&nbsp;důvěryhodnosti</strong>.
          Dostanete prioritní seznam úprav s&nbsp;odhadem dopadu, ke&nbsp;všemu
          plus <strong>60 minutovou konzultaci s&nbsp;naším týmem</strong>.
          Výstup do&nbsp;<strong>5&nbsp;pracovních dní</strong>.
        </p>

        <div class="audit-hero__price-block">
          <div class="audit-hero__price">
            <strong>9&nbsp;990&nbsp;Kč bez DPH</strong>
            <span>včetně prioritizace úprav + 60min konzultace</span>
          </div>
          <div class="audit-hero__price-meta">
            <span>s&nbsp;DPH 12&nbsp;088&nbsp;Kč</span>
            <span>výstup do&nbsp;5&nbsp;pracovních dní</span>
            <span>PDF / Notion / Google Doc</span>
          </div>
        </div>

        <ul class="audit-hero__outcomes" role="list">
          <li>
            <strong>Prioritní seznam úprav</strong>, ne obecný audit bez pořadí
          </li>
          <li>
            U&nbsp;každého bodu uvidíte <strong>dopad × náročnost</strong>, abyste věděli, co řešit jako první
          </li>
          <li>
            Výstup přizpůsobíme vaší <strong>platformě a&nbsp;sortimentu</strong> a&nbsp;projdeme ho s&nbsp;vámi na&nbsp;60min konzultaci
          </li>
        </ul>

        <div class="audit-hero__actions">
          <a href="#objednat" class="audit-btn audit-btn--solid">
            Chci AI&nbsp;SEO audit
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 7H13M13 7L7 1M13 7L7 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </a>
          <a
            href="https://www.sniperdesign.cz/kontakt"
            target="_blank"
            rel="noopener"
            class="audit-btn audit-btn--ghost"
          >
            Máte před objednáním otázku? Napište nám
          </a>
        </div>

        <p class="audit-hero__legal">
          Provozovatel: <strong>CPU s.r.o.</strong> &middot; IČO 08125163 &middot; plátce DPH
        </p>
      </div>
    </section>

    <!-- ===== 01 CO JE V AUDITU (3 vrstvy + bonusy) ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">01</span> Co je v auditu</span>
        <h2 class="lp-section__title">
          Co v auditu zkontrolujeme &mdash; <strong>a co dostanete jako výstup</strong>
        </h2>
        <p class="lp-section__lead">
          Používáme stejný postup jako u&nbsp;klientských webů, které dlouhodobě
          spravujeme na&nbsp;Upgates, Shoptetu i&nbsp;vlastních řešeních.
          <strong>Ne generický checklist</strong>, ale audit přizpůsobený vašemu
          webu a&nbsp;platformě.
        </p>
      </header>

      <div class="audit-layers">
        <article class="audit-layer">
          <span class="audit-layer__num" data-tone="seo">01</span>
          <h3>Technika</h3>
          <ul>
            <li>Core Web Vitals (rychlost, stabilita, interaktivita)</li>
            <li>Mobile UX a&nbsp;čitelnost na&nbsp;telefonu</li>
            <li>Indexace v&nbsp;Google &mdash; co Google vidí, co ne</li>
            <li>Strukturovaná data (Product, FAQPage, Article, drobečková navigace)</li>
            <li>robots.txt a&nbsp;přístup crawlerů &mdash; jestli si vyhledávače a&nbsp;AI nástroje mohou správně přečíst to, co chcete</li>
            <li>Sitemap, canonical, noindex &mdash; technické pokyny pro vyhledávače</li>
          </ul>
        </article>

        <article class="audit-layer">
          <span class="audit-layer__num" data-tone="geo">02</span>
          <h3>Obsah</h3>
          <ul>
            <li>Pokrytí hlavních témat oboru &mdash; jestli web odpovídá na&nbsp;důležité otázky zákazníků</li>
            <li>On-page optimalizace klíčových stránek (homepage, top kategorie, top produkty)</li>
            <li>Krátké, jasné odpovědi u&nbsp;klíčových témat &mdash; aby měl Google i&nbsp;AI nástroje co citovat</li>
            <li>Časté dotazy se&nbsp;strukturovanými daty (FAQPage)</li>
            <li>Content gaps proti konkurenci &mdash; co konkurence pokrývá a&nbsp;vy ne</li>
            <li>Prolinkování mezi stránkami (hub-and-spoke)</li>
          </ul>
        </article>

        <article class="audit-layer">
          <span class="audit-layer__num" data-tone="aeo">03</span>
          <h3>Důvěryhodnost</h3>
          <ul>
            <li>Signály důvěryhodnosti &mdash; kdo za&nbsp;obsahem stojí, jak je ověřitelný a&nbsp;proč mu vyhledávače věřit (E-E-A-T)</li>
            <li>Kontaktní údaje (NAP) konzistence napříč webem a&nbsp;katalogy</li>
            <li>Backlink profil &mdash; odkazy z&nbsp;jiných webů, které na&nbsp;vás vedou</li>
            <li>Brand mentions v&nbsp;Googlu, ChatGPT a&nbsp;Perplexity</li>
            <li>Schema Organization a&nbsp;strukturovaná data pro místní firmu</li>
            <li>Reputace v&nbsp;Heuréce, Zboží, Google reviews</li>
          </ul>
        </article>

        <article class="audit-layer audit-layer--bonus">
          <span class="audit-layer__num audit-layer__num--bonus">✦</span>
          <h3>Co dostanete jako výstup</h3>
          <ul>
            <li><strong>Prioritní seznam úprav</strong> podle dopadu a&nbsp;náročnosti (co řešit jako první)</li>
            <li><strong>Konkrétní doporučení pro vaši platformu</strong> (Upgates, Shoptet, WordPress, custom) a&nbsp;typ webu</li>
            <li><strong>Audit ve&nbsp;formátu</strong> PDF / Notion / Google Doc &mdash; podle vaší preference</li>
            <li><strong>60min konzultace s&nbsp;týmem</strong> &mdash; projdeme závěry a&nbsp;další postup</li>
          </ul>
        </article>
      </div>
    </section>

    <!-- ===== 02 PROČ NÁM MŮŽETE DŮVĚŘOVAT ===== -->
    <section class="lp-section lp-section--alt">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">02</span> Proč nám můžete důvěřovat</span>
        <h2 class="lp-section__title">
          Reálná zkušenost <strong>z&nbsp;denodenní praxe</strong>
        </h2>
      </header>

      <div class="audit-trust">
        <article class="audit-trust__item">
          <h3>Praxe z&nbsp;600+ e-shopů na&nbsp;CZ trhu</h3>
          <p>
            Za roky praxe jsme pracovali pro <strong>600+ e-shopů</strong>
            na&nbsp;CZ trhu. Na&nbsp;webu agentury najdete <a href="https://www.sniperdesign.cz/reference" target="_blank" rel="noopener">43&nbsp;veřejných referencí</a>,
            další jsou neveřejné. Nekupujete audit od&nbsp;anonymního freelancera,
            ale od&nbsp;týmu s&nbsp;dlouhodobou praxí v&nbsp;e-commerce.
          </p>
        </article>

        <article class="audit-trust__item">
          <h3>Zlatý partner Upgates a&nbsp;Gold partner Shoptet</h3>
          <p>
            Jsme oficiální Zlatý partner Upgates (od&nbsp;roku&nbsp;2016)
            a&nbsp;Gold partner Shoptet. Známe limity i&nbsp;možnosti obou
            platforem, takže <strong>doporučení v&nbsp;auditu nejsou
            odtržená od&nbsp;reality implementace</strong>.
          </p>
        </article>

        <article class="audit-trust__item">
          <h3>Ověřujeme i&nbsp;na&nbsp;vlastním e-shopu</h3>
          <p>
            Doporučení nebereme z&nbsp;prezentací. Ověřujeme je i&nbsp;na&nbsp;vlastním
            e-shopu <a href="https://www.megadetail.cz/" target="_blank" rel="noopener"><strong>MEGA&nbsp;DETAIL</strong></a>, kde řešíme stejná
            témata jako naši klienti: obsah, výkon, UX i&nbsp;viditelnost.
          </p>
        </article>

        <article class="audit-trust__item">
          <h3>Vlastní nástroje pro e-commerce</h3>
          <p>
            Nevnímáme web jen optikou SEO checklistu. Díky vlastním nástrojům
            (<strong>SYNKRO</strong> pro automatizaci a&nbsp;<strong>GPTfeed</strong>
            pro obsah) a&nbsp;provozu e-shopů řešíme i&nbsp;to, co je reálně
            udržitelné v&nbsp;provozu: obsahové workflow, feedy a&nbsp;škálování úprav.
          </p>
        </article>
      </div>
    </section>

    <!-- ===== 03 PACK VS AUDIT ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">03</span> Pack vs. audit</span>
        <h2 class="lp-section__title">
          Co je pro vás <strong>vhodnější</strong>?
        </h2>
        <p class="lp-section__lead">
          <a href="/pack/">AI&nbsp;SEO Wireframe Pack</a> a&nbsp;audit nejsou
          konkurenti &mdash; řeší dvě různé situace. Často je nejlepší
          mít obojí: Pack jako framework, audit jako přesný plán pro váš
          konkrétní web.
        </p>
        <p class="audit-bridge">
          <strong>Pack je framework, který si aplikujete sami.</strong> Audit je
          placený za&nbsp;expertizu nad&nbsp;vaším konkrétním webem: co řešit
          hned, co počká, co má nejvyšší dopad a&nbsp;co je na&nbsp;vaší platformě
          reálně proveditelné. <strong>Neplatíte za&nbsp;objem textu, ale
          za&nbsp;prioritizaci, kontext a&nbsp;konzultaci.</strong>
        </p>
      </header>

      <div class="audit-compare">
        <article class="audit-compare__col">
          <header>
            <span class="audit-compare__pill audit-compare__pill--pack">Pack</span>
            <h3>Když chcete <strong>řešit věci sami</strong></h3>
            <p class="audit-compare__price">1&nbsp;490&nbsp;Kč &middot; jednorázově</p>
          </header>
          <ul>
            <li>Máte čas si&nbsp;doporučení sami vyhodnotit a&nbsp;převést do&nbsp;praxe</li>
            <li>Chcete obecný recept pro 7&nbsp;typů stránek webu (homepage, produkt, kategorie, blog, prodejní landing, kontakt)</li>
            <li>Hodí se i&nbsp;agenturám / copywriterům pro klientské weby</li>
            <li>Vhodné jako pracovní podklad pro vlastní úpravy nebo zadání pro tým</li>
            <li>Master PDF 85&nbsp;stran + 9&nbsp;jednotlivých kapitol</li>
          </ul>
          <a href="/pack/" class="audit-compare__cta">
            Zobrazit Pack&nbsp;&rarr;
          </a>
        </article>

        <article class="audit-compare__col audit-compare__col--featured">
          <header>
            <span class="audit-compare__pill audit-compare__pill--audit">Audit</span>
            <h3>Když chcete <strong>plán pro váš konkrétní web</strong></h3>
            <p class="audit-compare__price">9&nbsp;990&nbsp;Kč bez DPH &middot; jednorázově</p>
          </header>
          <ul>
            <li>Chcete <strong>přesnou analýzu vašeho webu</strong>, ne&nbsp;obecný framework</li>
            <li>Potřebujete <strong>prioritní seznam úprav</strong> &mdash; co změnit jako první, proč a&nbsp;jaký to bude mít dopad</li>
            <li>Chcete <strong>konzultaci s&nbsp;týmem</strong>, kde si projdete závěry osobně</li>
            <li>Nemáte čas / chuť projít Pack vlastní silou a&nbsp;preferujete hotový plán</li>
            <li>Výstup do&nbsp;5&nbsp;pracovních dní + 60min konzultace</li>
          </ul>
          <a href="#objednat" class="audit-compare__cta audit-compare__cta--accent">
            Objednat audit&nbsp;&rarr;
          </a>
        </article>
      </div>
    </section>

    <!-- ===== 04 FAQ ===== -->
    <section class="lp-section lp-section--alt">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">04</span> Časté otázky</span>
        <h2 class="lp-section__title">
          Než si <strong>objednáte audit</strong>
        </h2>
      </header>

      <dl class="audit-faq">
        <div>
          <dt>Pro koho je audit určený?</dt>
          <dd>
            Pro provozovatele e-shopů (Upgates, Shoptet, WooCommerce) a&nbsp;firemních
            webů, kteří chtějí <strong>konkrétní plán</strong>, co změnit pro AI éru
            vyhledávání. Hodí se pro weby s&nbsp;ročním obratem 1+&nbsp;mil.&nbsp;Kč
            a&nbsp;s&nbsp;ambicí být citovaný v&nbsp;ChatGPT, Perplexity
            a&nbsp;Google AI Overviews.
          </dd>
        </div>
        <div>
          <dt>Co když nemám AI SEO Wireframe Pack?</dt>
          <dd>
            Pack i&nbsp;audit jsou samostatné produkty. Pack je framework pro DIY
            úpravy (1&nbsp;490&nbsp;Kč), audit je hands-on analýza vašeho webu
            se&nbsp;60min konzultací. <strong>Audit můžete objednat samostatně</strong>
            &mdash; nepotřebujete předem Pack.
          </dd>
        </div>
        <div>
          <dt>Jak dlouho audit trvá?</dt>
          <dd>
            Výstup audit dokumentu <strong>do&nbsp;5&nbsp;pracovních dní</strong>
            od&nbsp;potvrzení objednávky. Po&nbsp;vyplnění formuláře vás
            kontaktujeme do&nbsp;24&nbsp;hodin v&nbsp;pracovní dny s&nbsp;upřesněním
            a&nbsp;fakturou. Po&nbsp;platbě začneme auditovat.
          </dd>
        </div>
        <div>
          <dt>Co konkrétně dostanu jako výstup?</dt>
          <dd>
            Audit dokument (PDF nebo Notion / Google Doc, dle preference) se&nbsp;třemi
            vrstvami analýzy + <strong>prioritní seznam úprav</strong> s&nbsp;odhadem
            dopadu a&nbsp;effortu + <strong>60min online konzultaci</strong>
            s&nbsp;naším týmem.
          </dd>
        </div>
        <div>
          <dt>Komu platím a&nbsp;dostanu fakturu?</dt>
          <dd>
            Platíte <strong>CPU s.r.o.</strong> (IČO 08125163, plátce DPH). Faktura
            je vystavena samostatně po&nbsp;potvrzení objednávky. Cena <strong>9&nbsp;990&nbsp;Kč
            bez DPH</strong> (s&nbsp;DPH = 12&nbsp;088&nbsp;Kč).
          </dd>
        </div>
        <div>
          <dt>Co audit nezahrnuje?</dt>
          <dd>
            Audit zahrnuje <strong>analýzu, prioritizaci a&nbsp;konzultaci</strong>.
            Samotná <strong>implementace úprav, copywriting, vývoj nebo dlouhodobá
            správa</strong> nejsou součástí ceny, ale můžeme je případně nacenit
            zvlášť po&nbsp;dodání auditu.
          </dd>
        </div>
        <div>
          <dt>Mohu objednávku zrušit?</dt>
          <dd>
            Ano, <strong>do&nbsp;potvrzení rozsahu a&nbsp;vystavení faktury</strong> bez
            problémů. Jakmile je rozsah potvrzen a&nbsp;audit zahájen, jde o&nbsp;službu
            připravovanou na&nbsp;míru a&nbsp;storno řešíme individuálně podle
            rozpracovanosti.
          </dd>
        </div>
        <div>
          <dt>Můžu se na&nbsp;něco zeptat předem?</dt>
          <dd>
            Samozřejmě. Napište na&nbsp;<a href="mailto:aiseo-optimalizace@sniperdesign.cz">aiseo-optimalizace@sniperdesign.cz</a>
            nebo zavolejte <a href="tel:+420775181634">+420&nbsp;775&nbsp;181&nbsp;634</a>
            (Po&minus;Pá 9&minus;17). Pokud preferujete nezávaznou konzultaci, máme
            i&nbsp;tuto možnost na&nbsp;<a href="https://www.sniperdesign.cz/konzultace" target="_blank" rel="noopener">sniperdesign.cz/konzultace</a>.
          </dd>
        </div>
      </dl>
    </section>

    <!-- ===== 05 OBJEDNAT FORM ===== -->
    <section class="lp-section" id="objednat">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">05</span> Objednat audit</span>
        <h2 class="lp-section__title">
