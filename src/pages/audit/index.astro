---
import BaseLayout from "~/layouts/BaseLayout.astro";

const pageTitle = "AI SEO audit od Sniperdesign — přesný plán pro váš web, 9 990 Kč";
const pageDescription =
  "AI SEO audit od Sniperdesign za 9 990 Kč bez DPH. Projdeme váš konkrétní web v technice, obsahu a důvěryhodnosti. Prioritní seznam úprav s odhadem dopadu + 60min konzultace. Výstup do 5 pracovních dní. Zlatý Upgates partner od 2016, 600+ e-shopů.";

const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "AI SEO audit",
  provider: {
    "@type": "Organization",
    name: "CPU s.r.o.",
    alternateName: "Sniperdesign",
    url: "https://www.sniperdesign.cz/",
    email: "aiseo-optimalizace@sniperdesign.cz",
    telephone: "+420 775 181 634",
    address: {
      "@type": "PostalAddress",
      streetAddress: "Akademická 663/5",
      addressLocality: "Praha 10 — Malešice",
      postalCode: "10800",
      addressCountry: "CZ",
    },
  },
  areaServed: { "@type": "Country", name: "Czech Republic" },
  description:
    "Komplexní audit webu pro AI éru vyhledávání. Technický audit (Core Web Vitals, schema markup), obsahový audit (pillar coverage, on-page) a důvěryhodnost (E-E-A-T, NAP). Prioritní seznam úprav s odhadem dopadu + 60min konzultace s týmem. Výstup do 5 pracovních dní.",
  offers: {
    "@type": "Offer",
    price: "9990",
    priceCurrency: "CZK",
    priceSpecification: {
      "@type": "PriceSpecification",
      price: "9990",
      priceCurrency: "CZK",
      valueAddedTaxIncluded: false,
    },
    availability: "https://schema.org/InStock",
    url: "https://aiseo-optimalizace.cz/audit/",
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Pro koho je audit určený?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Audit je pro provozovatele e-shopů (Upgates, Shoptet, WooCommerce) a firemních webů, kteří chtějí konkrétní plán, co změnit pro AI éru vyhledávání. Hodí se pro weby s ročním obratem 1+ mil. Kč a s ambicí být citovaný v ChatGPT, Perplexity a Google AI Overviews.",
      },
    },
    {
      "@type": "Question",
      name: "Co když nemám AI SEO Wireframe Pack?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Pack i audit jsou samostatné produkty. Pack je framework pro DIY úpravy (1 490 Kč), audit je hands-on analýza vašeho webu se 60min konzultací (9 990 Kč). Audit můžete objednat samostatně — nepotřebujete předem Pack. Pokud máte Pack, audit se vám hodí jako navazující krok pro implementaci na váš konkrétní sortiment.",
      },
    },
    {
      "@type": "Question",
      name: "Jak dlouho audit trvá?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Výstup audit dokumentu do 5 pracovních dní od potvrzení objednávky. Po vyplnění formuláře vás kontaktujeme do 24 hodin (v pracovní dny) s upřesněním a fakturou. Po platbě začneme auditovat. 60min online konzultaci si domluvíme po dodání auditu.",
      },
    },
    {
      "@type": "Question",
      name: "Co konkrétně dostanu jako výstup?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Audit dokument (PDF nebo Notion / Google Doc, dle preference) obsahující: 1) technický audit (Core Web Vitals, schema markup, indexace, mobile UX), 2) obsahový audit (pillar coverage, on-page optimalizace, content gaps proti konkurenci), 3) E-E-A-T a důvěryhodnost (NAP konzistence, brand mentions, backlink profil). Plus prioritní seznam úprav s odhadem dopadu a effortu, a 60min online konzultaci s naším týmem.",
      },
    },
    {
      "@type": "Question",
      name: "Komu platím a dostanu fakturu?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Platíte CPU s.r.o. (IČO 08125163, plátce DPH). Faktura je vystavena samostatně po potvrzení objednávky. Cena 9 990 Kč je bez DPH (s DPH = 12 088 Kč).",
      },
    },
    {
      "@type": "Question",
      name: "Můžu se na něco zeptat předem?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Samozřejmě. Napište nám na aiseo-optimalizace@sniperdesign.cz nebo zavolejte +420 775 181 634 (Po-Pá 9-17). Pokud chcete spíš nezávaznou konzultaci než audit, máme i tuto možnost na sniperdesign.cz/konzultace.",
      },
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={[serviceJsonLd, faqJsonLd]} image="/og/audit.png">
  <main class="audit">
    <!-- ===== HERO — 2-col split: copy + form card ===== -->
    <!-- Form přesunutý do hero RIGHT col (dříve byl až sekce 05 pod FAQ).
         Vysoký-intent návštěvník nemusí scrollovat 7 obrazovek pro objednávku. -->
    <section class="audit-hero" aria-labelledby="audit-hero-title">
      <div class="audit-hero__inner audit-hero__inner--split">

        <div class="audit-hero__copy">
          <a
            href="https://www.sniperdesign.cz/"
            target="_blank"
            rel="noopener"
            class="audit-hero__brand"
            aria-label="Sniperdesign — domovská stránka agentury"
          >
            <img
              src="/sniperdesign/logo-wh.svg"
              alt="Sniperdesign"
              width="200"
              height="40"
              loading="eager"
            />
          </a>

          <span class="audit-hero__eyebrow">AI SEO audit od Sniperdesign</span>

          <h1 id="audit-hero-title" class="audit-hero__title">
            AI už cituje něčí web. <strong>Audit ukáže, proč ne&nbsp;ten&nbsp;váš.</strong>
          </h1>

          <p class="audit-hero__lead">
            Projdeme váš konkrétní web v <strong>technice, obsahu a&nbsp;důvěryhodnosti</strong>
            a&nbsp;dáme vám prioritní seznam úprav s&nbsp;odhadem dopadu plus
            <strong>60 minutovou konzultaci</strong>. Výstup
            do&nbsp;<strong>5&nbsp;pracovních dní</strong>.
          </p>

          <ul class="audit-hero__outcomes" role="list">
            <li>
              <strong>Prioritní seznam úprav</strong>, ne obecný audit bez pořadí
            </li>
            <li>
              U&nbsp;každého bodu uvidíte <strong>dopad × náročnost</strong>, abyste věděli, co řešit jako první
            </li>
            <li>
              Výstup přizpůsobíme vaší <strong>platformě a&nbsp;sortimentu</strong> a&nbsp;projdeme ho s&nbsp;vámi na&nbsp;60min konzultaci
            </li>
          </ul>

          <p class="audit-hero__legal">
            Provozovatel: <strong>CPU s.r.o.</strong> &middot; IČO 08125163 &middot; plátce DPH
          </p>
        </div>

        <aside class="audit-hero__form-card" id="objednat" aria-labelledby="audit-hero-form-title">
          <header class="audit-hero__form-head">
            <span class="audit-hero__form-eyebrow">
              <span class="audit-hero__form-eyebrow-pill">Objednávka</span>
              <span>výstup do 5 pracovních dní</span>
            </span>
            <p id="audit-hero-form-title" class="audit-hero__form-price">
              <strong>9&nbsp;990&nbsp;Kč</strong>
              <span class="audit-hero__form-price-detail">bez DPH (s&nbsp;DPH 12&nbsp;088&nbsp;Kč)</span>
            </p>
            <p class="audit-hero__form-reframe">
              Kupujete <strong>zkrácení rozhodování</strong> &mdash; místo týdnů
              domýšlení dostanete priority připravené k&nbsp;předání copywriterovi,
              vývojáři nebo internímu&nbsp;týmu.
            </p>
          </header>

          <form
            class="audit-form audit-form--inline"
            method="post"
            action="https://sniperdesign.ecomailapp.cz/public/subscribe/12/04d9c95424b2f28aaece6f953bb0e4aa"
            novalidate
          >
            <input type="hidden" name="name" id="audit-form-name" value="Audit poptávka" />
            <input type="hidden" name="updateExisting" value="1" />

            <div class="audit-form__grid">
              <div class="audit-form__field">
                <label for="audit-jmeno">
                  Vaše jméno <span aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="audit-jmeno"
                  required
                  autocomplete="name"
                  placeholder="Honza Novák"
                />
              </div>

              <div class="audit-form__field">
                <label for="audit-email">
                  E-mail <span aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="audit-email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder="honza@vas-eshop.cz"
                />
              </div>

              <div class="audit-form__field audit-form__field--full">
                <label for="audit-url">
                  URL webu, který chcete auditovat <span aria-hidden="true">*</span>
                </label>
                <input
                  type="url"
                  id="audit-url"
                  required
                  placeholder="https://vas-eshop.cz"
                  autocomplete="url"
                />
              </div>

              <div class="audit-form__field audit-form__field--full">
                <label for="audit-platforma">Platforma webu</label>
                <select id="audit-platforma">
                  <option value="">— vyberte —</option>
                  <option value="Upgates">Upgates</option>
                  <option value="Shoptet">Shoptet</option>
                  <option value="WooCommerce">WooCommerce</option>
                  <option value="WordPress">WordPress</option>
                  <option value="Webflow">Webflow</option>
                  <option value="Shopify">Shopify</option>
                  <option value="Custom / vlastní">Custom / vlastní řešení</option>
                  <option value="Nevím">Nevím / poradíte</option>
                </select>
              </div>

              <div class="audit-form__field audit-form__field--full">
                <label for="audit-cil">
                  Hlavní cíl auditu <span class="audit-form__hint">(volitelně, ale pomůže nám)</span>
                </label>
                <textarea
                  id="audit-cil"
                  rows="3"
                  placeholder="např. pokles z Googlu, slabá viditelnost, příprava na rebrand, lepší citace v AI nástrojích…"
                ></textarea>
              </div>

              <div class="audit-form__field audit-form__field--full audit-form__gdpr">
                <label>
                  <input type="checkbox" id="audit-gdpr" required />
                  <span>
                    Souhlasím se&nbsp;<a href="/gdpr/">zpracováním osobních údajů</a>
                    za&nbsp;účelem zpracování této poptávky. <span aria-hidden="true">*</span>
                  </span>
                </label>
              </div>
            </div>

            <button type="submit" class="audit-form__submit">
              Objednat audit za 9&nbsp;990&nbsp;Kč
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M1 7H13M13 7L7 1M13 7L7 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </button>

            <p class="audit-form__legal">
              Údaje použijeme pro vyřízení této poptávky a&nbsp;komunikaci k&nbsp;auditu.
              <strong>Bez samostatného souhlasu vás nezařadíme do&nbsp;marketingových
              e-mailů.</strong>
            </p>
          </form>
        </aside>

      </div>
    </section>

    <!-- ===== URGENCY / FOMO „proč to řešit teď" — hned za hero ===== -->
    <!-- Po hero (kde uživatel vidí formulář vpravo) přichází 3-card urgency
         blok — silný FOMO argument PRED tím, než pokračuje k „Co je v auditu". -->
    <section class="audit-urgency" aria-labelledby="audit-urgency-title">
      <div class="audit-urgency__inner">
        <header class="audit-urgency__head">
          <span class="audit-urgency__pill">Proč to řešit teď</span>
          <h2 id="audit-urgency-title" class="audit-urgency__title">
            <strong>Každý měsíc čekání</strong> obsazuje konkurence místo, které mohlo patřit&nbsp;vám
          </h2>
        </header>

        <div class="audit-urgency__grid">
          <article class="audit-urgency-card">
            <span class="audit-urgency-card__num">01</span>
            <h3 class="audit-urgency-card__title">AI už odpovídá za vyhledávač</h3>
            <p class="audit-urgency-card__desc">
              ChatGPT, Perplexity i&nbsp;Google AI&nbsp;Overviews dnes odpovídají
              zákazníkům přímo &mdash; místo klasického seznamu odkazů. Klikne se
              jen na&nbsp;to, co AI vybere jako zdroj.
            </p>
          </article>

          <article class="audit-urgency-card">
            <span class="audit-urgency-card__num">02</span>
            <h3 class="audit-urgency-card__title">Bez signálů AI vybírá někoho jiného</h3>
            <p class="audit-urgency-card__desc">
              Pokud váš web nemá jasné krátké odpovědi, strukturovaná data
              a&nbsp;signály důvěryhodnosti, AI sáhne pro&nbsp;zdroj, který je
              má. Často konkurence, která to&nbsp;začala řešit dřív.
            </p>
          </article>

          <article class="audit-urgency-card">
            <span class="audit-urgency-card__num">03</span>
            <h3 class="audit-urgency-card__title">Každý měsíc čekání = ztracené pozice</h3>
            <p class="audit-urgency-card__desc">
              Témata a&nbsp;dotazy, na&nbsp;které AI dnes odpovídá, někdo
              obsadí. Pozdější příchod znamená přepisovat víc obsahu,
              dohánět autoritu, soutěžit o&nbsp;už zacementované citace.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- ===== 01 CO JE V AUDITU (3 vrstvy + bonusy) ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">01</span> Co je v auditu</span>
        <h2 class="lp-section__title">
          Co v auditu zkontrolujeme &mdash; <strong>a co dostanete jako výstup</strong>
        </h2>
        <p class="lp-section__lead">
          Používáme stejný postup jako u&nbsp;klientských webů, které dlouhodobě
          spravujeme na&nbsp;Upgates, Shoptetu i&nbsp;vlastních řešeních.
          <strong>Ne generický checklist</strong>, ale audit přizpůsobený vašemu
          webu a&nbsp;platformě.
        </p>
      </header>

      <div class="audit-layers">
        <article class="audit-layer">
          <span class="audit-layer__num" data-tone="seo">01</span>
          <h3>Technika</h3>
          <ul>
            <li>Core Web Vitals (rychlost, stabilita, interaktivita)</li>
            <li>Mobile UX a&nbsp;čitelnost na&nbsp;telefonu</li>
            <li>Indexace v&nbsp;Google &mdash; co Google vidí, co ne</li>
            <li>Strukturovaná data (Product, FAQPage, Article, drobečková navigace)</li>
            <li>robots.txt a&nbsp;přístup crawlerů &mdash; jestli si vyhledávače a&nbsp;AI nástroje mohou správně přečíst to, co chcete</li>
            <li>Sitemap, canonical, noindex &mdash; technické pokyny pro vyhledávače</li>
          </ul>
        </article>

        <article class="audit-layer">
          <span class="audit-layer__num" data-tone="geo">02</span>
          <h3>Obsah</h3>
          <ul>
            <li>Pokrytí hlavních témat oboru &mdash; jestli web odpovídá na&nbsp;důležité otázky zákazníků</li>
            <li>On-page optimalizace klíčových stránek (homepage, top kategorie, top produkty)</li>
            <li>Krátké, jasné odpovědi u&nbsp;klíčových témat &mdash; aby měl Google i&nbsp;AI nástroje co citovat</li>
            <li>Časté dotazy se&nbsp;strukturovanými daty (FAQPage)</li>
            <li>Content gaps proti konkurenci &mdash; co konkurence pokrývá a&nbsp;vy ne</li>
            <li>Prolinkování mezi stránkami (hub-and-spoke)</li>
          </ul>
        </article>

        <article class="audit-layer">
          <span class="audit-layer__num" data-tone="aeo">03</span>
          <h3>Důvěryhodnost</h3>
          <ul>
            <li>Signály důvěryhodnosti &mdash; kdo za&nbsp;obsahem stojí, jak je ověřitelný a&nbsp;proč mu vyhledávače věřit (E-E-A-T)</li>
            <li>Kontaktní údaje (NAP) konzistence napříč webem a&nbsp;katalogy</li>
            <li>Backlink profil &mdash; odkazy z&nbsp;jiných webů, které na&nbsp;vás vedou</li>
            <li>Schema Organization a&nbsp;strukturovaná data pro místní firmu</li>
            <li>Reputace v&nbsp;Heuréce, Zboží, Google reviews</li>
          </ul>
        </article>

      </div>

      <!-- AI Visibility Check — elevated callout (audit #12) -->
      <aside class="audit-visibility" aria-labelledby="audit-visibility-title">
        <div class="audit-visibility__inner">
          <span class="audit-visibility__pill">★ Součástí auditu</span>
          <h3 id="audit-visibility-title" class="audit-visibility__title">
            AI Visibility Check &mdash; <strong>jste viditelní v&nbsp;AI&nbsp;odpovědích?</strong>
          </h3>
          <p class="audit-visibility__desc">
            Ověříme, jestli se&nbsp;vaše značka objevuje v&nbsp;odpovědích ChatGPT,
            Perplexity a&nbsp;Google AI&nbsp;Overviews u&nbsp;dotazů, které souvisí
            s&nbsp;vaším sortimentem nebo službou &mdash; a&nbsp;jestli AI nástroje
            místo vás nezmiňují&nbsp;konkurenci.
          </p>
        </div>
      </aside>

      <!-- Co konkrétně dostanete — sample output struktura (audit #5) -->
      <article class="audit-deliverable">
        <header class="audit-deliverable__head">
          <span class="audit-deliverable__pill">★ Výstup</span>
          <h3 class="audit-deliverable__title">
            Co konkrétně dostanete jako <strong>audit dokument</strong>
          </h3>
          <p class="audit-deliverable__lead">
            Strukturovaný dokument (PDF / Notion / Google Doc &mdash; podle
            vaší preference), který obsahuje:
          </p>
        </header>

        <ol class="audit-deliverable__list">
          <li>
            <strong>Kritická zjištění</strong>
            <span>Co teď nejvíc brzdí viditelnost ve&nbsp;vyhledávačích a&nbsp;AI nástrojích.</span>
          </li>
          <li>
            <strong>Prioritní tabulka úprav</strong>
            <span>Každá položka: dopad &times; náročnost &times; kdo by ji&nbsp;měl řešit (vývojář / copywriter / interní tým).</span>
          </li>
          <li>
            <strong>Technické problémy</strong>
            <span>Konkrétní URL, screenshot/citace, doporučená oprava. Připravené k&nbsp;předání vývojáři.</span>
          </li>
          <li>
            <strong>Obsahové mezery proti konkurenci</strong>
            <span>Témata a&nbsp;dotazy, kde konkurence pokrývá a&nbsp;vy ne &mdash; s&nbsp;odhadem priority.</span>
          </li>
          <li>
            <strong>Doporučení pro&nbsp;AI citovatelnost</strong>
            <span>Konkrétní úpravy textu, strukturovaných dat a&nbsp;signálů důvěryhodnosti, aby vás AI začala citovat.</span>
          </li>
          <li>
            <strong>30denní akční plán</strong>
            <span>Co řešit první týden, druhý, třetí, čtvrtý &mdash; v&nbsp;pořadí, které dává smysl.</span>
          </li>
          <li>
            <strong>60min konzultace s&nbsp;týmem</strong>
            <span>Projdeme závěry, dáme prostor na&nbsp;otázky, doladíme priority dle&nbsp;vašich možností.</span>
          </li>
        </ol>
      </article>
    </section>

    <!-- ===== 02 PROČ NÁM MŮŽETE DŮVĚŘOVAT ===== -->
    <section class="lp-section lp-section--alt">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">02</span> Proč nám můžete důvěřovat</span>
        <h2 class="lp-section__title">
          Reálná zkušenost <strong>z&nbsp;denodenní praxe</strong>
        </h2>
      </header>

      <div class="audit-trust">
        <article class="audit-trust__item">
          <h3>Praxe z&nbsp;600+ e-shopů na&nbsp;CZ trhu</h3>
          <p>
            Za roky praxe jsme pracovali pro <strong>600+ e-shopů</strong>
            na&nbsp;CZ trhu. Na&nbsp;webu agentury najdete <a href="https://www.sniperdesign.cz/reference" target="_blank" rel="noopener">43&nbsp;veřejných referencí</a>,
            další jsou neveřejné. Nekupujete audit od&nbsp;anonymního freelancera,
            ale od&nbsp;týmu s&nbsp;dlouhodobou praxí v&nbsp;e-commerce.
          </p>
        </article>

        <article class="audit-trust__item">
          <h3>Zlatý partner Upgates a&nbsp;Gold partner Shoptet</h3>
          <p>
            Jsme oficiální Zlatý partner Upgates (od&nbsp;roku&nbsp;2016)
            a&nbsp;Gold partner Shoptet. Známe limity i&nbsp;možnosti obou
            platforem, takže <strong>doporučení v&nbsp;auditu nejsou
            odtržená od&nbsp;reality implementace</strong>.
          </p>
        </article>

        <article class="audit-trust__item">
          <h3>Ověřujeme i&nbsp;na&nbsp;vlastním e-shopu</h3>
          <p>
            Doporučení nebereme z&nbsp;prezentací. Ověřujeme je i&nbsp;na&nbsp;vlastním
            e-shopu <a href="https://www.megadetail.cz/" target="_blank" rel="noopener"><strong>MEGA&nbsp;DETAIL</strong></a>, kde řešíme stejná
            témata jako naši klienti: obsah, výkon, UX i&nbsp;viditelnost.
          </p>
        </article>

        <article class="audit-trust__item">
          <h3>Vlastní nástroje pro e-commerce</h3>
          <p>
