---
import BaseLayout from "~/layouts/BaseLayout.astro";
import EmailCapture from "~/components/EmailCapture.astro";
import SniperDesignSmallContact from "~/components/sniperdesign/SmallContact.astro";

const pageTitle = "Návod zdarma — Jak má vypadat homepage pro AI vyhledávání";
const pageDescription =
  "Stáhněte si zdarma 6stránkový PDF průvodce s wireframem, anotacemi a třemi principy. Jak má homepage vypadat, aby ji našel Google, citoval ChatGPT a vytahoval Google AI Overviews. Výměnou za e-mail.";

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Co je v PDF a kolik to má stránek?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Šest stran: anotovaný wireframe homepage, tři principy SEO/GEO/AEO, mikro-case před/po a pět nejčastějších chyb. Praktický framework, ne teoretický ebook — pochopíte logiku za každým prvkem.",
      },
    },
    {
      "@type": "Question",
      name: "Pro koho je návod určený?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Pro provozovatele webů a e-shopů, marketing/SEO specialisty, B2B agentury, copywritery, designéry a vývojáře, kteří chtějí, aby jejich homepage byla připravená nejen na klasický Google, ale i na AI vyhledávače jako ChatGPT, Perplexity nebo Google AI Overviews.",
      },
    },
    {
      "@type": "Question",
      name: "Jak rychle dostanu PDF po vyplnění e-mailu?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Okamžitě. Do několika sekund po odeslání formuláře vám pošleme e-mail s odkazem ke stažení. Pokud zprávu nevidíte, zkontrolujte složku Hromadné nebo Promo akce.",
      },
    },
    {
      "@type": "Question",
      name: "Funguje to i pro e-shop?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Tento návod cílí konkrétně na homepage firemního webu nebo služby. Pro e-shop platí stejné principy, ale jiná struktura sekcí — to pokrývá rozšířený Wireframe Pack za 1 490 Kč, kde je sedm typů stránek včetně produktové a kategoriální.",
      },
    },
    {
      "@type": "Question",
      name: "Co když chci, ať to za mě uděláte vy?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sniperdesign nabízí AI SEO audit za 9 990 Kč. Projdeme váš web, najdeme problémy ve třech vrstvách (technika, obsah, autorita), dáme vám prioritní seznam úprav a 60min konzultaci. Výstup do 5 pracovních dní.",
      },
    },
    {
      "@type": "Question",
      name: "Můžu se kdykoli odhlásit z e-mailů?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ano. V každém e-mailu je odhlašovací odkaz, jedním kliknutím vás odstraníme z databáze. Žádné spamování, žádný důraz na neustálé prodávání.",
      },
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={faqJsonLd} noindex={true}>
  <main class="lp">
    <!-- ===== HERO (v2 — fold-fit pro Full HD) =====
         Text 1:1 jako v1, jediný strukturální zásah:
         - CTA card přesunuta do PRAVÉHO sloupce nahoře (vždy nad foldem)
         - Image SUB-stack pod CTA kartou, zmenšená
         - Levý sloupec: jen copy (eyebrow, h1, urgency, lead)
         - Tighter padding/margins přes CSS
         Cíl: CTA card bottom ≤ 768 px na Full HD i MacBook viewportech. -->
    <section class="lp-hero lp-hero--compact">
      <div class="lp-hero__inner">
        <div class="lp-hero__copy">
          <span class="lp-hero__eyebrow">Návod zdarma · pro AI vyhledávání</span>
          <h1 class="lp-hero__title">
            Vaši zákazníci se dnes ptají ChatGPT.<br />
            <strong>Cituje umělá inteligence váš obsah?</strong>
          </h1>
          <p class="lp-hero__urgency">
            Firmy už dnes optimalizují obsah pro AI odpovědi. Pokud AI nerozumí
            vašemu homepage, <strong>doporučí konkurenci</strong>.
          </p>
          <p class="lp-hero__lead">
            Návod, podle kterého homepage začne fungovat v AI vyhledávání.
            Wireframe s anotacemi, tři principy a mikro‑case před/po.
            Aplikujete na svůj web během odpoledne — a začnete dostávat
            přístupy z AI, které byste jinak neviděli.
          </p>
        </div>

        <!-- RIGHT column: CTA card on top + image below (smaller) -->
        <aside class="lp-hero__side">
          <div class="lp-hero__cta-card" role="region" aria-labelledby="cta-card-eyebrow">
            <span id="cta-card-eyebrow" class="lp-hero__cta-eyebrow">
              <span class="lp-hero__cta-eyebrow-pill">Zdarma</span>
              <span>Doručíme e-mailem do 30 vteřin</span>
            </span>

            <ul class="lp-hero__bullets" aria-label="Co dostanete">
              <li>Wireframe homepage s 10 anotacemi (SEO / GEO / AEO)</li>
              <li>Tři klíčové principy a mikro‑case před / po</li>
              <li>5 nejčastějších chyb, které vidíme u klientských webů</li>
            </ul>

            <EmailCapture
              variant="hero"
              buttonLabel="Stáhnout AI SEO návod zdarma"
              leadSourceTag="Lead — Návod zdarma (homepage v2)"
            />
          </div>

          <div class="lp-hero__mockup" aria-hidden="true">
            <figure class="hero-illustration">
              <img
                src="/navod-zdarma/hero-illustration.png"
                alt=""
                width="1024"
                height="1536"
                loading="eager"
                decoding="async"
              />
            </figure>
          </div>
        </aside>
      </div>
    </section>

    <!-- ===== CO DOSTANETE ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">01</span> Co najdete v PDF</span>
        <h2 class="lp-section__title">
          Postavte homepage tak, aby vás <strong>AI citovala, doporučovala a vytahovala do AI Overviews</strong>
        </h2>
      </header>

      <div class="lp-features">
        <article class="lp-feature">
          <span class="lp-feature__num">1</span>
          <h3 class="lp-feature__title">Wireframe s 10 anotacemi</h3>
          <p class="lp-feature__desc">
            Homepage, podle které okamžitě poznáte slabá místa svého webu.
            Každý prvek má vysvětlení, jaký signál pro Google, ChatGPT
            a AI Overviews generuje a proč na něm záleží.
          </p>
        </article>

        <article class="lp-feature">
          <span class="lp-feature__num">2</span>
          <h3 class="lp-feature__title">Tři klíčové principy</h3>
          <p class="lp-feature__desc">
            Hlavní nadpis, krátká odpověď 40–60 slov a FAQ se strukturovanými daty.
            Tři vrstvy, díky kterým vás AI nástroje pochopí a ocitují — místo aby
            doporučily konkurenci.
          </p>
        </article>

        <article class="lp-feature">
          <span class="lp-feature__num">3</span>
          <h3 class="lp-feature__title">Mikro-case před / po</h3>
          <p class="lp-feature__desc">
            Konkrétní příklad transformace generického nadpisu na specifický.
            Ukazuje, jak malá změna v hlavním nadpisu mění, jestli vás AI doporučí
            — nebo přehlédne.
          </p>
        </article>

        <article class="lp-feature">
          <span class="lp-feature__num">4</span>
          <h3 class="lp-feature__title">Pět typických chyb</h3>
          <p class="lp-feature__desc">
            Pět chyb, kvůli kterým AI špatně chápe váš homepage — i&nbsp;když máte
            dobrý produkt. Z analýzy stovek e‑shopů: opakují se pořád stejné.
          </p>
        </article>
      </div>
    </section>

    <!-- ===== PRO KOHO ===== -->
    <section class="lp-section lp-section--alt">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">02</span> Pro koho je to</span>
        <h2 class="lp-section__title">
          <strong>Univerzální postup</strong> — funguje na e-shopu, webu služeb i firemní prezentaci
        </h2>
      </header>

      <ul class="lp-audience">
        <li>
          <strong>Provozovatelé webů a e-shopů</strong> — víte, že je třeba něco
          změnit, ale nevíte, kde začít.
        </li>
        <li>
          <strong>SEO a marketing specialisté</strong> — potřebujete framework,
          který předáte klientovi nebo internímu týmu.
        </li>
        <li>
          <strong>Copywriteři, designéři, vývojáři</strong> — chcete navrhovat
          homepage, které AI chápe stejně dobře jako člověk.
        </li>
        <li>
          <strong>B2B agentury</strong> — hledáte vlastní pracovní rámec
          pro klientské weby v AI éře.
        </li>
      </ul>
    </section>

    <!-- ===== AUTHORITY — Sniperdesign medallion =====
         Shared component, stejný brand styl jako na homepage (BigContact).
         Self-contained, vlastní H2 + lead + 3 trust signály + 2 CTA.
    -->
    <SniperDesignSmallContact />


    <!-- ===== UPSELL TEASER ===== -->
    <section class="lp-section" id="pack">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">03</span> Co dál — pokud chcete víc</span>
        <span class="lp-section__proof">600+ e‑shopů · specialisté na Upgates a Shoptet</span>
        <h2 class="lp-section__title">
          Tohle PDF řeší jednu stránku. <strong>AI vyhledávání ale hodnotí celý web.</strong>
        </h2>
        <p class="lp-section__lead">
          Pokud má konkurence připravené i produktové stránky, kategorie a blog,
          dohoníte je těžko. Tady jsou dva způsoby, jak se vyrovnat.
        </p>
      </header>

      <div class="lp-tiers">
        <article class="lp-tier">
          <span class="lp-tier__num">Pack · pro celý web</span>
          <h3 class="lp-tier__title">Kompletní AI&nbsp;SEO Wireframe Pack</h3>
          <p class="lp-tier__body">
            Návod pokryl homepage. Pack pokryje celý e‑shop — sedm typů stránek
            s hotovými texty, kterým AI rozumí. Otevřete, dosaďte vlastní obsah,
            máte hotovo. Bez konzultantů.
          </p>
          <div class="lp-tier__footer">
            <div class="lp-tier__price">1&nbsp;490&nbsp;Kč <small>jednorázově, bez DPH</small></div>
            <a href="/pack/" class="lp-tier__cta">Koupit Pack&nbsp;→</a>
          </div>
        </article>

        <article class="lp-tier lp-tier--audit lp-tier--featured">
          <div class="lp-tier__head">
            <span class="lp-tier__num">Audit · uděláme to za vás</span>
            <span class="lp-tier__pill">★&nbsp;To nejlepší</span>
          </div>
          <h3 class="lp-tier__title">AI&nbsp;SEO audit od Sniperdesign</h3>
          <p class="lp-tier__body">
            Získáte přesný plán, co změnit na každé stránce, aby vás AI začala
            doporučovat zákazníkům. Víte, co AI hledá u vašeho oboru, kde má
            konkurence díry a jak ji předběhnout. Plus 60min konzultace.
            Výstup do 5 pracovních dní.
          </p>
          <span class="lp-tier__chip">✓ Postavili jsme 600+ e‑shopů na Upgates a Shoptet</span>
          <div class="lp-tier__footer">
            <div class="lp-tier__price">9&nbsp;990&nbsp;Kč <small>jednorázově, bez DPH</small></div>
            <a href="/audit/" class="lp-tier__cta">
              Objednat&nbsp;→
            </a>
          </div>
        </article>
      </div>
    </section>

    <!-- ===== FAQ ===== -->
    <section class="lp-section lp-section--alt">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">FAQ</span> Časté otázky</span>
        <h2 class="lp-section__title">Než si stáhnete PDF, <strong>tady jsou odpovědi</strong></h2>
      </header>

      <dl class="lp-faq">
        {faqJsonLd.mainEntity.map((q, i) => (
          <div class="lp-faq__item">
            <dt class="lp-faq__q">
              <span class="lp-faq__q-num">{String(i + 1).padStart(2, "0")}</span>
              <span>{q.name}</span>
            </dt>
            <dd class="lp-faq__a">{q.acceptedAnswer.text}</dd>
          </div>
        ))}
      </dl>
    </section>

    <!-- ===== FINAL CTA ===== -->
    <section class="lp-final">
      <div class="lp-final__inner">
        <h2 class="lp-final__title">
          Stáhněte si návod a <strong>postavte homepage tak, aby fungovala</strong>
        </h2>
        <p class="lp-final__lead">
          Wireframe, principy, mikro-case, typické chyby. Aplikujete za odpoledne.
          Žádný spam — odhlásíte se kdykoli jedním kliknutím.
        </p>
        <EmailCapture
          variant="hero"
          buttonLabel="Stáhnout AI SEO návod zdarma"
          leadSourceTag="Lead — Návod zdarma (final CTA)"
        />
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ===== Page root ===== */
  .lp {
    --lp-violet: oklch(0.55 0.25 305);
    --lp-magenta: oklch(0.62 0.27 335);
    --lp-gold: oklch(0.82 0.16 80);
  }

  /* ===== Section primitives ===== */
  .lp-section {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(3.5rem, 7vw, 6rem) var(--space-section-x);
  }
  .lp-section--alt {
    background: var(--color-paper-deep);
    max-width: none;
    padding-left: 0;
    padding-right: 0;
  }
  .lp-section--alt > * {
    max-width: var(--max-section);
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--space-section-x);
    padding-right: var(--space-section-x);
  }

  .lp-section__head {
    max-width: 50rem;
    margin-bottom: clamp(2.5rem, 4vw, 3.5rem);
  }
  .lp-section__title {
    font-family: var(--font-sans);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 250;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--color-ink);
    margin: 0.75rem 0 0.5rem;
  }
  .lp-section__title strong {
    font-weight: 600;
    color: var(--lp-violet);
  }
  .lp-section__lead {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0.75rem 0 0;
    max-width: 48rem;
  }

  /* ===== HERO ===== */
  .lp-hero {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) var(--space-section-x) clamp(2.5rem, 5vw, 4rem);
  }
  .lp-hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  @media (min-width: 960px) {
    .lp-hero__inner {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    }
  }
  .lp-hero__copy { min-width: 0; }
  .lp-hero__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--lp-violet);
    background: color-mix(in oklch, var(--lp-violet) 8%, transparent);
    padding: 0.4rem 0.875rem;
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }
  .lp-hero__title {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 250;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--color-ink);
    margin: 0 0 1.25rem;
  }
  .lp-hero__title strong {
    font-weight: 600;
    color: var(--lp-violet);
  }
  .lp-hero__urgency {
    /* Subtilní urgency řádek mezi H1 a leadem — tlak trhu / FOMO bez bullshitu */
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.5;
    color: var(--color-ink-muted);
    margin: 1.25rem 0 1.5rem;
    padding-left: 0.875rem;
    border-left: 3px solid var(--lp-magenta);
    max-width: 36rem;
  }
  .lp-hero__urgency strong {
    color: var(--lp-magenta);
    font-weight: 600;
  }
  .lp-hero__lead {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.5vw, 1.1875rem);
    font-weight: 350;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0 0 2rem;
    max-width: 36rem;
  }
  /* ===== Hero CTA card — primární akce (email + button) ===== */
  /* Vizuálně oddělené od ostatních hero prvků, aby uživatel nepřehlédl,
     že tohle je TO, co se má stát. Padding-safe-zone, soft shadow, accent
     border, světlá violet membrána pozadí. */
  .lp-hero__cta-card {
    margin: 2.25rem 0 0;
    padding: clamp(1.5rem, 2.5vw, 2rem) clamp(1.25rem, 2.5vw, 1.875rem);
    background:
      linear-gradient(180deg, color-mix(in oklch, var(--lp-violet) 6%, var(--color-paper)) 0%, var(--color-paper) 60%);
    border: 1px solid color-mix(in oklch, var(--lp-violet) 22%, var(--color-rule));
    border-radius: 18px;
    box-shadow:
      0 14px 40px -16px color-mix(in oklch, var(--lp-violet) 38%, transparent),
      0 2px 6px -2px color-mix(in oklch, var(--lp-violet) 15%, transparent),
      inset 0 1px 0 color-mix(in oklch, white 60%, transparent);
    max-width: 36rem;
  }
  .lp-hero__cta-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin: 0 0 1rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink-muted);
  }
  .lp-hero__cta-eyebrow-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.625rem;
    background: var(--lp-violet);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 999px;
  }
  .lp-hero__bullets {
    margin: 0 0 1.5rem;
    padding: 0;
    list-style: none;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-ink);
    display: grid;
    gap: 0.4rem;
  }
  .lp-hero__bullets li {
    position: relative;
    padding: 0 0 0 1.5rem;
  }
  .lp-hero__bullets li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.45em;
    width: 14px;
    height: 14px;
    background: no-repeat center / contain;
    /* checkmark v lp-violet barvě, sjednoceno s eyebrow pillem */
    background-image: url("data:image/svg+xml,%3Csvg width='14' height='14' viewBox='0 0 14 14' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M2 7L6 11L12 3' stroke='%237b3fc7' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  }

  /* ===== Mockup (6-page composite) ===== */
  .lp-hero__mockup {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 420px;
  }

  /* ===== Hero illustration (AI gen + baked-in SEO/GEO/AEO pills) ===== */
  .hero-illustration {
    width: 100%;
    max-width: 420px;
    margin: 0;
  }
  .hero-illustration img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ===== Features ===== */
  .lp-features {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 2vw, 1.5rem);
  }
  @media (min-width: 720px) {
    .lp-features { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1080px) {
    .lp-features { grid-template-columns: repeat(4, 1fr); }
  }
  .lp-feature {
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 12px;
    padding: 1.5rem 1.375rem 1.625rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .lp-feature:hover {
    border-color: color-mix(in oklch, var(--lp-violet) 35%, var(--color-rule));
    transform: translateY(-2px);
  }
  .lp-feature__num {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--lp-violet);
    margin-bottom: 0.875rem;
  }
  .lp-feature__title {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 0 0 0.5rem;
    line-height: 1.25;
  }
  .lp-feature__desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0;
  }

  /* ===== Audience ===== */
  .lp-audience {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem 2rem;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    max-width: 60rem;
