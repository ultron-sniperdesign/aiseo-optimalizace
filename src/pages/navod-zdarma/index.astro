---
import BaseLayout from "~/layouts/BaseLayout.astro";
import EmailCapture from "~/components/EmailCapture.astro";

const pageTitle = "Návod zdarma — Jak má vypadat homepage pro AI vyhledávání";
const pageDescription =
  "Stáhněte si zdarma 6stránkový PDF průvodce s wireframem, anotacemi a třemi principy. Jak má homepage vypadat, aby ji našel Google, citoval ChatGPT a vytahoval Google AI Overviews. Výměnou za e-mail.";

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Co je v PDF a kolik to má stránek?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Šest stran: cover, anotovaný wireframe homepage s 10 prvky, tři klíčové principy SEO/GEO/AEO, mikro-case před/po, pět nejčastějších chyb, a přehled rozšířeného packu a auditu od Sniperdesign. Strukturováno tak, abyste pochopili logiku za každým prvkem, ne jen jak vypadá.",
      },
    },
    {
      "@type": "Question",
      name: "Pro koho je návod určený?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Pro provozovatele webů a e-shopů, marketing/SEO specialisty, B2B agentury, copywritery, designéry a vývojáře, kteří chtějí, aby jejich homepage byla připravená nejen na klasický Google, ale i na AI vyhledávače jako ChatGPT, Perplexity nebo Google AI Overviews.",
      },
    },
    {
      "@type": "Question",
      name: "Jak rychle dostanu PDF po vyplnění e-mailu?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Okamžitě. Do několika sekund po odeslání formuláře vám pošleme e-mail s odkazem ke stažení. Pokud zprávu nevidíte, zkontrolujte složku Hromadné nebo Promo akce.",
      },
    },
    {
      "@type": "Question",
      name: "Funguje to i pro e-shop?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Tento návod cílí konkrétně na homepage firemního webu nebo služby. Pro e-shop platí stejné principy, ale jiná struktura sekcí — to pokrývá rozšířený Wireframe Pack za 1 490 Kč, kde je sedm typů stránek včetně produktové a kategoriální.",
      },
    },
    {
      "@type": "Question",
      name: "Co když chci, ať to za mě uděláte vy?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sniperdesign nabízí AI SEO audit za 9 990 Kč. Projdeme váš konkrétní web, najdeme problémy ve třech vrstvách (technika, obsah, autorita), předáme prioritní seznam úprav s odhadem dopadu a 60min konzultaci s vysvětlením. Výstup do 5 pracovních dní.",
      },
    },
    {
      "@type": "Question",
      name: "Můžu se kdykoli odhlásit z e-mailů?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ano. V každém e-mailu je odhlašovací odkaz, jedním kliknutím vás odstraníme z databáze. Žádné spamování, žádný důraz na neustálé prodávání.",
      },
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={faqJsonLd}>
  <main class="lp">
    <!-- ===== HERO ===== -->
    <section class="lp-hero">
      <div class="lp-hero__inner">
        <div class="lp-hero__copy">
          <span class="lp-hero__eyebrow">Návod zdarma · pro AI vyhledávání</span>
          <h1 class="lp-hero__title">
            Vaši zákazníci se dnes ptají ChatGPT.<br />
            <strong>Cituje umělá inteligence váš obsah?</strong>
          </h1>
          <p class="lp-hero__lead">
            Návod, podle kterého homepage začne fungovat v AI vyhledávání.
            Wireframe s anotacemi, tři principy a mikro‑case před/po.
            Aplikujete na svůj web během odpoledne — a začnete dostávat
            přístupy z AI, které byste jinak neviděli.
          </p>

          <EmailCapture
            variant="hero"
            buttonLabel="Otevřít a stáhnout PDF návod"
            leadSourceTag="Lead — Návod zdarma (homepage)"
          />

          <ul class="lp-hero__bullets" aria-label="Co dostanete">
            <li>✓ Wireframe homepage s 10 anotacemi (SEO / GEO / AEO)</li>
            <li>✓ Tři klíčové principy a mikro‑case před / po</li>
            <li>✓ 5 nejčastějších chyb, které vidíme u klientských webů</li>
          </ul>
        </div>

        <!-- 6-page mockup composite -->
        <div class="lp-hero__mockup" aria-hidden="true">
          <div class="lp-mockup">
            <img src="/products/wireframe-pack/page-6.jpg" alt="" class="lp-mockup__page lp-mockup__page--6" />
            <img src="/products/wireframe-pack/page-5.jpg" alt="" class="lp-mockup__page lp-mockup__page--5" />
            <img src="/products/wireframe-pack/page-4.jpg" alt="" class="lp-mockup__page lp-mockup__page--4" />
            <img src="/products/wireframe-pack/page-3.jpg" alt="" class="lp-mockup__page lp-mockup__page--3" />
            <img src="/products/wireframe-pack/page-2.jpg" alt="" class="lp-mockup__page lp-mockup__page--2" />
            <img src="/products/wireframe-pack/page-1.jpg" alt="" class="lp-mockup__page lp-mockup__page--1" />
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CO DOSTANETE ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">01</span> Co najdete v PDF</span>
        <h2 class="lp-section__title">
          Konkrétní struktura, podle které <strong>poznáte slabá místa svého webu</strong>
        </h2>
      </header>

      <div class="lp-features">
        <article class="lp-feature">
          <span class="lp-feature__num">1</span>
          <h3 class="lp-feature__title">Wireframe s 10 anotacemi</h3>
          <p class="lp-feature__desc">
            Homepage, podle které okamžitě poznáte slabá místa svého webu.
            Každý prvek má vysvětlení, jaký signál pro Google, ChatGPT
            a AI Overviews generuje a proč na něm záleží.
          </p>
        </article>

        <article class="lp-feature">
          <span class="lp-feature__num">2</span>
          <h3 class="lp-feature__title">Tři klíčové principy</h3>
          <p class="lp-feature__desc">
            Hlavní nadpis, krátká odpověď 40–60 slov a FAQ se strukturovanými daty.
            Tři vrstvy, díky kterým vás AI nástroje pochopí a ocitují — místo aby
            doporučily konkurenci.
          </p>
        </article>

        <article class="lp-feature">
          <span class="lp-feature__num">3</span>
          <h3 class="lp-feature__title">Mikro-case před / po</h3>
          <p class="lp-feature__desc">
            Konkrétní příklad transformace generického nadpisu na specifický.
            Ukazuje, jak malá změna v hlavním nadpisu mění, jestli vás AI doporučí
            — nebo přehlédne.
          </p>
        </article>

        <article class="lp-feature">
          <span class="lp-feature__num">4</span>
          <h3 class="lp-feature__title">Pět typických chyb</h3>
          <p class="lp-feature__desc">
            Diagnostický seznam, který okamžitě odhalí, co na vaší aktuální homepage
            brzdí výsledky. Z analýzy stovek webů — opakují se pořád stejné chyby.
          </p>
        </article>
      </div>
    </section>

    <!-- ===== PRO KOHO ===== -->
    <section class="lp-section lp-section--alt">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">02</span> Pro koho je to</span>
        <h2 class="lp-section__title">
          Návod sedí <strong>každému, kdo má co do činění s webem</strong>
        </h2>
      </header>

      <ul class="lp-audience">
        <li>
          <strong>Provozovatelé webů a e-shopů</strong> — víte, že je třeba něco
          změnit, ale nevíte, kde začít.
        </li>
        <li>
          <strong>SEO a marketing specialisté</strong> — potřebujete framework,
          který předáte klientovi nebo internímu týmu.
        </li>
        <li>
          <strong>Copywriteři, designéři, vývojáři</strong> — chcete jasnou
          šablonu, podle které pracovat na nové stránce bez vymýšlení od nuly.
        </li>
        <li>
          <strong>B2B agentury</strong> — hledáte vlastní pracovní rámec
          pro klientské weby v AI éře.
        </li>
      </ul>
    </section>

    <!-- ===== AUTHORITY ===== -->
    <section class="lp-section">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">03</span> Kdo za návodem stojí</span>
        <h2 class="lp-section__title">
          AI SEO je nové. <strong>Webová řemeslnost ne.</strong>
        </h2>
      </header>

      <div class="lp-authority">
        <a href="https://www.sniperdesign.cz/" target="_blank" rel="noopener" class="lp-authority__brand">
          <img src="/sniperdesign/logo-brand.svg" alt="Sniperdesign" />
        </a>
        <div class="lp-authority__body">
          <p class="lp-authority__lead">
            Sniperdesign je e-shopová agentura, která 8+ let staví a optimalizuje
            weby na Upgates a Shoptetu. AI vyhledávání je nová vrstva, kterou
            klientům přidáváme — a tohle PDF je první veřejný framework, který
            z toho vznikl.
          </p>
          <div class="lp-authority__stats">
            <div class="lp-stat">
              <span class="lp-stat__num">600+</span>
              <span class="lp-stat__label">e‑shopů, které jsme za roky postavili</span>
            </div>
            <div class="lp-stat">
              <span class="lp-stat__num">60</span>
              <span class="lp-stat__label">klientů aktivně spravujeme</span>
            </div>
            <div class="lp-stat">
              <span class="lp-stat__num">20</span>
              <span class="lp-stat__label">top klientů updatujeme<br /> na denní bázi</span>
            </div>
          </div>
          <div class="lp-authority__platforms">
            <span>Specialisté na <strong>Upgates</strong> a <strong>Shoptet</strong></span>
            <a href="https://www.sniperdesign.cz/reference" target="_blank" rel="noopener" class="lp-authority__refs">
              sniperdesign.cz/reference →
            </a>
          </div>
        </div>
      </div>

      <!-- Pioneer disclosure box — honest framing místo testimonialu, který zatím nemáme -->
      <aside class="lp-pioneer">
        <div class="lp-pioneer__label">
          <span class="lp-pioneer__dot" aria-hidden="true"></span>
          Poctivá rovnice
        </div>
        <p class="lp-pioneer__text">
          AI SEO v ČR řeší zatím málokdo soustavně. Nedostanete od nás testimonial
          klienta, který si přečetl ChatGPT, řekl „díky, Sniperdesign" a koupil
          si u nás 10 produktů — taková data zatím nikdo nemá.
          Dostanete framework od lidí, <strong>kteří weby staví a vědí, co AI
          potřebuje, aby pochopila, kdo jste.</strong> Stejnou logiku aplikujeme
          na téhle stránce, kterou právě čtete.
        </p>
      </aside>
    </section>

    <!-- ===== UPSELL TEASER ===== -->
    <section class="lp-section" id="pack">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">04</span> Co dál — pokud chcete víc</span>
        <span class="lp-section__proof">600+ e‑shopů · specialisté na Upgates a Shoptet</span>
        <h2 class="lp-section__title">
          Tohle PDF řeší jednu stránku. <strong>AI vyhledávání ale hodnotí celý web.</strong>
        </h2>
        <p class="lp-section__lead">
          Pokud má konkurence připravené i produktové stránky, kategorie a blog,
          dohoníte je těžko. Tady jsou dva způsoby, jak se vyrovnat.
        </p>
      </header>

      <div class="lp-tiers">
        <article class="lp-tier">
          <span class="lp-tier__num">Pack · pro celý web</span>
          <h3 class="lp-tier__title">Kompletní AI&nbsp;SEO Wireframe Pack</h3>
          <p class="lp-tier__body">
            Návod pokryl homepage. Pack pokryje celý e‑shop — sedm typů stránek
            s hotovými texty, kterým AI rozumí. Otevřete, dosaďte vlastní obsah,
            máte hotovo. Bez konzultantů.
          </p>
          <div class="lp-tier__footer">
            <div class="lp-tier__price">1&nbsp;490&nbsp;Kč <small>jednorázově, bez DPH</small></div>
            <a href="/pack/" class="lp-tier__cta">Koupit Pack&nbsp;→</a>
          </div>
        </article>

        <article class="lp-tier lp-tier--audit lp-tier--featured">
          <div class="lp-tier__head">
            <span class="lp-tier__num">Audit · uděláme to za vás</span>
            <span class="lp-tier__pill">★&nbsp;To nejlepší</span>
          </div>
          <h3 class="lp-tier__title">AI&nbsp;SEO audit od Sniperdesign</h3>
          <p class="lp-tier__body">
            Získáte přesný plán, co změnit na každé stránce, aby vás AI začala
            doporučovat zákazníkům. Víte, co AI hledá u vašeho oboru, kde má
            konkurence díry a jak ji předběhnout. Plus 60min konzultace.
            Výstup do 5 pracovních dní.
          </p>
          <span class="lp-tier__chip">✓ Postavili jsme 600+ e‑shopů na Upgates a Shoptet</span>
          <div class="lp-tier__footer">
            <div class="lp-tier__price">9&nbsp;990&nbsp;Kč <small>jednorázově, bez DPH</small></div>
            <a href="https://www.sniperdesign.cz/audity" target="_blank" rel="noopener" class="lp-tier__cta">
              Objednat&nbsp;→
            </a>
          </div>
        </article>
      </div>
    </section>

    <!-- ===== FAQ ===== -->
    <section class="lp-section lp-section--alt">
      <header class="lp-section__head">
        <span class="eyebrow"><span class="eyebrow__num">FAQ</span> Časté otázky</span>
        <h2 class="lp-section__title">Než si stáhnete PDF, <strong>tady jsou odpovědi</strong></h2>
      </header>

      <dl class="lp-faq">
        {faqJsonLd.mainEntity.map((q, i) => (
          <div class="lp-faq__item">
            <dt class="lp-faq__q">
              <span class="lp-faq__q-num">{String(i + 1).padStart(2, "0")}</span>
              <span>{q.name}</span>
            </dt>
            <dd class="lp-faq__a">{q.acceptedAnswer.text}</dd>
          </div>
        ))}
      </dl>
    </section>

    <!-- ===== FINAL CTA ===== -->
    <section class="lp-final">
      <div class="lp-final__inner">
        <h2 class="lp-final__title">
          Stáhněte si návod a <strong>postavte homepage tak, aby fungovala</strong>
        </h2>
        <p class="lp-final__lead">
          Wireframe, principy, mikro-case, typické chyby. Aplikujete za odpoledne.
          Žádný spam — odhlásíte se kdykoli jedním kliknutím.
        </p>
        <EmailCapture
          variant="hero"
          buttonLabel="Otevřít a stáhnout PDF návod"
          leadSourceTag="Lead — Návod zdarma (final CTA)"
        />
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ===== Page root ===== */
  .lp {
    --lp-violet: oklch(0.55 0.25 305);
    --lp-magenta: oklch(0.62 0.27 335);
    --lp-gold: oklch(0.82 0.16 80);
  }

  /* ===== Section primitives ===== */
  .lp-section {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(3.5rem, 7vw, 6rem) var(--space-section-x);
  }
  .lp-section--alt {
    background: var(--color-paper-deep);
    max-width: none;
    padding-left: 0;
    padding-right: 0;
  }
  .lp-section--alt > * {
    max-width: var(--max-section);
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--space-section-x);
    padding-right: var(--space-section-x);
  }

  .lp-section__head {
    max-width: 50rem;
    margin-bottom: clamp(2.5rem, 4vw, 3.5rem);
  }
  .lp-section__title {
    font-family: var(--font-sans);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 250;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--color-ink);
    margin: 0.75rem 0 0.5rem;
  }
  .lp-section__title strong {
    font-weight: 600;
    color: var(--lp-violet);
  }
  .lp-section__lead {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0.75rem 0 0;
    max-width: 48rem;
  }

  /* ===== HERO ===== */
  .lp-hero {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) var(--space-section-x) clamp(2.5rem, 5vw, 4rem);
  }
  .lp-hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  @media (min-width: 960px) {
    .lp-hero__inner {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    }
  }
  .lp-hero__copy { min-width: 0; }
  .lp-hero__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--lp-violet);
    background: color-mix(in oklch, var(--lp-violet) 8%, transparent);
    padding: 0.4rem 0.875rem;
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }
  .lp-hero__title {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 250;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--color-ink);
    margin: 0 0 1.25rem;
  }
  .lp-hero__title strong {
    font-weight: 600;
    color: var(--lp-violet);
  }
  .lp-hero__lead {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.5vw, 1.1875rem);
    font-weight: 350;
    line-height: 1.55;
    color: var(--color-ink-muted);
    margin: 0 0 2rem;
    max-width: 36rem;
  }
  .lp-hero__bullets {
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-ink-muted);
  }
  .lp-hero__bullets li {
    padding: 0.3125rem 0;
    color: var(--color-ink);
  }

  /* ===== Mockup (6-page composite) ===== */
  .lp-hero__mockup {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 380px;
  }
  .lp-mockup {
    position: relative;
    width: 100%;
    max-width: 480px;
    aspect-ratio: 1.05 / 1;
    transform: translateX(-2%);
  }
  .lp-mockup__page {
    position: absolute;
    width: 62%;
    aspect-ratio: 210 / 297;
    object-fit: cover;
    border-radius: 8px;
    box-shadow:
      0 1px 2px rgba(15, 22, 36, 0.06),
      0 8px 24px -8px rgba(15, 22, 36, 0.18),
      0 24px 64px -24px rgba(15, 22, 36, 0.22);
    transition: transform 0.4s ease;
  }
  .lp-mockup__page--1 {
    left: 0;
    top: 0;
    z-index: 6;
    transform: rotate(-4deg);
  }
  .lp-mockup__page--2 {
    left: 14%;
    top: 4%;
    z-index: 5;
    transform: rotate(-1.5deg);
    opacity: 0.96;
  }
  .lp-mockup__page--3 {
    left: 24%;
    top: 8%;
    z-index: 4;
    transform: rotate(1deg);
    opacity: 0.92;
  }
  .lp-mockup__page--4 {
    left: 32%;
    top: 12%;
    z-index: 3;
    transform: rotate(3deg);
    opacity: 0.88;
  }
  .lp-mockup__page--5 {
    left: 38%;
    top: 16%;
    z-index: 2;
    transform: rotate(5deg);
    opacity: 0.82;
  }
  .lp-mockup__page--6 {
    left: 42%;
    top: 20%;
    z-index: 1;
    transform: rotate(7deg);
    opacity: 0.76;
  }

  /* ===== Features ===== */
  .lp-features {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 2vw, 1.5rem);
  }
  @media (min-width: 720px) {
    .lp-features { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1080px) {
    .lp-features { grid-template-columns: repeat(4, 1fr); }
  }
  .lp-feature {
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 12px;
    padding: 1.5rem 1.375rem 1.625rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .lp-feature:hover {
    border-color: color-mix(in oklch, var(--lp-violet) 35%, var(--color-rule));
    transform: translateY(-2px);
  }
  .lp-feature__num {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--lp-violet);
    margin-bottom: 0.875rem;
  }
  .lp-feature__title {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 0 0 0.5rem;
    line-height: 1.25;
  }
  .lp-feature__desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
