---
/**
 * EmailCapture — formulář pro sběr emailů přes Ecomail.cz POST endpoint.
 *
 * Single source of truth pro email capture napříč webem. Pokud změníme
 * obsah (placeholder text, button label, GDPR text), propíše se všude,
 * kde je komponenta vložená.
 *
 * Použití:
 *   <EmailCapture />                                  → default texty
 *   <EmailCapture variant="hero" />                   → větší, primary
 *   <EmailCapture variant="inline" buttonLabel="..." />→ kompaktní v textu
 *
 * Ecomail integrace:
 * - POST endpoint: sniperdesign.ecomailapp.cz/public/subscribe/12/...
 * - Pole: email (visible) + name (hidden, default "Lead — Návod zdarma")
 * - Po submitu: redirect na URL nakonfigurovanou v Ecomail dashboardu
 *   (doporučeno: aiseo-optimalizace.cz/navod-zdarma/dekujeme/)
 *
 * Props:
 *   variant?: "hero" | "inline" | "footer"  — vizuální styl
 *   buttonLabel?: string                     — text tlačítka
 *   placeholder?: string                     — placeholder emailu
 *   leadSourceTag?: string                   — tag pro Ecomail name pole
 */
interface Props {
  variant?: "hero" | "inline" | "footer";
  buttonLabel?: string;
  placeholder?: string;
  leadSourceTag?: string;
}
const {
  variant = "hero",
  buttonLabel = "Otevřít a stáhnout PDF návod",
  placeholder = "vas@email.cz",
  leadSourceTag = "Lead — Návod zdarma",
} = Astro.props as Props;

const ECOMAIL_ENDPOINT =
  "https://sniperdesign.ecomailapp.cz/public/subscribe/12/04d9c95424b2f28aaece6f953bb0e4aa";
---

<form
  class={`ec-form ec-form--${variant}`}
  method="post"
  action={ECOMAIL_ENDPOINT}
  novalidate
>
  <!-- Hidden: name field (Ecomail vyžaduje, ale UX-wise nechceme zobrazovat) -->
  <input type="hidden" name="name" value={leadSourceTag} />
  <!-- Update existing kontakty (pokud už mail v listu je) -->
  <input type="hidden" name="updateExisting" value="1" />

  <div class="ec-form__row">
    <label class="ec-form__label" for={`ec-email-${variant}`}>
      Váš e-mail
    </label>
    <input
      id={`ec-email-${variant}`}
      class="ec-form__input"
      type="email"
      name="email"
      placeholder={placeholder}
      required
      autocomplete="email"
    />
    <button type="submit" class="ec-form__button">
      {buttonLabel}
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path
          d="M1 7H13M13 7L7 1M13 7L7 13"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </button>
  </div>

  <p class="ec-form__legal">
    Zadáním e-mailu souhlasíte se zasíláním našich e-mailů. Odhlásit se můžete kdykoli jedním kliknutím. <a
      href="https://www.sniperdesign.cz/zpracovani-osobnich-udaju"
      target="_blank"
      rel="noopener">Zásady zpracování osobních údajů</a>.
  </p>
</form>

<style>
  /* ===== EmailCapture — sdílené tokens ===== */
  .ec-form {
    --ec-violet: oklch(0.55 0.25 305);
    --ec-magenta: oklch(0.62 0.27 335);
    /* Green CTA — sjednoceno s welcome e-mailem (Tailwind green-500 → green-600) */
    --ec-green: oklch(0.72 0.2 145);          /* #22C55E */
    --ec-green-deep: oklch(0.6 0.18 145);     /* #16A34A */
    /* Gold tokens ponechány pro budoucí účely / jiné variants */
    --ec-gold: oklch(0.82 0.16 80);
    --ec-gold-deep: oklch(0.7 0.18 60);
    width: 100%;
  }
  .ec-form__row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: stretch;
  }
  .ec-form__label {
    /* Visually hidden, accessible */
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .ec-form__input {
    flex: 1 1 240px;
    min-height: 52px;
    padding: 0.875rem 1.125rem;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-ink);
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 999px;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .ec-form__input::placeholder {
    color: var(--color-ink-faint);
  }
  .ec-form__input:hover {
    border-color: var(--color-rule-strong);
  }
  .ec-form__input:focus {
    outline: none;
    border-color: var(--ec-violet);
    box-shadow: 0 0 0 3px color-mix(in oklch, var(--ec-violet) 18%, transparent);
  }
  .ec-form__input:invalid:not(:placeholder-shown) {
    border-color: oklch(0.55 0.2 25);
  }

  .ec-form__button {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    min-height: 52px;
    padding: 0.875rem 1.625rem;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    color: #ffffff;
    background: linear-gradient(135deg, var(--ec-green) 0%, var(--ec-green-deep) 100%);
    border: none;
    border-radius: 999px;
    cursor: pointer;
    transition: all 0.2s ease;
    letter-spacing: -0.005em;
    box-shadow: 0 4px 16px -4px color-mix(in oklch, var(--ec-green) 55%, transparent);
  }
  .ec-form__button:hover {
    background: linear-gradient(135deg, var(--ec-green-deep) 0%, var(--ec-green) 100%);
    color: #ffffff;
    transform: translateX(2px);
    box-shadow: 0 6px 20px -4px color-mix(in oklch, var(--ec-green) 70%, transparent);
  }
  .ec-form__button:active {
    transform: translateX(1px);
  }
  .ec-form__button:focus-visible {
    outline: 2px solid var(--ec-violet);
    outline-offset: 3px;
  }

  .ec-form__legal {
    margin: 0.875rem 0 0;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
    max-width: 36rem;
  }
  .ec-form__legal a {
    color: var(--color-ink-muted);
    text-decoration: underline;
    text-decoration-color: var(--color-rule-strong);
    text-underline-offset: 2px;
    transition: color 0.15s ease;
  }
  .ec-form__legal a:hover {
    color: var(--color-ink);
  }

  /* ===== Variant: HERO (větší, primary CTA na landing page) ===== */
  .ec-form--hero .ec-form__input {
    font-size: 1.0625rem;
    min-height: 56px;
  }
  .ec-form--hero .ec-form__button {
    min-height: 56px;
    font-size: 1.0625rem;
  }

  /* ===== Variant: INLINE (kompaktní v textu / sidebaru) ===== */
  .ec-form--inline .ec-form__input {
    min-height: 44px;
    font-size: 0.9375rem;
    padding: 0.625rem 1rem;
  }
  .ec-form--inline .ec-form__button {
    min-height: 44px;
    padding: 0.625rem 1.25rem;
    font-size: 0.9375rem;
  }
  .ec-form--inline .ec-form__legal {
    font-size: 0.75rem;
    margin-top: 0.625rem;
  }

  /* ===== Variant: FOOTER (na tmavém pozadí) ===== */
  .ec-form--footer .ec-form__input {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.18);
    color: oklch(0.985 0.004 250);
  }
  .ec-form--footer .ec-form__input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }
  .ec-form--footer .ec-form__legal {
    color: rgba(255, 255, 255, 0.65);
  }
  .ec-form--footer .ec-form__legal a {
    color: rgba(255, 255, 255, 0.85);
  }

  /* ===== Mobile: stack ===== */
  @media (max-width: 540px) {
    .ec-form__row {
      flex-direction: column;
    }
    .ec-form__input,
    .ec-form__button {
      width: 100%;
    }
  }
</style>
