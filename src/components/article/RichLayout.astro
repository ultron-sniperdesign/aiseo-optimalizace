---
/**
 * RichLayout — enhanced article layout (preview).
 *
 * Filozofie iterace 2:
 * - Přidat **užitečné** vrstvy (sticky TOC, reading progress, smooth anchors,
 *   collapsible FAQ) bez aggressive override existujících element-level stylů.
 * - Nepřepisovat H2/H3 design — base typography zůstává konzistentní napříč
 *   webem; rich layout přidává jen rámec, ne nadpisy.
 * - Nezasahovat do nested komponent (Insight, Compare, DoDont, Checklist)
 *   přes prose-level `:global()` selektory.
 *
 * Opt-in přes frontmatter `variant: rich`.
 */
import type { CollectionEntry } from "astro:content";

import Insight from "~/components/blocks/Insight.astro";
import Compare from "~/components/blocks/Compare.astro";
import CompareCol from "~/components/blocks/CompareCol.astro";
import DoDont from "~/components/blocks/DoDont.astro";
import Do from "~/components/blocks/Do.astro";
import Dont from "~/components/blocks/Dont.astro";
import Checklist from "~/components/blocks/Checklist.astro";
import Stepper from "~/components/blocks/Stepper.astro";
import SniperDesignSmallContact from "~/components/sniperdesign/SmallContact.astro";

interface Props {
  entry: CollectionEntry<"articles">;
  Content: any;
  crumbLabel: string;
  wordCountRounded: number;
  readingMinutes: number;
  faqCount: number;
}

const { entry, Content, crumbLabel, wordCountRounded, readingMinutes, faqCount } =
  Astro.props as Props;

/**
 * Build heading list z raw entry.body — H2 a H3.
 * Pozor: v body jsou i komponentové bloky (Compare, Insight) které mají
 * vlastní `<h3>` v rendrovaném HTML — ty NEjsou v markdown jako `### `,
 * takže parser je správně přeskočí. TOC a scrollspy pracuje jen
 * s markdown headingy.
 */
const rawBody = entry.body ?? "";
const headings = rawBody
  .split("\n")
  .map((line) => {
    const m2 = line.match(/^##\s+(.+?)\s*$/);
    const m3 = line.match(/^###\s+(.+?)\s*$/);
    if (!m2 && !m3) return null;
    const level = m2 ? 2 : 3;
    const raw = (m2?.[1] ?? m3?.[1] ?? "").trim();
    const text = raw
      .replace(/<[^>]+>/g, "")
      .replace(/[*_`]/g, "")
      .trim();
    const id = text
      .toLowerCase()
      .normalize("NFD")
      .replace(/[̀-ͯ]/g, "")
      .replace(/[^a-z0-9\s-]/g, "")
      .trim()
      .replace(/\s+/g, "-")
      .replace(/-+/g, "-")
      .slice(0, 64);
    return { level, text, id };
  })
  .filter(Boolean) as { level: 2 | 3; text: string; id: string }[];

/**
 * Sentinel reference — Astro CSS bundler vidí, že tyhle komponenty se
 * mohou v MDX vykreslit, a CSS pro ně bundluje do stránky. Bez explicitního
 * importu zde Astro CSS pro některé bloky (Insight) vynechá — uvnitř
 * `<Content />` rendrovaného přes RichLayout neumí dependency vystopovat.
 */
const _bundlerHints = [
  Insight,
  Compare,
  CompareCol,
  DoDont,
  Do,
  Dont,
  Checklist,
  Stepper,
];
---

<!-- READING PROGRESS BAR -->
<div class="reading-progress" aria-hidden="true">
  <div class="reading-progress__bar" id="reading-progress-bar"></div>
</div>

<div class="rich-page">
  <!-- HERO — clean, no stat tiles, žádný rail (chytřeji přidáme později) -->
  <section class="rhero">
    <nav class="rhero__crumbs" aria-label="Drobečková navigace">
      <a href="/">Úvod</a>
      <span class="crumb-sep">›</span>
      <a href="/blog/">Blog</a>
      <span class="crumb-sep">›</span>
      <span class="rhero__crumb-pill">{crumbLabel}</span>
    </nav>

    <h1 class="rhero__title">{entry.data.title}</h1>

    <p class="rhero__sub">{entry.data.description}</p>

    <div class="rhero__meta">
      <span>~{wordCountRounded.toLocaleString("cs-CZ")} slov</span>
      <span>{faqCount} častých otázek</span>
      <span>~{readingMinutes} minut čtení</span>
      <span>Aktualizováno: {entry.data.updated}</span>
    </div>
  </section>

  <!-- ANSWER BLOCK -->
  <section class="ranswer">
    <div class="ranswer__inner">
      <span class="ranswer__mark">Stručná odpověď</span>
      <p class="ranswer__text">{entry.data.answer}</p>
    </div>
  </section>

  <!-- ARTICLE GRID — sticky TOC (≥1080px) + content -->
  <div class="rgrid">
    {
      headings.length > 0 && (
        <aside class="rtoc" aria-label="Obsah článku">
          <div class="rtoc__sticky">
            <span class="rtoc__label">V tomto článku</span>
            <nav class="rtoc__nav">
              <ol class="rtoc__list">
                {headings.map((h) => (
                  <li class={`rtoc__item rtoc__item--h${h.level}`}>
                    <a href={`#${h.id}`} class="rtoc__link" data-toc-target={h.id}>
                      {h.text}
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          </div>
        </aside>
      )
    }

    <article class="rarticle">
      <div class="rarticle__prose" id="rich-article-prose" data-headings={JSON.stringify(headings)}>
        <Content />
      </div>
    </article>
  </div>

  <!-- SNIPERDESIGN SMALL CONTACT — nad FAQ -->
  <SniperDesignSmallContact />

  <!-- FAQ — collapsible <details> -->
  {
    entry.data.faq && entry.data.faq.length > 0 && (
      <section class="rfaq" aria-labelledby="rfaq-title">
        <header class="rfaq__head">
          <span class="rfaq__eyebrow">FAQ · {entry.data.faq.length} otázek</span>
          <h2 id="rfaq-title" class="rfaq__title">
            Časté otázky, které k tématu padají
          </h2>
        </header>

        <dl class="rfaq__list">
          {entry.data.faq.map((item, i) => (
            <details class="rfaq__item">
              <summary class="rfaq__q">
                <span class="rfaq__q-num">{String(i + 1).padStart(2, "0")}</span>
                <span class="rfaq__q-text">{item.q}</span>
                <span class="rfaq__q-chevron" aria-hidden="true">+</span>
              </summary>
              <div class="rfaq__a">{item.a}</div>
            </details>
          ))}
        </dl>
      </section>
    )
  }

  <section class="rback">
    <a href="/blog/" class="rback__primary">
      <span aria-hidden="true">←</span>
      Všechny články v blogu
    </a>
    <a href="/" class="rback__secondary">Zpět na úvod</a>
  </section>
</div>

<!-- CLIENT SCRIPT — assign IDs to headings + scrollspy + progress bar -->
<script is:inline>
  (function () {
    var prose = document.getElementById("rich-article-prose");
    if (!prose) return;
    var headingsData = [];
    try {
      headingsData = JSON.parse(prose.getAttribute("data-headings") || "[]");
    } catch (e) {}

    /**
     * Walk DOM h2/h3 in order, assign IDs from data sequentially.
     * Pozor: některé komponenty (Compare/CompareCol) renderují své vlastní h3 — ty
     * jsou v DOMu jako `.cmp__heading`. Skipujeme je, abychom IDs přiřadili
     * jen markdown headingům, které jsou v `headingsData`.
     */
    var domHeadings = prose.querySelectorAll("h2, h3");
    var idIdx = 0;
    domHeadings.forEach(function (h) {
      /* Skip h3 inside Compare/DoDont/Stepper components */
      if (h.classList.contains("cmp__heading")) return;
      if (h.closest("[class^='cmp']")) return;
      if (h.closest("[class^='dd-']")) return;
      if (h.closest(".stepper")) return;

      var level = h.tagName === "H2" ? 2 : 3;
      while (idIdx < headingsData.length && headingsData[idIdx].level !== level) idIdx++;
      if (idIdx < headingsData.length && headingsData[idIdx].level === level) {
        h.id = headingsData[idIdx].id;
        idIdx++;
      }
    });

    /* Scrollspy — highlight TOC link of nearest heading above scroll position. */
    var tocLinks = document.querySelectorAll("[data-toc-target]");
    var idToLink = {};
    tocLinks.forEach(function (a) {
      idToLink[a.getAttribute("data-toc-target")] = a;
    });
    var trackedHeadings = Array.prototype.filter.call(domHeadings, function (h) {
      return !!h.id;
    });

    function updateSpy() {
      var pos = window.scrollY + 140;
      var current = null;
      trackedHeadings.forEach(function (h) {
        if (h.offsetTop <= pos) current = h.id;
      });
      tocLinks.forEach(function (a) {
        a.classList.remove("is-active");
      });
      if (current && idToLink[current]) idToLink[current].classList.add("is-active");
    }

    /* Reading progress bar */
    var bar = document.getElementById("reading-progress-bar");
    function updateProgress() {
      if (!bar) return;
      var doc = document.documentElement;
      var max = doc.scrollHeight - doc.clientHeight;
      var pct = max > 0 ? Math.min(100, Math.max(0, (window.scrollY / max) * 100)) : 0;
      bar.style.width = pct + "%";
    }

    var ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(function () {
        updateSpy();
        updateProgress();
        ticking = false;
      });
    }
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
    onScroll();
  })();
</script>

<style>
  /* ===== DESIGN TOKENS — discipline color (analysis category default = SEO indigo) ===== */
  .rich-page {
    --d: var(--color-seo);
    --d-tint: var(--color-seo-tint);
    --d-soft: var(--color-seo-soft);
  }

  /* ===== READING PROGRESS BAR ===== */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: transparent;
    z-index: 100;
    pointer-events: none;
  }
  .reading-progress__bar {
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, var(--color-seo) 0%, var(--color-aio) 100%);
    transition: width 0.05s linear;
  }

  /* ===== HERO ===== */
  .rhero {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: clamp(3rem, 8vh, 5.5rem) var(--space-section-x) clamp(2rem, 4vw, 3rem);
  }
  .rhero__crumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    flex-wrap: wrap;
  }
  .rhero__crumbs a {
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .rhero__crumbs a:hover { color: var(--color-ink); }
  .rhero__crumb-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    background: var(--d-tint);
    color: var(--d);
    border: 1px solid var(--d-soft);
    border-radius: 999px;
    font-weight: 500;
  }
  .rhero__crumb-pill::before {
    content: "";
    width: 7px;
    height: 7px;
    background: var(--d);
    border-radius: 50%;
  }
  .crumb-sep { opacity: 0.4; }

  .rhero__title {
    font-family: var(--font-sans);
    font-weight: 250;
    font-size: clamp(1.875rem, 4.4vw, 3.75rem);
    letter-spacing: -0.045em;
    line-height: 1.02;
    margin: 0 0 1.25rem;
    max-width: 24ch;
    color: var(--color-ink);
  }
  .rhero__sub {
    font-family: var(--font-sans);
    font-weight: 350;
    font-size: clamp(1.0625rem, 1.5vw, 1.25rem);
    line-height: 1.55;
    color: var(--color-ink-muted);
    max-width: 50rem;
    margin: 0 0 2rem;
  }
  .rhero__meta {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
  }
  .rhero__meta span {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .rhero__meta span::before {
    content: "";
    width: 6px;
    height: 6px;
    background: var(--d);
    border-radius: 50%;
  }

  /* ===== ANSWER BLOCK ===== */
  .ranswer {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: 0 var(--space-section-x) clamp(2.5rem, 5vw, 3.5rem);
  }
  .ranswer__inner {
    background: var(--color-paper-deep);
    border: 1px solid var(--color-rule);
    border-left: 3px solid var(--d);
    border-radius: 10px;
    padding: clamp(1.5rem, 2.4vw, 2rem);
    max-width: 60rem;
  }
  .ranswer__mark {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--d);
    margin-bottom: 0.5rem;
  }
  .ranswer__text {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.6;
    color: var(--color-ink);
    margin: 0;
  }

  /* ===== ARTICLE GRID — TOC + content ===== */
  .rgrid {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: 0 var(--space-section-x) clamp(3rem, 6vw, 5rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 3vw, 3rem);
  }
  @media (min-width: 1080px) {
    .rgrid { grid-template-columns: 220px minmax(0, 1fr); }
  }

  /* ===== STICKY TOC ===== */
  .rtoc { display: none; }
  @media (min-width: 1080px) { .rtoc { display: block; } }
  .rtoc__sticky {
    position: sticky;
    top: 1.5rem;
    max-height: calc(100vh - 3rem);
    overflow-y: auto;
    padding-right: 0.5rem;
  }
  .rtoc__label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: 1rem;
  }
  .rtoc__list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 1px solid var(--color-rule);
  }
  .rtoc__item { margin: 0; }
  .rtoc__item--h3 { padding-left: 1rem; }
  .rtoc__link {
    display: block;
    padding: 0.4rem 0.875rem;
    font-family: var(--font-sans);
    font-size: 0.825rem;
    line-height: 1.4;
    color: var(--color-ink-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    margin-left: -1px;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }
  .rtoc__link:hover {
    color: var(--color-ink);
    background: var(--color-paper-deep);
  }
  .rtoc__link.is-active {
    color: var(--d);
    border-left-color: var(--d);
    font-weight: 500;
  }
  .rtoc__item--h2 > .rtoc__link {
    font-weight: 500;
    color: var(--color-ink);
  }

  /* ===== ARTICLE BODY — minimální override; žádný H2/H3 redesign, žádný counter ===== */
  .rarticle { min-width: 0; }
  .rarticle__prose {
    max-width: 50rem;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-ink);
  }
  /* H2 — base typography z [slug] classic, jen větší top margin pro vizuální gap mezi sekcemi */
  .rarticle__prose :global(h2) {
    font-family: var(--font-sans);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.022em;
    line-height: 1.18;
    margin: clamp(3rem, 5vw, 4rem) 0 1rem;
    color: var(--color-ink);
  }
  .rarticle__prose :global(h2:first-child) {
    margin-top: 0;
  }
  /* H3 — bold, větší, žádný counter, žádný card. Jednoduché. */
  .rarticle__prose :global(h3) {
    font-family: var(--font-sans);
    font-size: clamp(1.125rem, 1.6vw, 1.25rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
    margin: 2rem 0 0.75rem;
    color: var(--color-ink);
  }
  .rarticle__prose :global(p) { margin: 0 0 1.25rem; }
  .rarticle__prose :global(ul),
  .rarticle__prose :global(ol) { margin: 0 0 1.5rem; padding-left: 1.5rem; }
  .rarticle__prose :global(li) { margin-bottom: 0.5rem; }
  .rarticle__prose :global(a) {
    color: var(--d);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
  }
  .rarticle__prose :global(a:hover) { text-decoration-thickness: 2px; }
  .rarticle__prose :global(strong) { font-weight: 600; color: var(--color-ink); }

  .rarticle__prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0 2rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
  }
  .rarticle__prose :global(th),
  .rarticle__prose :global(td) {
    text-align: left;
    padding: 0.625rem 0.875rem;
    border-bottom: 1px solid var(--color-rule);
  }
  .rarticle__prose :global(th) {
    font-weight: 600;
    color: var(--color-ink);
    background: var(--color-paper-deep);
  }
  .rarticle__prose :global(blockquote) {
    border-left: 3px solid var(--d);
    background: var(--d-tint);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    color: var(--color-ink);
    border-radius: 0 6px 6px 0;
  }
  .rarticle__prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-paper-deep);
    padding: 0.1em 0.35em;
    border-radius: 3px;
    color: var(--color-ink);
  }
  .rarticle__prose :global(.hl) {
    background: linear-gradient(180deg, transparent 60%, var(--d-tint) 60%);
    padding: 0 0.15em;
  }

  /* ===== FAQ — collapsible <details> ===== */
  .rfaq {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: 0 var(--space-section-x) clamp(3rem, 6vw, 4.5rem);
  }
  .rfaq__head {
    max-width: 50rem;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }
  .rfaq__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--d);
    margin-bottom: 0.625rem;
  }
  .rfaq__title {
    font-family: var(--font-sans);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 250;
    letter-spacing: -0.025em;
    margin: 0;
    color: var(--color-ink);
    line-height: 1.1;
  }
  .rfaq__list {
    max-width: 60rem;
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .rfaq__item {
    border-top: 1px solid var(--color-rule);
    padding: 0;
  }
  .rfaq__item:last-child {
    border-bottom: 1px solid var(--color-rule);
  }
  .rfaq__item[open] {
    background: var(--color-paper-deep);
  }
  .rfaq__q {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-ink);
    cursor: pointer;
    list-style: none;
    padding: 1.25rem 1rem 1.25rem 0;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.875rem;
    align-items: baseline;
    line-height: 1.35;
    transition: color 0.15s ease;
  }
  .rfaq__q::-webkit-details-marker { display: none; }
  .rfaq__q:hover { color: var(--d); }
  .rfaq__q-num {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--d);
  }
  .rfaq__q-text { min-width: 0; }
  .rfaq__q-chevron {
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 250;
    color: var(--d);
    line-height: 1;
    transition: transform 0.2s ease;
  }
  .rfaq__item[open] .rfaq__q-chevron { transform: rotate(45deg); }
  .rfaq__a {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-ink-muted);
    padding: 0 1rem 1.5rem 2.625rem;
  }

  /* ===== BACK CTA ===== */
  .rback {
    max-width: var(--max-section);
    margin: 0 auto;
    padding: 0 var(--space-section-x) clamp(4rem, 8vw, 6rem);
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .rback__primary,
  .rback__secondary {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    padding: 0.75rem 1.25rem;
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .rback__primary {
    background: var(--d-tint);
    color: var(--d);
    border: 1px solid var(--d-soft);
  }
  .rback__primary:hover { background: var(--d-soft); }
  .rback__secondary { color: var(--color-ink-muted); }
  .rback__secondary:hover { color: var(--color-ink); }

  /* Smooth scroll for in-page anchors */
  :global(html) {
    scroll-behavior: smooth;
    scroll-padding-top: 3rem;
  }
  @media (prefers-reduced-motion: reduce) {
    :global(html) { scroll-behavior: auto; }
  }
</style>
