---
/**
 * SignalGrid — grid očíslovaných karet s kategoriemi + faktory.
 * Vhodné pro „4 kategorie ranking signálů", „4 vrstvy AI strategie" apod.
 *
 * Použití:
 *   <SignalGrid tone="seo" cards={[
 *     {
 *       title: "On-page faktory",
 *       icon: "page",   // page | content | tech | offpage | star | bolt
 *       items: [
 *         { key: "Title tag", desc: "50–60 znaků, primární klíčové slovo na začátku, brand na konci" },
 *         …
 *       ]
 *     },
 *     …
 *   ]} />
 */

interface SignalItem {
  key: string;
  desc: string;
}

interface SignalCard {
  title: string;
  icon?: "page" | "content" | "tech" | "offpage" | "star" | "bolt";
  items: SignalItem[];
}

interface Props {
  cards: SignalCard[];
  tone?: "accent" | "seo" | "geo" | "aeo" | "aio";
}

const { cards, tone = "accent" } = Astro.props;
---

<div class={`sg sg--${tone}`}>
  {
    cards.map((card, i) => (
      <article class="sg__card">
        <header class="sg__head">
          <span class="sg__num" aria-hidden="true">
            {String(i + 1).padStart(2, "0")}
          </span>
          {card.icon && (
            <span class="sg__icon" aria-hidden="true">
              {card.icon === "page" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="4" y="3" width="16" height="18" rx="2" />
                  <line x1="8" y1="8" x2="16" y2="8" />
                  <line x1="8" y1="12" x2="16" y2="12" />
                  <line x1="8" y1="16" x2="13" y2="16" />
                </svg>
              )}
              {card.icon === "content" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 6h16" />
                  <path d="M4 10h12" />
                  <path d="M4 14h16" />
                  <path d="M4 18h10" />
                  <circle cx="20" cy="18" r="2" />
                </svg>
              )}
              {card.icon === "tech" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="3" />
                  <path d="M12 2v3" />
                  <path d="M12 19v3" />
                  <path d="M2 12h3" />
                  <path d="M19 12h3" />
                  <path d="M5 5l2 2" />
                  <path d="M17 17l2 2" />
                  <path d="M5 19l2-2" />
                  <path d="M17 7l2-2" />
                </svg>
              )}
              {card.icon === "offpage" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                  <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.72-1.71" />
                </svg>
              )}
              {card.icon === "star" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                </svg>
              )}
              {card.icon === "bolt" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
                </svg>
              )}
            </span>
          )}
          <h3 class="sg__title">{card.title}</h3>
        </header>
        <ul class="sg__list">
          {card.items.map((item) => (
            <li class="sg__item">
              <strong class="sg__key">{item.key}</strong>
              <span class="sg__sep" aria-hidden="true">—</span>
              <span class="sg__desc">{item.desc}</span>
            </li>
          ))}
        </ul>
      </article>
    ))
  }
</div>

<style>
  .sg {
    --tone: var(--color-accent);
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin: 1.75rem 0;
  }
  @media (min-width: 720px) {
    .sg { grid-template-columns: repeat(2, 1fr); }
  }
  .sg--seo { --tone: var(--color-seo); }
  .sg--geo { --tone: var(--color-geo); }
  .sg--aeo { --tone: var(--color-aeo); }
  .sg--aio { --tone: var(--color-aio); }

  .sg__card {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding: 1.25rem 1.375rem 1.375rem;
    background: var(--color-paper);
    border: 1px solid var(--color-rule-strong);
    border-radius: 10px;
    position: relative;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .sg__card:hover {
    border-color: color-mix(in oklch, var(--tone) 50%, var(--color-rule-strong));
    transform: translateY(-1px);
  }

  .sg__head {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid var(--color-rule);
  }
  .sg__num {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    width: 2rem;
    height: 2rem;
    background: color-mix(in oklch, var(--tone) 12%, var(--color-paper));
    color: var(--tone);
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .sg__icon {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--tone);
    flex-shrink: 0;
    display: inline-flex;
  }
  .sg__icon svg { width: 100%; height: 100%; }
  .sg__title {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 0;
    flex: 1;
  }

  .sg__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .sg__item {
    font-family: var(--font-sans);
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--color-ink);
    padding-left: 0.875rem;
    border-left: 2px solid color-mix(in oklch, var(--tone) 25%, var(--color-rule));
  }
  .sg__key { font-weight: 600; color: var(--color-ink); }
  .sg__sep { margin: 0 0.4rem; color: var(--color-ink-faint); }
  .sg__desc { color: var(--color-ink-muted); }
</style>
