---
/**
 * Prompt — kopírovatelný AI prompt box.
 * Pro „vyzkoušejte sami v ChatGPT" sekce. JS handler v PromptList.
 *
 * Použití (uvnitř <PromptList>):
 *   <Prompt text="co je GEO Generative Engine Optimization" />
 */

interface Props {
  text: string;
  tone?: "seo" | "geo" | "aeo" | "aio";
}

const { text, tone = "geo" } = Astro.props;
---

<div class={`prmt prmt--${tone}`}>
  <code class="prmt__text">{text}</code>
  <button type="button" class="prmt__copy" data-prompt-copy>
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
      <rect x="4" y="3" width="8" height="9" rx="1" stroke="currentColor" stroke-width="1.4"/>
      <path d="M2 9V2C2 1.45 2.45 1 3 1H9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </svg>
    Kopírovat
  </button>
</div>

<style>
  .prmt {
    --pr-tone: var(--color-geo);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--color-paper-deep);
    border: 1px solid var(--color-rule);
    border-radius: 8px;
    padding: 0.625rem 0.875rem;
  }
  .prmt--seo { --pr-tone: var(--color-seo); }
  .prmt--aeo { --pr-tone: var(--color-aeo); }
  .prmt--aio { --pr-tone: var(--color-aio); }
  .prmt__text {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-ink);
    background: none;
    padding: 0;
    word-break: break-word;
  }
  .prmt__copy {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--pr-tone);
    background: oklch(from var(--pr-tone) l c h / 0.08);
    border: 1px solid oklch(from var(--pr-tone) l c h / 0.25);
    border-radius: 6px;
    padding: 0.4rem 0.75rem;
    cursor: pointer;
    transition: background 0.15s ease;
    white-space: nowrap;
  }
  .prmt__copy:hover {
    background: oklch(from var(--pr-tone) l c h / 0.15);
  }
  .prmt__copy.prmt__copy--done {
    background: oklch(0.4 0.12 145);
    color: white;
    border-color: oklch(0.4 0.12 145);
  }
</style>
