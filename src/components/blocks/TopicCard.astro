---
/**
 * TopicCard — cross-link karta na hluboký subtopic z pillar sekce.
 *
 * Použití (pouze MDX nebo jiné Astro):
 *   <TopicCard
 *     tone="seo"
 *     href="/seo-nastroje-2026/"
 *     eyebrow="Tutorial · 12 min"
 *     title="SEO nástroje 2026: kompletní průvodce"
 *   >
 *     Sedm kategorií, reálné ceny v roce 2026, 4 doporučené stacky.
 *   </TopicCard>
 *
 * Tone: accent (default) | seo | geo | aeo | aio
 *
 * Klíčový rozdíl proti Insight — title je prominentní H3 (ne malý uppercase label),
 * celá karta je odkaz, dominuje vizuálně, ne se rozplývá v body textu.
 */
interface Props {
  tone?: "accent" | "seo" | "geo" | "aeo" | "aio";
  href: string;
  title: string;
  eyebrow?: string;
}

const { tone = "accent", href, title, eyebrow } = Astro.props;
const isExternal = href.startsWith("http");
---

<a
  class={`tcard tcard--${tone}`}
  href={href}
  {...(isExternal ? { target: "_blank", rel: "noopener" } : {})}
>
  <div class="tcard__head">
    {eyebrow && <span class="tcard__eyebrow">{eyebrow}</span>}
    <h3 class="tcard__title">{title}</h3>
  </div>
  <div class="tcard__desc"><slot /></div>
  <span class="tcard__cta">
    Číst <span class="tcard__arrow" aria-hidden="true">→</span>
  </span>
</a>

<style>
  .tcard {
    --tone: var(--color-accent);
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    margin: 1.5rem 0;
    padding: 1.5rem 1.625rem 1.375rem;
    background: var(--color-paper);
    border: 1px solid var(--color-rule-strong);
    border-left: 4px solid var(--tone);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease,
      background 0.18s ease;
  }
  .tcard--seo { --tone: var(--color-seo); }
  .tcard--geo { --tone: var(--color-geo); }
  .tcard--aeo { --tone: var(--color-aeo); }
  .tcard--aio { --tone: var(--color-aio); }

  .tcard:hover,
  .tcard:focus-visible {
    transform: translateY(-2px);
    border-color: color-mix(in oklch, var(--tone) 50%, var(--color-rule-strong));
    background: color-mix(in oklch, var(--tone) 3%, var(--color-paper));
    box-shadow: 0 6px 18px -8px color-mix(in oklch, var(--tone) 30%, transparent);
    outline: none;
  }

  .tcard__head {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .tcard__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tone);
  }
  .tcard__title {
    font-family: var(--font-sans);
    font-size: clamp(1.125rem, 1.4vw, 1.3125rem);
    font-weight: 600;
    letter-spacing: -0.012em;
    line-height: 1.25;
    margin: 0;
    color: var(--color-ink);
  }
  .tcard:hover .tcard__title,
  .tcard:focus-visible .tcard__title {
    color: var(--tone);
  }

  .tcard__desc {
    font-family: var(--font-sans);
    font-size: 0.975rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
  }
  .tcard__desc :global(p) {
    margin: 0;
  }
  .tcard__desc :global(strong) {
    font-weight: 600;
    color: var(--color-ink);
  }

  .tcard__cta {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--tone);
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .tcard__arrow {
    transition: transform 0.18s ease;
  }
  .tcard:hover .tcard__arrow,
  .tcard:focus-visible .tcard__arrow {
    transform: translateX(3px);
  }
</style>
