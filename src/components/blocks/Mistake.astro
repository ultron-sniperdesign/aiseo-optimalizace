---
/**
 * Mistake — karta častého omylu / anti-patternu s číslem + fix line.
 * Pro „Časté chyby" sekce. Červený border + číslo + popis + jak to napravit.
 *
 * Použití (uvnitř <MistakeGrid>):
 *   <Mistake num="01" title="Optimalizace bez SEO baseline" fix="Nejdřív technické SEO, pak GEO playbook.">
 *     Bez Google indexace vás AI engine vůbec nezacituje.
 *   </Mistake>
 */

interface Props {
  num: string;
  title: string;
  fix?: string;
}

const { num, title, fix } = Astro.props;
---

<article class="mistake">
  <span class="mistake__num">{num}</span>
  <h3 class="mistake__title">{title}</h3>
  <div class="mistake__desc"><slot /></div>
  {fix && <p class="mistake__fix"><strong>Fix:</strong> {fix}</p>}
</article>

<style>
  .mistake {
    position: relative;
    background: var(--color-paper);
    border: 1px solid oklch(0.85 0.06 25);
    border-left: 4px solid oklch(0.6 0.18 25);
    border-radius: 8px;
    padding: 1rem 1.125rem 1.125rem;
    height: 100%;
  }
  .mistake__num {
    position: absolute;
    top: 0.625rem;
    right: 0.875rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: oklch(0.6 0.18 25);
    opacity: 0.6;
  }
  .mistake__title {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    color: oklch(0.35 0.12 25);
    margin: 0 0 0.5rem;
    padding-right: 2rem;
    line-height: 1.3;
  }
  .mistake__desc {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-ink-muted);
    margin-bottom: 0.625rem;
  }
  .mistake__desc :global(p) { margin: 0 0 0.5rem; }
  .mistake__desc :global(p:last-child) { margin: 0; }
  .mistake__desc :global(strong) { color: var(--color-ink); font-weight: 600; }
  .mistake__desc :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-paper-deep);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }
  .mistake__fix {
    font-family: var(--font-sans);
    font-size: 0.825rem;
    line-height: 1.5;
    color: var(--color-ink);
    margin: 0;
    padding-top: 0.5rem;
    border-top: 1px dashed oklch(0.85 0.06 25);
  }
  .mistake__fix strong { color: oklch(0.35 0.12 25); font-weight: 700; }
</style>
